<Window x:Class="JoinGameAfk.LogoEditor.GitHubBannerPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GitHub banner preview"
        Width="1040"
        Height="660"
        MinWidth="760"
        MinHeight="500"
        Background="#05070D"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#0B0E14" />
        <SolidColorBrush x:Key="BorderBrush" Color="#232836" />
        <SolidColorBrush x:Key="TextBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#CBD5E1" />

        <DrawingBrush x:Key="PreviewCheckerBrush"
                      TileMode="Tile"
                      Viewbox="0,0,24,24"
                      ViewboxUnits="Absolute"
                      Viewport="0,0,24,24"
                      ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#F8FAFC">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,24,24" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#CBD5E1">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,12,12" />
                                <RectangleGeometry Rect="12,12,12,12" />
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Background" Value="#1E293B" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="GitHub banner"
                           FontSize="21"
                           FontWeight="SemiBold"
                           Margin="0,0,0,2" />
                <TextBlock x:Name="SizeText"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="12" />
            </StackPanel>
            <TextBlock Grid.Column="1"
                       Text="scaled preview"
                       Foreground="#93C5FD"
                       FontSize="12"
                       VerticalAlignment="Bottom"
                       Margin="16,0,0,3" />
        </Grid>

        <Border Grid.Row="1"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12"
                Margin="0,14,0,14">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <Border Width="960"
                        Height="480"
                        Background="{StaticResource PreviewCheckerBrush}">
                    <Image x:Name="BannerImage"
                           Width="960"
                           Height="480"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           SnapsToDevicePixels="True" />
                </Border>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="PathText"
                       Foreground="{StaticResource MutedTextBrush}"
                       FontSize="12"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center"
                       Margin="0,0,18,0" />

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Save default"
                        Click="SaveDefaultButton_Click"
                        Background="#2563EB"
                        BorderBrush="#60A5FA"
                        Margin="0,0,8,0" />
                <Button Content="Save as..."
                        Click="SaveAsButton_Click"
                        Margin="0,0,8,0" />
                <Button Content="Close"
                        Click="CloseButton_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
