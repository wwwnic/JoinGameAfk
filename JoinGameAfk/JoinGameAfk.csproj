<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>Assets\logo.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="Assets\logo.ico" />
    <Content Include="Assets\champions.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <TargetPath>champions.json</TargetPath>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <Folder Include="MVP\Model\" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\JoinGameAfk.Common\JoinGameAfk.Common.csproj" />
    <ProjectReference Include="..\JoinGameAfk.Plugin\JoinGameAfk.Plugin.csproj" />
  </ItemGroup>

</Project>
