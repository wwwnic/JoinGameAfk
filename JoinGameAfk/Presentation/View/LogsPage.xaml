<Page x:Class="JoinGameAfk.View.LogsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">
    <Border Background="{DynamicResource AppSurfaceBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="12">
        <TextBox x:Name="LogTextBox"
                 Background="Transparent"
                 Foreground="{DynamicResource AccentGreenTextBrush}"
                 CaretBrush="{DynamicResource AccentGreenTextBrush}"
                 FontFamily="Cascadia Mono, Consolas, Courier New"
                 FontSize="12"
                 IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Disabled"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 BorderThickness="0">
            <TextBox.Resources>
                <Style TargetType="{x:Type ScrollBar}"
                       BasedOn="{StaticResource SlimVerticalScrollBarStyle}" />
            </TextBox.Resources>
        </TextBox>
    </Border>
</Page>
