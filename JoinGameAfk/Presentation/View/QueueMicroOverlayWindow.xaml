<Window x:Class="JoinGameAfk.View.QueueMicroOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:JoinGameAfk.View.Controls"
        Title="Queue Micro Overlay"
        Width="56"
        Height="56"
        MinWidth="56"
        MinHeight="56"
        MaxWidth="56"
        MaxHeight="56"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True">
    <Grid Background="Transparent"
          MouseLeftButtonDown="DragSurface_MouseLeftButtonDown">
        <Border x:Name="OverlayPanel"
                Background="{DynamicResource AppSurfaceBrush}"
                BorderBrush="{DynamicResource AccentBlueBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Opacity="0.96"
                Padding="6"
                SnapsToDevicePixels="True">
            <controls:PhaseStatusIndicator x:Name="MicroPhaseIndicator"
                                           Width="42"
                                           Height="42"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           SnapsToDevicePixels="True" />
        </Border>
    </Grid>
</Window>
