<Page x:Class="JoinGameAfk.Presentation.View.Settings.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource AppSurfaceBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="12"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            VerticalAlignment="Center">
                    <TextBlock Text="Settings"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="General app behavior, alert sounds, and overlays live in separate settings pages."
                               Style="{StaticResource FieldHintStyle}"
                               Margin="0,3,18,0" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button x:Name="GeneralSettingsSectionButton"
                            Content="General"
                            Click="GeneralSettingsSectionButton_Click"
                            Style="{StaticResource TabButtonStyle}"
                            MinWidth="92"
                            AutomationProperties.Name="General settings page" />
                    <Button x:Name="SoundSettingsSectionButton"
                            Content="Sounds"
                            Click="SoundSettingsSectionButton_Click"
                            Style="{StaticResource TabButtonStyle}"
                            MinWidth="92"
                            AutomationProperties.Name="Sound settings page" />
                    <Button x:Name="OverlaySettingsSectionButton"
                            Content="Overlays"
                            Click="OverlaySettingsSectionButton_Click"
                            Style="{StaticResource TabButtonStyle}"
                            MinWidth="92"
                            AutomationProperties.Name="Overlay settings page" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Frame x:Name="GeneralSettingsFrame"
                   NavigationUIVisibility="Hidden"
                   Background="Transparent"
                   BorderThickness="0" />

            <Frame x:Name="SoundSettingsFrame"
                   NavigationUIVisibility="Hidden"
                   Background="Transparent"
                   BorderThickness="0"
                   Visibility="Collapsed" />

            <Frame x:Name="OverlaySettingsFrame"
                   NavigationUIVisibility="Hidden"
                   Background="Transparent"
                   BorderThickness="0"
                   Visibility="Collapsed" />
        </Grid>
    </Grid>
</Page>
