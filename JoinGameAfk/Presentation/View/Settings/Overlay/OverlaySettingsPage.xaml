<Page x:Class="JoinGameAfk.Presentation.View.Settings.Overlay.OverlaySettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource AppSurfaceBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="18,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Overlays"
                               Style="{StaticResource PageTitleStyle}" />
                    <TextBlock Text="Control the queue micro overlay and champion select mini overlay."
                               Style="{StaticResource PageDescriptionStyle}"
                               Margin="0,4,24,0" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="Reset Defaults"
                            Click="ResetDefaultsButton_Click"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="18,10"
                            ToolTip="Restore default overlay settings." />
                    <Button x:Name="CancelOverlayChangesButton"
                            Content="Cancel Changes"
                            Click="CancelChangesButton_Click"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="18,10"
                            Margin="8,0,0,0"
                            IsEnabled="False"
                            ToolTip="Discard unsaved overlay changes." />
                    <Button Content="Save Overlays"
                            Click="SaveButton_Click"
                            Background="{DynamicResource AccentGreenBrush}"
                            Style="{StaticResource AccentButtonStyle}"
                            Padding="18,10"
                            Margin="8,0,0,0"
                            ToolTip="Save overlay settings." />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2"
                      Style="{StaticResource StableVerticalScrollViewerStyle}">
            <StackPanel>
                <Border Style="{StaticResource SectionCardStyle}"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Queue Overlay"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="Animation-only micro overlay for matchmaking and ready checks."
                                   Style="{StaticResource SectionDescriptionStyle}"
                                   Margin="0,4,0,0" />

                        <Border Style="{StaticResource SettingRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Show queue overlay"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Text="Automatically shows during matchmaking and ready check."
                                               Style="{StaticResource FieldHintStyle}" />
                                </StackPanel>

                                <CheckBox x:Name="QueueOverlayEnabledCheckBox"
                                          Grid.Column="2"
                                          Style="{StaticResource AppCheckBoxStyle}"
                                          VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource SettingRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Queue overlay size"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Text="Scales the animation-only queue overlay."
                                               Style="{StaticResource FieldHintStyle}" />
                                </StackPanel>

                                <Grid Grid.Column="2"
                                      Width="230">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="52" />
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="QueueOverlayScaleSlider"
                                            Grid.Column="0"
                                            Minimum="80"
                                            Maximum="180"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            VerticalAlignment="Center" />
                                    <TextBlock x:Name="QueueOverlayScaleValueText"
                                               Grid.Column="1"
                                               Text="100%"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextAlignment="Right"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource SettingRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Queue overlay stays on top"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Text="Keeps the queue animation visible above other windows."
                                               Style="{StaticResource FieldHintStyle}" />
                                </StackPanel>

                                <CheckBox x:Name="QueueOverlayTopmostCheckBox"
                                          Grid.Column="2"
                                          Style="{StaticResource AppCheckBoxStyle}"
                                          VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCardStyle}"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Champion Select Overlay"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="Pick/ban overlay window behavior and visible sections."
                                   Style="{StaticResource SectionDescriptionStyle}"
                                   Margin="0,4,0,0" />

                        <UniformGrid Columns="2"
                                     Margin="0,10,0,0">
                            <Border Background="{DynamicResource AppSurfaceRaisedBrush}"
                                    BorderBrush="{DynamicResource AppStrongBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="0,0,5,0">
                                <StackPanel>
                                    <CheckBox x:Name="PickBanAutoShowCheckBox"
                                              Content="Open when champion select starts"
                                              Style="{StaticResource AppCheckBoxStyle}" />
                                    <CheckBox x:Name="PickBanAutoCloseCheckBox"
                                              Content="Close when champion select is over"
                                              Style="{StaticResource AppCheckBoxStyle}"
                                              Margin="0,10,0,0" />
                                    <CheckBox x:Name="PickBanOpenOnStartupCheckBox"
                                              Content="Open on app startup"
                                              Style="{StaticResource AppCheckBoxStyle}"
                                              Margin="0,10,0,0" />
                                    <CheckBox x:Name="PickBanTopmostCheckBox"
                                              Content="Stay on top"
                                              Style="{StaticResource AppCheckBoxStyle}"
                                              Margin="0,10,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource AppSurfaceRaisedBrush}"
                                    BorderBrush="{DynamicResource AppStrongBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="5,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Visible sections"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <UniformGrid Columns="2"
                                                 Margin="0,10,0,0">
                                        <CheckBox x:Name="PickBanShowPhaseSummaryCheckBox"
                                                  Content="Targets"
                                                  Style="{StaticResource AppCheckBoxStyle}"
                                                  Margin="0,0,14,8" />
                                        <CheckBox x:Name="PickBanShowPhaseTimerCheckBox"
                                                  Content="Phase timer"
                                                  Style="{StaticResource AppCheckBoxStyle}"
                                                  Margin="0,0,0,8" />
                                        <CheckBox x:Name="PickBanShowLockTimerCheckBox"
                                                  Content="Lock timer"
                                                  Style="{StaticResource AppCheckBoxStyle}"
                                                  Margin="0,0,14,8" />
                                        <CheckBox x:Name="PickBanShowPickPlanCheckBox"
                                                  Content="Pick plan"
                                                  Style="{StaticResource AppCheckBoxStyle}"
                                                  Margin="0,0,0,8" />
                                        <CheckBox x:Name="PickBanShowBanPlanCheckBox"
                                                  Content="Ban plan"
                                                  Style="{StaticResource AppCheckBoxStyle}" />
                                    </UniformGrid>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Border Style="{StaticResource SettingRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Champion select overlay opacity"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Text="Adjusts the pick/ban overlay panel opacity."
                                               Style="{StaticResource FieldHintStyle}" />
                                </StackPanel>

                                <Grid Grid.Column="2"
                                      Width="230">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="52" />
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="PickBanOpacitySlider"
                                            Grid.Column="0"
                                            Minimum="55"
                                            Maximum="100"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            VerticalAlignment="Center" />
                                    <TextBlock x:Name="PickBanOpacityValueText"
                                               Grid.Column="1"
                                               Text="94%"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextAlignment="Right"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="3">
            <Border x:Name="FloatingOverlayStatusBar"
                    HorizontalAlignment="Stretch"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Height="54"
                    Padding="14,8"
                    Margin="0,12,0,0"
                    Visibility="Collapsed">
                <TextBlock x:Name="FloatingOverlayStatusText"
                           FontSize="13"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </Border>

            <Border x:Name="DirtyOverlayBar"
                    HorizontalAlignment="Stretch"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AccentGreenBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Height="48"
                    Padding="14,8"
                    Margin="0,12,0,0"
                    Visibility="Collapsed">
                <TextBlock Text="Unsaved overlay changes. Use Save Overlays or Cancel Changes above."
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </Border>
        </StackPanel>
    </Grid>
</Page>
