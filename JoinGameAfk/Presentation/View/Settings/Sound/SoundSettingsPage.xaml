<Page x:Class="JoinGameAfk.Presentation.View.Settings.Sound.SoundSettingsPage"
      x:Name="RootPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      AllowDrop="True"
      PreviewMouseMove="Page_PreviewMouseMove"
      PreviewMouseLeftButtonUp="Page_PreviewMouseLeftButtonUp"
      PreviewMouseWheel="Page_PreviewMouseWheel">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Geometry x:Key="SoundInfiniteIconGeometry">M17.27,16.73a4.67,4.67,0,0,1-3.34-1.39L12,13.41l-1.93,1.93a4.72,4.72,0,0,1-6.69,0h0a4.73,4.73,0,1,1,6.69-6.68L12,10.59l1.93-1.93a4.73,4.73,0,0,1,6.69,6.68h0A4.71,4.71,0,0,1,17.27,16.73ZM13.41,12l1.93,1.93a2.8,2.8,0,0,0,3.86,0h0a2.73,2.73,0,0,0,0-3.86,2.8,2.8,0,0,0-3.86,0ZM6.73,9.27A2.73,2.73,0,0,0,4.8,13.93h0a2.8,2.8,0,0,0,3.86,0L10.59,12,8.66,10.07A2.74,2.74,0,0,0,6.73,9.27Z</Geometry>

        <Style x:Key="SoundWorkspacePanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="9" />
        </Style>

        <Style x:Key="SoundClearDropPanelStyle"
               TargetType="Border"
               BasedOn="{StaticResource SoundWorkspacePanelStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=RootPage, Path=IsSoundClearDropTarget}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DangerSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource DangerAccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SoundClearDropOverlayStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=RootPage, Path=IsSoundClearDropTarget}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SoundLabRailStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceInsetBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppMutedBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10,8" />
        </Style>

        <Style x:Key="SoundSearchClearButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,5,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
            <Setter Property="ToolTip" Value="Clear sound search" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{Binding Background, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=Transparent}"
                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=Transparent}"
                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=0}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource AppInputHoverBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SoundCueClearButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
            <Setter Property="ToolTip" Value="Clear this sound" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{Binding Background, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=Transparent}"
                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=Transparent}"
                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=0}"
                                CornerRadius="11">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource DangerSurfaceRaisedBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource DangerTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SoundCueEditButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{DynamicResource AppSurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppMutedBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
            <Setter Property="ToolTip" Value="Edit cue settings" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{Binding Background, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=Transparent}"
                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=Transparent}"
                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=1}"
                                CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource AccentBlueActionBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextInverseBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.72" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                                <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SoundInfiniteToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{DynamicResource AppSurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppMutedBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="ToolTip" Value="Loop this countdown cue until it is replaced or auto-lock happens." />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ButtonBorder"
                                Background="{Binding Background, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=Transparent}"
                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=Transparent}"
                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=0}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=#94A3B8}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource AccentBlueSoftBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource AccentBlueActionBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextInverseBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                                <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SoundBoardHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="SoundGroupHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextSoftBrush}" />
            <Setter Property="Margin" Value="2,10,0,6" />
        </Style>

        <Style x:Key="SoundCueRowStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppMutedBorderBrush}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="MinHeight" Value="74" />
            <Setter Property="Cursor" Value="Arrow" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                    <Setter Property="Opacity" Value="0.62" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSoundDropTarget}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TargetDropHoverBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource TargetDropHoverBrush}" />
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSoundDragging}" Value="True">
                    <Setter Property="Opacity" Value="0.78" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SoundCueStateBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SoundCueStateBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SoundLibraryChoiceButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="116" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Margin" Value="0,0,4,6" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Background" Value="{DynamicResource AppInputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppStrongBorderBrush}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Cursor" Value="SizeAll" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="ButtonBorder"
                                    Background="{Binding Background, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=Transparent}"
                                    BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=Transparent}"
                                    BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=1}"
                                    CornerRadius="7"
                                    Padding="{Binding Padding, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=0}">
                                <ContentPresenter HorizontalAlignment="{Binding HorizontalContentAlignment, RelativeSource={RelativeSource TemplatedParent}}"
                                                  VerticalAlignment="{Binding VerticalContentAlignment, RelativeSource={RelativeSource TemplatedParent}}"
                                                  TextElement.Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=#E2E8F0}" />
                            </Border>
                            <Border x:Name="KeyboardFocusRing"
                                    BorderBrush="{DynamicResource AccentBluePaleBrush}"
                                    BorderThickness="2"
                                    CornerRadius="7"
                                    IsHitTestVisible="False"
                                    Opacity="0" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="KeyboardFocusRing" Property="Opacity" Value="1" />
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsLastPreviewed}" Value="True">
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsDragging}" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource TargetDropHoverBackgroundBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource TargetDropHoverBrush}" />
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.72" />
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            </DataTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                                <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PaneGridSplitterStyle" TargetType="GridSplitter">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="ShowsPreview" Value="False" />
            <Setter Property="ResizeBehavior" Value="PreviousAndNext" />
            <Setter Property="ResizeDirection" Value="Columns" />
            <Setter Property="Focusable" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridSplitter">
                        <Grid Background="Transparent">
                            <Border x:Name="SplitterRail"
                                    Width="2"
                                    HorizontalAlignment="Center"
                                    Background="{DynamicResource AppMutedBorderBrush}"
                                    CornerRadius="1"
                                    Opacity="0.7" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SplitterRail" Property="Width" Value="4" />
                                <Setter TargetName="SplitterRail" Property="Background" Value="{DynamicResource AccentBlueBrush}" />
                                <Setter TargetName="SplitterRail" Property="Opacity" Value="0.95" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="SplitterRail" Property="Width" Value="4" />
                                <Setter TargetName="SplitterRail" Property="Background" Value="{DynamicResource AccentBlueBrush}" />
                                <Setter TargetName="SplitterRail" Property="Opacity" Value="0.95" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="SplitterRail" Property="Width" Value="4" />
                                <Setter TargetName="SplitterRail" Property="Background" Value="{DynamicResource AccentBlueSoftBrush}" />
                                <Setter TargetName="SplitterRail" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource AppSurfaceBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="18,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Sound Studio"
                                       Style="{StaticResource PageTitleStyle}" />
                            <TextBlock Text="Queue, phase, action, and lock-warning cue setup."
                                       Style="{StaticResource PageDescriptionStyle}"
                                       Margin="0,4,24,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <Button x:Name="ResetSoundDefaultsButton"
                                    Content="Reset Sounds"
                                    Click="ResetSoundDefaultsButton_Click"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="18,10"
                                    ToolTip="Restore default sound alert mode, volume, sounds, and warning timing." />

                            <Button x:Name="CancelSoundChangesButton"
                                    Content="Cancel Changes"
                                    Click="CancelSoundChangesButton_Click"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="18,10"
                                    Margin="10,0,0,0"
                                    IsEnabled="False"
                                    ToolTip="Discard unsaved sound changes and return to the saved values." />

                            <Button x:Name="SaveButton"
                                    Content="Save Sounds"
                                    Click="SaveButton_Click"
                                    Background="{DynamicResource AccentGreenBrush}"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Padding="24,10"
                                    Margin="10,0,0,0" />
                        </StackPanel>
                    </Grid>
        </Border>

        <Grid x:Name="ContentGrid"
              Grid.Row="2"
              ClipToBounds="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="7*" MinWidth="520" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="300" MinWidth="260" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="SoundPickerPanel"
                            Grid.Column="2"
                            AllowDrop="True"
                            Padding="16"
                            Style="{StaticResource SoundClearDropPanelStyle}">
                        <Grid ClipToBounds="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                    <Border x:Name="SoundAlertsMasterRow"
                            Grid.Row="0"
                            Style="{StaticResource AutomationMasterRowStyle}"
                            Margin="0">
                                <StackPanel>
                                    <CheckBox x:Name="SoundAlertsEnabledCheckBox"
                                              Content="Sound alerts on"
                                              Style="{StaticResource AutomationMasterCheckBoxStyle}"
                                              Checked="SoundAlertsEnabledCheckBox_Changed"
                                              Unchecked="SoundAlertsEnabledCheckBox_Changed"
                                              ToolTip="Turn every sound alert on or off." />

                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="50" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="Master volume"
                                                   Style="{StaticResource FieldLabelStyle}" />
                                        <TextBlock x:Name="SoundAlertVolumeValueText"
                                                   Grid.Column="1"
                                                   Text="100%"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   TextAlignment="Right"
                                                   VerticalAlignment="Center" />
                                    </Grid>

                                    <Slider x:Name="SoundAlertVolumeSlider"
                                            Margin="0,6,0,0"
                                            Minimum="0"
                                            Maximum="100"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            VerticalAlignment="Center"
                                            ToolTip="Master volume for every sound alert and preview. Each cue volume is multiplied by this value." />
                                    <TextBlock Text="Applies to every sound alert, cue preview, and assigned cue."
                                               Style="{StaticResource FieldHintStyle}"
                                               Margin="0,4,0,0" />

                                    <Grid Margin="0,10,0,0">
                                        <TextBox x:Name="SoundPickerSearchBox"
                                                 TextChanged="SoundPickerSearchBox_TextChanged"
                                                 Padding="10,6,34,6"
                                                 Style="{StaticResource SearchTextBoxStyle}"
                                                 ToolTip="Filter sound names." />
                                        <Path Width="14"
                                              Height="14"
                                              Margin="0,0,10,0"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False"
                                              Stretch="Uniform"
                                              Stroke="{DynamicResource TextSubtleBrush}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Data="M10.5,18 A7.5,7.5 0 1 1 10.5,3 A7.5,7.5 0 0 1 10.5,18 M16,16 L21,21">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ElementName=SoundPickerSearchBox, Path=Text}" Value="">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                        <Button x:Name="SoundPickerSearchClearButton"
                                                AutomationProperties.Name="Clear sound search"
                                                Click="SoundPickerSearchClearButton_Click">
                                            <Button.Style>
                                                <Style TargetType="Button"
                                                       BasedOn="{StaticResource SoundSearchClearButtonStyle}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ElementName=SoundPickerSearchBox, Path=Text}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <Path Width="10"
                                                  Height="10"
                                                  Stretch="Uniform"
                                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  StrokeThickness="2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  Data="M6,6 L18,18 M18,6 L6,18" />
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border x:Name="SoundPickerChoicesPanel"
                                    Grid.Row="2"
                                    Background="{DynamicResource AppSurfaceInsetBrush}"
                                    BorderBrush="{DynamicResource AppStrongBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="8">
                                <Grid>
                                    <ScrollViewer x:Name="SoundPickerScrollViewer"
                                                  Style="{StaticResource StableVerticalScrollViewerStyle}">
                                        <ItemsControl x:Name="SoundPickerItemsControl">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button PreviewMouseLeftButtonDown="SoundPickerChoiceButton_PreviewMouseLeftButtonDown"
                                                            PreviewMouseMove="SoundPickerChoiceButton_PreviewMouseMove"
                                                            PreviewMouseLeftButtonUp="SoundPickerChoiceButton_PreviewMouseLeftButtonUp"
                                                            Style="{StaticResource SoundLibraryChoiceButtonStyle}"
                                                            ToolTip="{Binding DisplayName}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="24" />
                                                                <ColumnDefinition Width="8" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>

                                                            <Border Grid.Column="0"
                                                                    Width="22"
                                                                    Height="22"
                                                                    BorderThickness="1"
                                                                    CornerRadius="11"
                                                                    VerticalAlignment="Center">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="{DynamicResource AppSurfaceRaisedBrush}" />
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource AppMutedBorderBrush}" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsLoopable}" Value="True">
                                                                                <Setter Property="Background" Value="{DynamicResource AccentBlueActionBrush}" />
                                                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <Grid>
                                                                    <Path Width="9"
                                                                          Height="11"
                                                                          Margin="2,0,0,0"
                                                                          HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"
                                                                          Data="M0,0 L9,5.5 L0,11 Z"
                                                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                          Stretch="Uniform">
                                                                        <Path.Style>
                                                                            <Style TargetType="Path">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsLoopable}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Path.Style>
                                                                    </Path>
                                                                    <Path Width="15"
                                                                          Height="15"
                                                                          Data="{StaticResource SoundInfiniteIconGeometry}"
                                                                          Fill="{DynamicResource TextInverseBrush}"
                                                                          Stretch="Uniform"
                                                                          ToolTip="Designed for infinite playback.">
                                                                        <Path.Style>
                                                                            <Style TargetType="Path">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsLoopable}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Path.Style>
                                                                    </Path>
                                                                </Grid>
                                                            </Border>

                                                            <TextBlock Grid.Column="2"
                                                                       Text="{Binding DisplayName}"
                                                                       FontSize="10.5"
                                                                       FontWeight="SemiBold"
                                                                       TextWrapping="Wrap"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       LineHeight="11.5"
                                                                       LineStackingStrategy="BlockLineHeight"
                                                                       MaxHeight="24"
                                                                       VerticalAlignment="Center" />
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <Border x:Name="SoundPickerEmptyState"
                                            Background="{DynamicResource AppSurfaceRaisedBrush}"
                                            BorderBrush="{DynamicResource AppStrongBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="18"
                                            Visibility="Collapsed">
                                        <TextBlock Text="No sounds match that search."
                                                   Style="{StaticResource FieldHintStyle}"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Grid.RowSpan="3"
                                    Style="{StaticResource SoundClearDropOverlayStyle}"
                                    Background="{DynamicResource DangerOverlayBrush}"
                                    BorderBrush="{DynamicResource DangerAccentBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    IsHitTestVisible="False">
                                <Viewbox Width="42"
                                         Height="42"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Stroke="{DynamicResource DangerTextPaleBrush}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Data="M3,6 L5,6 M5,6 L21,6 M19,6 L21,6 M8,6 L8,4 L16,4 L16,6 M6,6 L7,21 L17,21 L18,6 M10,11 L10,17 M14,11 L14,17" />
                                    </Canvas>
                                </Viewbox>
                            </Border>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Column="1"
                                  Style="{StaticResource PaneGridSplitterStyle}" />

                    <Border x:Name="CustomAlertsSection"
                            Grid.Column="0"
                            Style="{StaticResource SoundWorkspacePanelStyle}">
                        <Grid ClipToBounds="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0"
                                  Margin="4,0,4,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="202" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="58" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="34" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="Cue"
                                           Style="{StaticResource SoundBoardHeaderTextStyle}" />
                                <TextBlock Grid.Column="2"
                                           Text="Sound"
                                           Style="{StaticResource SoundBoardHeaderTextStyle}" />
                                <TextBlock Grid.Column="4"
                                           Text="Start"
                                           Style="{StaticResource SoundBoardHeaderTextStyle}" />
                                <TextBlock Grid.Column="6"
                                           Text="Edit"
                                           Style="{StaticResource SoundBoardHeaderTextStyle}" />
                            </Grid>

                            <ScrollViewer x:Name="SoundAlertListScrollViewer"
                                          Grid.Row="2"
                                          Style="{StaticResource StableVerticalScrollViewerStyle}">
                                <StackPanel x:Name="SoundAlertCustomPanel">
                                    <ItemsControl x:Name="SoundAlertGroupItemsControl">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               Style="{StaticResource SoundGroupHeaderTextStyle}" />
                                                    <ItemsControl ItemsSource="{Binding Alerts}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Style="{StaticResource SoundCueRowStyle}"
                                                                        AllowDrop="True"
                                                                        DragOver="SoundAlertRow_DragOver"
                                                                        DragLeave="SoundAlertRow_DragLeave"
                                                                        Drop="SoundAlertRow_Drop"
                                                                        ToolTip="Drop a sound here.">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="12" />
                                                                            <ColumnDefinition Width="202" />
                                                                            <ColumnDefinition Width="12" />
                                                                            <ColumnDefinition Width="58" />
                                                                            <ColumnDefinition Width="8" />
                                                                            <ColumnDefinition Width="34" />
                                                                        </Grid.ColumnDefinitions>

                                                                        <StackPanel Grid.Column="0"
                                                                                    VerticalAlignment="Center">
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="*" />
                                                                                    <ColumnDefinition Width="8" />
                                                                                    <ColumnDefinition Width="Auto" />
                                                                                </Grid.ColumnDefinitions>

                                                                                <TextBlock Grid.Column="0"
                                                                                           Text="{Binding DisplayName}"
                                                                                           Style="{StaticResource FieldLabelStyle}"
                                                                                           TextTrimming="CharacterEllipsis"
                                                                                           VerticalAlignment="Center" />

                                                                                <Border Grid.Column="2"
                                                                                        Background="{DynamicResource AppInputFocusBrush}"
                                                                                        BorderBrush="{DynamicResource AccentGreenBrush}"
                                                                                        ToolTip="Cue is enabled.">
                                                                                    <Border.Style>
                                                                                        <Style TargetType="Border" BasedOn="{StaticResource SoundCueStateBadgeStyle}">
                                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </Border.Style>
                                                                                    <StackPanel Orientation="Horizontal">
                                                                                        <Path Width="10"
                                                                                              Height="10"
                                                                                              Margin="0,0,4,0"
                                                                                              Data="M5,12 L10,17 L19,7"
                                                                                              Stroke="{DynamicResource AccentGreenTextBrush}"
                                                                                              StrokeThickness="2.4"
                                                                                              StrokeStartLineCap="Round"
                                                                                              StrokeEndLineCap="Round"
                                                                                              StrokeLineJoin="Round"
                                                                                              Stretch="Uniform"
                                                                                              VerticalAlignment="Center" />
                                                                                        <TextBlock Text="On"
                                                                                                   Foreground="{DynamicResource AccentGreenTextBrush}"
                                                                                                   Style="{StaticResource SoundCueStateBadgeTextStyle}" />
                                                                                    </StackPanel>
                                                                                </Border>

                                                                                <Border Grid.Column="2"
                                                                                        Background="{DynamicResource DangerSurfaceBrush}"
                                                                                        BorderBrush="{DynamicResource DangerAccentBrush}"
                                                                                        ToolTip="Cue is disabled.">
                                                                                    <Border.Style>
                                                                                        <Style TargetType="Border" BasedOn="{StaticResource SoundCueStateBadgeStyle}">
                                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </Border.Style>
                                                                                    <StackPanel Orientation="Horizontal">
                                                                                        <Path Width="9"
                                                                                              Height="9"
                                                                                              Margin="0,0,4,0"
                                                                                              Data="M6,6 L18,18 M18,6 L6,18"
                                                                                              Stroke="{DynamicResource DangerTextBrush}"
                                                                                              StrokeThickness="2.2"
                                                                                              StrokeStartLineCap="Round"
                                                                                              StrokeEndLineCap="Round"
                                                                                              Stretch="Uniform"
                                                                                              VerticalAlignment="Center" />
                                                                                        <TextBlock Text="Off"
                                                                                                   Foreground="{DynamicResource DangerTextBrush}"
                                                                                                   Style="{StaticResource SoundCueStateBadgeTextStyle}" />
                                                                                    </StackPanel>
                                                                                </Border>
                                                                            </Grid>
                                                                            <TextBlock Text="{Binding Description}"
                                                                                       Style="{StaticResource FieldHintStyle}"
                                                                                       TextWrapping="Wrap"
                                                                                       Margin="0,3,0,0" />
                                                                        </StackPanel>

                                                                        <Border Grid.Column="2"
                                                                                Background="{DynamicResource AppInputBrush}"
                                                                                BorderBrush="{DynamicResource AppStrongBorderBrush}"
                                                                                BorderThickness="1"
                                                                                CornerRadius="7"
                                                                                PreviewMouseLeftButtonDown="SoundAlertSoundCell_PreviewMouseLeftButtonDown"
                                                                                PreviewMouseMove="SoundAlertSoundCell_PreviewMouseMove"
                                                                                PreviewMouseLeftButtonUp="SoundAlertSoundCell_PreviewMouseLeftButtonUp"
                                                                                Padding="10,8"
                                                                                ToolTip="Click to preview. Drag this sound."
                                                                                VerticalAlignment="Center">
                                                                            <Border.Style>
                                                                                <Style TargetType="Border">
                                                                                    <Setter Property="Cursor" Value="SizeAll" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HasAssignedSound}" Value="False">
                                                                                            <Setter Property="Cursor" Value="Arrow" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Border.Style>
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="Auto" />
                                                                                    <ColumnDefinition Width="8" />
                                                                                    <ColumnDefinition Width="*" />
                                                                                    <ColumnDefinition Width="6" />
                                                                                    <ColumnDefinition Width="Auto" />
                                                                                </Grid.ColumnDefinitions>

                                                                                <Path Grid.Column="0"
                                                                                      Width="9"
                                                                                      Height="11"
                                                                                      Data="M0,0 L9,5.5 L0,11 Z"
                                                                                      Fill="{DynamicResource TextMutedBrush}"
                                                                                      Stretch="Uniform"
                                                                                      VerticalAlignment="Center"
                                                                                      Visibility="{Binding HasAssignedSound, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                                                <TextBlock Grid.Column="2"
                                                                                           Text="{Binding SelectedSoundDisplayName}"
                                                                                           FontSize="12"
                                                                                           FontWeight="SemiBold"
                                                                                           Foreground="{DynamicResource TextSoftBrush}"
                                                                                           TextTrimming="CharacterEllipsis"
                                                                                           VerticalAlignment="Center"
                                                                                           Visibility="{Binding HasAssignedSound, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                                                <TextBlock Grid.Column="2"
                                                                                           Text="No sound"
                                                                                           FontSize="12"
                                                                                           FontWeight="SemiBold"
                                                                                           Foreground="{DynamicResource TextSubtleBrush}"
                                                                                           TextTrimming="CharacterEllipsis"
                                                                                           VerticalAlignment="Center">
                                                                                    <TextBlock.Style>
                                                                                        <Style TargetType="TextBlock">
                                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding HasAssignedSound}" Value="False">
                                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </TextBlock.Style>
                                                                                </TextBlock>
                                                                                <Button Grid.Column="4"
                                                                                        Click="ClearSoundAlertButton_Click"
                                                                                        Style="{StaticResource SoundCueClearButtonStyle}"
                                                                                        Visibility="{Binding HasAssignedSound, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                                    <Path Width="9"
                                                                                          Height="9"
                                                                                          Stretch="Uniform"
                                                                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                                          StrokeThickness="2"
                                                                                          StrokeStartLineCap="Round"
                                                                                          StrokeEndLineCap="Round"
                                                                                          Data="M6,6 L18,18 M18,6 L6,18" />
                                                                                </Button>
                                                                            </Grid>
                                                                        </Border>

                                                                        <TextBlock Grid.Column="4"
                                                                                   Text="{Binding ThresholdText, StringFormat={}{0}s}"
                                                                                   FontSize="12"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                                                   TextAlignment="Right"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   VerticalAlignment="Center"
                                                                                   Visibility="{Binding HasThreshold, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                                   ToolTip="This cue starts this many seconds before auto-lock." />

                                                                        <Button Grid.Column="6"
                                                                                Click="SoundCueEditButton_Click"
                                                                                Style="{StaticResource SoundCueEditButtonStyle}"
                                                                                AutomationProperties.Name="Edit sound cue settings">
                                                                            <Path Width="13"
                                                                                  Height="13"
                                                                                  Stretch="Uniform"
                                                                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                                  StrokeThickness="2"
                                                                                  StrokeStartLineCap="Round"
                                                                                  StrokeEndLineCap="Round"
                                                                                  StrokeLineJoin="Round"
                                                                                  Data="M4,16 L4,20 L8,20 L18.5,9.5 L14.5,5.5 L4,16 M13.5,6.5 L17.5,10.5" />
                                                                        </Button>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
        </Grid>

        <StackPanel Grid.Row="3">
            <Border x:Name="FloatingSoundStatusBar"
                    HorizontalAlignment="Stretch"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Height="48"
                    Padding="14,8"
                    Margin="0,12,0,0"
                    Visibility="Collapsed">
                <TextBlock x:Name="FloatingSoundStatusText"
                           FontSize="13"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </Border>

            <Border x:Name="DirtySoundBar"
                    HorizontalAlignment="Stretch"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AccentGreenBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Height="48"
                    Padding="14,8"
                    Margin="0,12,0,0"
                    Visibility="Collapsed">
                <TextBlock Text="Unsaved sound changes. Use Save Sounds or Cancel Changes above."
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </Border>
        </StackPanel>

        <Border x:Name="SoundCueEditorOverlay"
                Grid.RowSpan="4"
                Panel.ZIndex="40"
                Background="#80000000"
                Visibility="Collapsed"
                MouseDown="SoundCueEditorOverlay_MouseDown">
            <Border Width="500"
                    MaxHeight="560"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Sound cue"
                                       Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock x:Name="SoundCueEditorTitleTextBlock"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <Button Grid.Column="2"
                                Content="Restore Defaults"
                                Click="SoundCueEditorRestoreDefaultsButton_Click"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="14,8"
                                ToolTip="Restore this cue's default enabled state, sound, volume, start time, and loop behavior." />

                        <Button Grid.Column="4"
                                Width="30"
                                Height="30"
                                Padding="0"
                                Click="SoundCueEditorCloseButton_Click"
                                Style="{StaticResource SoundSearchClearButtonStyle}"
                                ToolTip="Close cue settings"
                                AutomationProperties.Name="Close cue settings">
                            <Path Width="11"
                                  Height="11"
                                  Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="M6,6 L18,18 M18,6 L6,18" />
                        </Button>
                    </Grid>

                    <Border Grid.Row="2"
                            Background="{DynamicResource AppSurfaceInsetBrush}"
                            BorderBrush="{DynamicResource AppStrongBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12"
                            Cursor="Hand"
                            MouseLeftButtonUp="SoundCueEditorSoundCard_MouseLeftButtonUp"
                            ToolTip="Click to preview this cue.">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="34"
                                    Height="34"
                                    Background="{DynamicResource AppSurfaceRaisedBrush}"
                                    BorderBrush="{DynamicResource AppMutedBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="17">
                                <Path Width="13"
                                      Height="15"
                                      Margin="2,0,0,0"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Data="M0,0 L13,7.5 L0,15 Z"
                                      Fill="{DynamicResource TextSecondaryBrush}"
                                      Stretch="Uniform" />
                            </Border>

                            <StackPanel Grid.Column="2"
                                        VerticalAlignment="Center">
                                <TextBlock x:Name="SoundCueEditorSoundTextBlock"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="SoundCueEditorDescriptionTextBlock"
                                           Margin="0,3,0,0"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSoftBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="4">
                        <CheckBox x:Name="SoundCueEditorEnabledCheckBox"
                                  Content="Cue enabled"
                                  Style="{StaticResource AutomationMasterCheckBoxStyle}"
                                  Checked="SoundCueEditorEnabledCheckBox_Changed"
                                  Unchecked="SoundCueEditorEnabledCheckBox_Changed" />

                        <Border Margin="0,12,0,0"
                                Background="{DynamicResource AppInputBrush}"
                                BorderBrush="{DynamicResource AppStrongBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Cue volume"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock x:Name="SoundCueEditorVolumeValueText"
                                               Grid.Column="1"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextAlignment="Right" />
                                </Grid>

                                <Slider x:Name="SoundCueEditorVolumeSlider"
                                        Margin="0,8,0,0"
                                        Minimum="0"
                                        Maximum="100"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        ValueChanged="SoundCueEditorVolumeSlider_ValueChanged"
                                        ToolTip="Cue volume. Combined with the master sound alert volume." />
                            </StackPanel>
                        </Border>

                        <Border x:Name="SoundCueEditorLeadPanel"
                                Margin="0,12,0,0"
                                Background="{DynamicResource AppInputBrush}"
                                BorderBrush="{DynamicResource AppStrongBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="76" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Cue start"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Text="Starts this many seconds before auto-lock."
                                               Style="{StaticResource FieldHintStyle}"
                                               Margin="0,3,0,0" />
                                </StackPanel>

                                <TextBox x:Name="SoundCueEditorLeadTextBox"
                                         Grid.Column="2"
                                         Width="64"
                                         HorizontalAlignment="Right"
                                         TextChanged="SoundCueEditorLeadTextBox_TextChanged"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         VerticalAlignment="Center"
                                         ToolTip="This cue starts this many seconds before auto-lock." />
                            </Grid>
                        </Border>

                        <Border x:Name="SoundCueEditorInfinitePanel"
                                Margin="0,12,0,0"
                                Background="{DynamicResource AppInputBrush}"
                                BorderBrush="{DynamicResource AppStrongBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">
                            <CheckBox x:Name="SoundCueEditorInfiniteCheckBox"
                                      Content="Loop until the next cue or auto-lock"
                                      Style="{StaticResource AutomationMasterCheckBoxStyle}"
                                      Checked="SoundCueEditorInfiniteCheckBox_Changed"
                                      Unchecked="SoundCueEditorInfiniteCheckBox_Changed"
                                      ToolTip="Loop this countdown cue until it is replaced or auto-lock happens." />
                        </Border>
                    </StackPanel>

                </Grid>
            </Border>
        </Border>

        <Canvas Grid.RowSpan="4"
                Panel.ZIndex="100"
                ClipToBounds="False"
                IsHitTestVisible="False">
            <Border x:Name="SoundDragPreviewOverlay"
                    Background="{DynamicResource AppInputFocusBrush}"
                    BorderBrush="{DynamicResource TargetDropHoverBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="7,6"
                    Opacity="0.95"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Width="24"
                            Height="24"
                            Margin="0,0,8,0"
                            Background="{DynamicResource AppSurfaceRaisedBrush}"
                            BorderBrush="{DynamicResource AppMutedBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <Path Width="9"
                              Height="11"
                              Margin="2,0,0,0"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Data="M0,0 L9,5.5 L0,11 Z"
                              Fill="{DynamicResource TextSecondaryBrush}"
                              Stretch="Uniform" />
                    </Border>
                    <TextBlock x:Name="SoundDragPreviewText"
                               MaxWidth="180"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
        </Canvas>
    </Grid>
</Page>
