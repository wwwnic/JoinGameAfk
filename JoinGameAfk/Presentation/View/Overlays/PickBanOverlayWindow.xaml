<Window x:Class="JoinGameAfk.Presentation.View.Overlays.PickBanOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:JoinGameAfk.Presentation.View.Controls"
        Title="Pick/Ban Overlay"
        Width="360"
        Height="435"
        MinWidth="252"
        MinHeight="132"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowActivated="False"
        ShowInTaskbar="True"
        Topmost="True"
        Closed="Window_Closed">
    <Window.Resources>
        <Style x:Key="OverlayTitleButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource TitleBarButtonStyle}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="5,0,0,0" />
        </Style>

        <Style x:Key="OverlayCloseButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource CloseButtonStyle}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="5,0,0,0" />
        </Style>

        <Style x:Key="OverlaySectionStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppStrongBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="0,10,0,0" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="OverlayPlaceholderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
            <Setter Property="FontStyle" Value="Italic" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="OverlaySettingsButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,6,6" />
        </Style>

        <Style x:Key="OverlaySettingsCheckBoxStyle"
               TargetType="CheckBox"
               BasedOn="{StaticResource AppCheckBoxStyle}">
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="OverlaySettingsLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="Margin" Value="0,10,0,4" />
        </Style>

        <Style x:Key="OverlayPlanHorizontalScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="MinWidth" Value="26" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Grid Height="8"
                              Background="Transparent"
                              SnapsToDevicePixels="True">
                            <Border x:Name="ThumbRail"
                                    Height="4"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource AppStrongBorderBrush}"
                                    CornerRadius="2"
                                    Opacity="0.58" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbRail" Property="Height" Value="6" />
                                <Setter TargetName="ThumbRail" Property="Background" Value="{DynamicResource AccentBlueBrush}" />
                                <Setter TargetName="ThumbRail" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbRail" Property="Height" Value="6" />
                                <Setter TargetName="ThumbRail" Property="Background" Value="{DynamicResource AccentBlueSoftBrush}" />
                                <Setter TargetName="ThumbRail" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ThumbRail" Property="Opacity" Value="0.25" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OverlayPlanHorizontalScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Height" Value="8" />
            <Setter Property="MinHeight" Value="8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Height="8"
                              Background="Transparent"
                              SnapsToDevicePixels="True">
                            <Border x:Name="ScrollRail"
                                    Height="2"
                                    Margin="3,0"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource AppSurfaceInsetBrush}"
                                    CornerRadius="1"
                                    Opacity="0.65" />

                            <Track x:Name="PART_Track"
                                   Margin="3,0"
                                   Minimum="{TemplateBinding Minimum}"
                                   Maximum="{TemplateBinding Maximum}"
                                   Value="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                   ViewportSize="{TemplateBinding ViewportSize}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageLeftCommand"
                                                  CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                                  Style="{StaticResource SlimScrollBarRepeatButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource OverlayPlanHorizontalScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageRightCommand"
                                                  CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                                  Style="{StaticResource SlimScrollBarRepeatButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ScrollRail" Property="Background" Value="{DynamicResource AppMutedBorderBrush}" />
                                <Setter TargetName="ScrollRail" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ScrollRail" Property="Opacity" Value="0.25" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OverlayPlanTileScrollViewerStyle" TargetType="ScrollViewer">
            <Setter Property="MinHeight" Value="72" />
            <Setter Property="MaxHeight" Value="72" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="VerticalScrollBarVisibility" Value="Disabled" />
            <Setter Property="PanningMode" Value="HorizontalOnly" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid Background="{TemplateBinding Background}"
                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="8" />
                            </Grid.RowDefinitions>

                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                    Grid.Row="0"
                                                    CanContentScroll="{TemplateBinding CanContentScroll}"
                                                    CanHorizontallyScroll="False"
                                                    CanVerticallyScroll="False"
                                                    Content="{TemplateBinding Content}"
                                                    ContentStringFormat="{TemplateBinding ContentStringFormat}"
                                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                                    ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                                                    Margin="{TemplateBinding Padding}"
                                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />

                            <ScrollBar x:Name="PART_HorizontalScrollBar"
                                       Grid.Row="1"
                                       AutomationProperties.AutomationId="HorizontalScrollBar"
                                       Maximum="{TemplateBinding ScrollableWidth}"
                                       Orientation="Horizontal"
                                       Style="{StaticResource OverlayPlanHorizontalScrollBarStyle}"
                                       Value="{Binding HorizontalOffset, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}"
                                       ViewportSize="{TemplateBinding ViewportWidth}"
                                       Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OverlayTargetCellStyle" TargetType="Border">
            <Setter Property="Width" Value="74" />
            <Setter Property="MinWidth" Value="74" />
            <Setter Property="Height" Value="74" />
            <Setter Property="Padding" Value="5" />
            <Setter Property="Background" Value="{DynamicResource AppSurfaceInsetBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppStrongBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
        </Style>

        <Style x:Key="OverlayTargetPortraitFrameStyle" TargetType="Border">
            <Setter Property="Width" Value="64" />
            <Setter Property="Height" Value="64" />
            <Setter Property="Background" Value="{DynamicResource AppInputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppStrongBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
        </Style>

        <DataTemplate x:Key="OverlayChampionChipTemplate">
            <Border Style="{StaticResource PlannerPortraitChampionChipStyle}"
                    ToolTip="{Binding ToolTipText}">
                <Grid Width="48"
                      Height="64"
                      ClipToBounds="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="0" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            ClipToBounds="True"
                            Style="{StaticResource PlannerChampionPortraitSlotStyle}">
                        <Grid>
                            <controls:ChampionMysteryGlyph Width="30"
                                                            Height="30"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            Foreground="{DynamicResource TextSubtleBrush}" />
                            <Image Source="{Binding PortraitImageSource}"
                                   Stretch="UniformToFill"
                                   SnapsToDevicePixels="True" />
                        </Grid>
                    </Border>

                    <Viewbox Grid.Row="2"
                             Style="{StaticResource ChampionTileLabelViewboxStyle}">
                        <TextBlock Text="{Binding ChipDisplayText}"
                                   FontSize="{Binding ChipDisplayFontSize}"
                                   Style="{StaticResource PlannerChampionChipTextStyle}" />
                    </Viewbox>

                    <Border Grid.Row="0"
                            Panel.ZIndex="10"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,2,2,0"
                            Style="{StaticResource PlannerUnavailableHelpBadgeStyle}"
                            ToolTip="{Binding StatusText}">
                        <TextBlock Text="?"
                                   Style="{StaticResource PlannerUnavailableHelpTextStyle}" />
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Border x:Name="OverlayPanel"
                Background="{DynamicResource AppSurfaceBrush}"
                BorderBrush="{DynamicResource AccentBlueBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Opacity="0.94"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource AppSurfaceRaisedBrush}"
                        BorderBrush="{DynamicResource AppMutedBorderBrush}"
                        BorderThickness="0,0,0,1"
                        CornerRadius="10,10,0,0"
                        Padding="10,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0"
                              Background="Transparent"
                              MouseLeftButtonDown="DragHandle_MouseLeftButtonDown">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <controls:PhaseStatusIndicator x:Name="OverlayPhaseIndicator"
                                                           Grid.Column="0"
                                                           VerticalAlignment="Center" />

                            <StackPanel Grid.Column="2"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Pick/Ban Overlay"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                <TextBlock x:Name="StatusText"
                                           Text="Stopped"
                                           Margin="0,1,0,0"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal">
                            <Button ToolTip="Open or minimize main app"
                                    AutomationProperties.Name="Open or minimize main app"
                                    Click="OpenMainAppButton_Click"
                                    Style="{StaticResource OverlayTitleButtonStyle}">
                                <Path Data="M4,4 H13 V13 H4 Z M8,8 H17 V17 H8 Z"
                                      Width="14"
                                      Height="14"
                                      Stretch="Uniform"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" />
                            </Button>
                            <Button x:Name="SettingsButton"
                                    ToolTip="Expand overlay options"
                                    AutomationProperties.Name="Expand overlay options"
                                    Click="SettingsButton_Click"
                                    Style="{StaticResource OverlayTitleButtonStyle}">
                                <TextBlock Text="..."
                                           Margin="0,-4,0,0"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Button>
                            <Button ToolTip="Close overlay"
                                    AutomationProperties.Name="Close pick ban overlay"
                                    Click="CloseButton_Click"
                                    Style="{StaticResource OverlayCloseButtonStyle}">
                                <Path Width="12"
                                      Height="12"
                                      Data="M6,6 L18,18 M18,6 L6,18"
                                      Stretch="Uniform"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer x:Name="OverlayScrollViewer"
                              Grid.Row="1"
                              VerticalScrollBarVisibility="Visible"
                              Style="{StaticResource StableVerticalScrollViewerStyle}">
                    <StackPanel x:Name="ContentPanel"
                                Margin="12,12,18,18">
                        <WrapPanel x:Name="PhaseTimerSection"
                                   HorizontalAlignment="Center"
                                   Orientation="Horizontal">
                            <Grid x:Name="TargetSelectionPanel"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border x:Name="OverlayPickTargetChampionCell"
                                        Grid.Column="0"
                                        Style="{StaticResource OverlayTargetCellStyle}">
                                    <Grid Width="64"
                                          Height="64">
                                        <Border Style="{StaticResource OverlayTargetPortraitFrameStyle}">
                                            <Grid>
                                                <controls:ChampionMysteryGlyph Width="34"
                                                                                Height="34"
                                                                                HorizontalAlignment="Center"
                                                                                VerticalAlignment="Center"
                                                                                Foreground="{DynamicResource TextSubtleBrush}" />
                                                <Image x:Name="OverlayPickTargetChampionImage"
                                                       Stretch="UniformToFill"
                                                       SnapsToDevicePixels="True" />
                                            </Grid>
                                        </Border>

                                        <Viewbox IsHitTestVisible="False"
                                                 Stretch="Fill">
                                            <Canvas Width="200"
                                                    Height="200">
                                                <Rectangle Canvas.Left="12"
                                                           Canvas.Top="12"
                                                           Width="176"
                                                           Height="176"
                                                           RadiusX="8"
                                                           RadiusY="8"
                                                           Fill="Transparent"
                                                           Stroke="{DynamicResource AppStrongBorderBrush}"
                                                           StrokeThickness="2" />
                                                <Path Data="M 28 62 L 28 28 L 62 28"
                                                      Stroke="{DynamicResource AccentBlueSoftBrush}"
                                                      StrokeThickness="4"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round" />
                                                <Path Data="M 138 28 L 172 28 L 172 62"
                                                      Stroke="{DynamicResource AccentBlueSoftBrush}"
                                                      StrokeThickness="4"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round" />
                                                <Path Data="M 172 138 L 172 172 L 138 172"
                                                      Stroke="{DynamicResource AccentBlueSoftBrush}"
                                                      StrokeThickness="4"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round" />
                                                <Path Data="M 62 172 L 28 172 L 28 138"
                                                      Stroke="{DynamicResource AccentBlueSoftBrush}"
                                                      StrokeThickness="4"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round" />
                                                <Path Data="M 100 12 L 100 25"
                                                      Stroke="{DynamicResource AppMutedBorderBrush}"
                                                      StrokeThickness="2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round" />
                                                <Path Data="M 100 188 L 100 175"
                                                      Stroke="{DynamicResource AppMutedBorderBrush}"
                                                      StrokeThickness="2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round" />
                                                <Path Data="M 12 100 L 25 100"
                                                      Stroke="{DynamicResource AppMutedBorderBrush}"
                                                      StrokeThickness="2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round" />
                                                <Path Data="M 188 100 L 175 100"
                                                      Stroke="{DynamicResource AppMutedBorderBrush}"
                                                      StrokeThickness="2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round" />
                                            </Canvas>
                                        </Viewbox>
                                    </Grid>
                                </Border>

                                <Border x:Name="OverlayBanTargetChampionCell"
                                        Grid.Column="2"
                                        Style="{StaticResource OverlayTargetCellStyle}">
                                    <Grid Width="64"
                                          Height="64">
                                        <Border Style="{StaticResource OverlayTargetPortraitFrameStyle}">
                                            <Grid>
                                                <controls:ChampionMysteryGlyph Width="34"
                                                                                Height="34"
                                                                                HorizontalAlignment="Center"
                                                                                VerticalAlignment="Center"
                                                                                Foreground="{DynamicResource TextSubtleBrush}" />
                                                <Image x:Name="OverlayBanTargetChampionImage"
                                                       Stretch="UniformToFill"
                                                       SnapsToDevicePixels="True" />
                                            </Grid>
                                        </Border>

                                        <Viewbox IsHitTestVisible="False"
                                                 Stretch="Fill">
                                            <Canvas Width="200"
                                                    Height="200">
                                                <Rectangle Canvas.Left="12"
                                                           Canvas.Top="12"
                                                           Width="176"
                                                           Height="176"
                                                           RadiusX="8"
                                                           RadiusY="8"
                                                           Fill="Transparent"
                                                           Stroke="{DynamicResource AppStrongBorderBrush}"
                                                           StrokeThickness="2" />
                                                <Path Data="M 28 62 L 28 28 L 62 28"
                                                      Stroke="{DynamicResource DangerAccentBrush}"
                                                      StrokeThickness="4"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round" />
                                                <Path Data="M 138 28 L 172 28 L 172 62"
                                                      Stroke="{DynamicResource DangerAccentBrush}"
                                                      StrokeThickness="4"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round" />
                                                <Path Data="M 172 138 L 172 172 L 138 172"
                                                      Stroke="{DynamicResource DangerAccentBrush}"
                                                      StrokeThickness="4"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round" />
                                                <Path Data="M 62 172 L 28 172 L 28 138"
                                                      Stroke="{DynamicResource DangerAccentBrush}"
                                                      StrokeThickness="4"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round" />
                                                <Path Data="M 100 12 L 100 25"
                                                      Stroke="{DynamicResource AppMutedBorderBrush}"
                                                      StrokeThickness="2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round" />
                                                <Path Data="M 100 188 L 100 175"
                                                      Stroke="{DynamicResource AppMutedBorderBrush}"
                                                      StrokeThickness="2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round" />
                                                <Path Data="M 12 100 L 25 100"
                                                      Stroke="{DynamicResource AppMutedBorderBrush}"
                                                      StrokeThickness="2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round" />
                                                <Path Data="M 188 100 L 175 100"
                                                      Stroke="{DynamicResource AppMutedBorderBrush}"
                                                      StrokeThickness="2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round" />
                                            </Canvas>
                                        </Viewbox>
                                    </Grid>
                                </Border>
                            </Grid>

                            <Border x:Name="PhaseTimerCard"
                                    Width="74"
                                    Height="74"
                                    Background="{DynamicResource AppSurfaceInsetBrush}"
                                    BorderBrush="{DynamicResource AppStrongBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="6"
                                    VerticalAlignment="Center"
                                    Margin="0,0,8,8">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <TextBlock x:Name="TimerText"
                                               Text="--"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource AccentBlueSoftBrush}"
                                               HorizontalAlignment="Center"
                                               LineHeight="25"
                                               LineStackingStrategy="BlockLineHeight" />
                                    <TextBlock Text="sec"
                                               Margin="0,2,0,0"
                                               FontSize="9"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <Border x:Name="LockTimerCard"
                                    Width="74"
                                    Height="74"
                                    Background="{DynamicResource AppSurfaceInsetBrush}"
                                    BorderBrush="{DynamicResource AppStrongBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="6"
                                    VerticalAlignment="Center"
                                    Margin="0,0,0,8">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <TextBlock x:Name="LockTimerText"
                                               Text="--"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource DangerTextBrush}"
                                               HorizontalAlignment="Center"
                                               LineHeight="25"
                                               LineStackingStrategy="BlockLineHeight" />
                                    <TextBlock x:Name="LockTimerLabel"
                                               Text="lock"
                                               Margin="0,2,0,0"
                                               FontSize="9"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <Border x:Name="PickPlanSection"
                                Style="{StaticResource OverlaySectionStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Width="4"
                                            Height="24"
                                            Background="{DynamicResource AccentBlueBrush}"
                                            CornerRadius="2" />
                                    <TextBlock Grid.Column="2"
                                               Text="Pick plan"
                                               Style="{StaticResource CardTitleStyle}"
                                               FontSize="14"
                                               VerticalAlignment="Center" />
                                    <TextBlock x:Name="PickLockText"
                                               Grid.Column="3"
                                               Text="Lock timing unavailable."
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextAlignment="Right"
                                               TextWrapping="Wrap"
                                               MaxWidth="116"
                                               VerticalAlignment="Center" />
                                </Grid>

                                <Border Grid.Row="2"
                                        Style="{StaticResource PlannerChampionChipListFrameStyle}"
                                        Margin="0,6,0,6"
                                        Padding="10,0">
                                    <Grid ClipToBounds="True">
                                        <TextBlock x:Name="PickPlaceholderText"
                                                   Text="Waiting for champion select."
                                                   Style="{StaticResource OverlayPlaceholderStyle}" />
                                        <ScrollViewer Style="{StaticResource OverlayPlanTileScrollViewerStyle}">
                                            <ItemsControl x:Name="PickPlanList"
                                                          ItemTemplate="{StaticResource OverlayChampionChipTemplate}"
                                                          HorizontalAlignment="Left"
                                                          VerticalAlignment="Top">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <Border x:Name="BanPlanSection"
                                Style="{StaticResource OverlaySectionStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Width="4"
                                            Height="24"
                                            Background="{DynamicResource DangerAccentBrush}"
                                            CornerRadius="2" />
                                    <TextBlock Grid.Column="2"
                                               Text="Ban plan"
                                               Style="{StaticResource CardTitleStyle}"
                                               FontSize="14"
                                               VerticalAlignment="Center" />
                                    <TextBlock x:Name="BanLockText"
                                               Grid.Column="3"
                                               Text="Lock timing unavailable."
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextAlignment="Right"
                                               TextWrapping="Wrap"
                                               MaxWidth="116"
                                               VerticalAlignment="Center" />
                                </Grid>

                                <Border Grid.Row="2"
                                        Style="{StaticResource PlannerChampionChipListFrameStyle}"
                                        Margin="0,6,0,6"
                                        Padding="10,0">
                                    <Grid ClipToBounds="True">
                                        <TextBlock x:Name="BanPlaceholderText"
                                                   Text="Waiting for champion select."
                                                   Style="{StaticResource OverlayPlaceholderStyle}" />
                                        <ScrollViewer Style="{StaticResource OverlayPlanTileScrollViewerStyle}">
                                            <ItemsControl x:Name="BanPlanList"
                                                          ItemTemplate="{StaticResource OverlayChampionChipTemplate}"
                                                          HorizontalAlignment="Left"
                                                          VerticalAlignment="Top">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <ResizeGrip x:Name="WindowResizeGrip"
                    Width="18"
                    Height="18"
                    Margin="0,0,4,4"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Panel.ZIndex="20"
                    Cursor="SizeNWSE"
                    ToolTip="Drag to resize overlay"
                    MouseLeftButtonDown="ResizeGrip_MouseLeftButtonDown"
                    MouseMove="ResizeGrip_MouseMove"
                    MouseLeftButtonUp="ResizeGrip_MouseLeftButtonUp"
                    LostMouseCapture="ResizeGrip_LostMouseCapture" />

        <Popup x:Name="SettingsPopup"
               PlacementTarget="{Binding ElementName=OverlayPanel}"
               Placement="Right"
               HorizontalOffset="8"
               VerticalOffset="0"
               AllowsTransparency="True"
               StaysOpen="False">
            <Border Width="332"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppStrongBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12"
                    SnapsToDevicePixels="True">
                <ScrollViewer MaxHeight="560"
                              Style="{StaticResource StableVerticalScrollViewerStyle}">
                    <StackPanel>
                        <TextBlock Text="Overlay options"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                        <TextBlock Text="Presets"
                                   Style="{StaticResource OverlaySettingsLabelStyle}" />
                        <UniformGrid Columns="2">
                            <Button Content="Targets + lock"
                                    Click="TargetsLockPresetButton_Click"
                                    ToolTip="Compact default: targets and lock timer."
                                    Style="{StaticResource OverlaySettingsButtonStyle}" />
                            <Button Content="Targets + everything"
                                    Click="TargetsEverythingCompactPresetButton_Click"
                                    ToolTip="Compact width with targets, lock timer, and plans; scroll to see more."
                                    Style="{StaticResource OverlaySettingsButtonStyle}" />
                            <Button Content="Everything"
                                    Click="EverythingPresetButton_Click"
                                    ToolTip="Full width with every section visible."
                                    Style="{StaticResource OverlaySettingsButtonStyle}" />
                            <Button Content="Everything scroll"
                                    Click="EverythingCompactPresetButton_Click"
                                    ToolTip="Full width with every section enabled and a shorter scroll height."
                                    Style="{StaticResource OverlaySettingsButtonStyle}" />
                        </UniformGrid>

                        <TextBlock Text="Show sections"
                                   Style="{StaticResource OverlaySettingsLabelStyle}" />
                        <UniformGrid Columns="2">
                            <CheckBox x:Name="ShowPhaseSummaryCheckBox"
                                      Content="Targets"
                                      Checked="OverlayOptionCheckBox_Changed"
                                      Unchecked="OverlayOptionCheckBox_Changed"
                                      Style="{StaticResource OverlaySettingsCheckBoxStyle}" />
                            <CheckBox x:Name="ShowPhaseTimerCheckBox"
                                      Content="Phase timer"
                                      Checked="OverlayOptionCheckBox_Changed"
                                      Unchecked="OverlayOptionCheckBox_Changed"
                                      Style="{StaticResource OverlaySettingsCheckBoxStyle}" />
                            <CheckBox x:Name="ShowLockTimerCheckBox"
                                      Content="Lock timer"
                                      Checked="OverlayOptionCheckBox_Changed"
                                      Unchecked="OverlayOptionCheckBox_Changed"
                                      Style="{StaticResource OverlaySettingsCheckBoxStyle}" />
                            <CheckBox x:Name="ShowPickPlanCheckBox"
                                      Content="Pick plan"
                                      Checked="OverlayOptionCheckBox_Changed"
                                      Unchecked="OverlayOptionCheckBox_Changed"
                                      Style="{StaticResource OverlaySettingsCheckBoxStyle}" />
                            <CheckBox x:Name="ShowBanPlanCheckBox"
                                      Content="Ban plan"
                                      Checked="OverlayOptionCheckBox_Changed"
                                      Unchecked="OverlayOptionCheckBox_Changed"
                                      Style="{StaticResource OverlaySettingsCheckBoxStyle}" />
                        </UniformGrid>

                        <TextBlock Text="Window"
                                   Style="{StaticResource OverlaySettingsLabelStyle}" />
                        <CheckBox x:Name="TopmostCheckBox"
                                  Content="Stay on top"
                                  Checked="OverlayOptionCheckBox_Changed"
                                  Unchecked="OverlayOptionCheckBox_Changed"
                                  Style="{StaticResource OverlaySettingsCheckBoxStyle}" />

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="68" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="44" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Opacity"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSoftBrush}"
                                       VerticalAlignment="Center" />
                            <Slider x:Name="OpacitySlider"
                                    Grid.Column="1"
                                    Minimum="55"
                                    Maximum="100"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center" />
                            <TextBlock x:Name="OpacityValueText"
                                       Grid.Column="2"
                                       Text="94%"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       TextAlignment="Right"
                                       VerticalAlignment="Center" />
                        </Grid>

                        <Button x:Name="ResetOverlayViewButton"
                                Content="Reset to default preset"
                                Click="ResetOverlayViewButton_Click"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="12,8"
                                Margin="0,14,0,0"
                                HorizontalAlignment="Left"
                                ToolTip="Restore the default targets and lock timer preset." />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Popup>
    </Grid>
</Window>
