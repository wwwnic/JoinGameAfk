<UserControl x:Class="JoinGameAfk.Presentation.View.Controls.PhaseStatusIndicator"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:JoinGameAfk.Presentation.View.Controls"
             Width="32"
             Height="32"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <Border Background="{DynamicResource AppSurfaceInsetBrush}"
            BorderBrush="{DynamicResource AppMutedBorderBrush}"
            BorderThickness="1"
            CornerRadius="9"
            SnapsToDevicePixels="True">
        <Grid x:Name="IndicatorContent"
              Margin="3"
              ClipToBounds="False"
              SnapsToDevicePixels="True">
            <controls:PhaseActivityRing x:Name="ActivityRing"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed"
                                        SnapsToDevicePixels="True" />

            <Ellipse x:Name="PhaseCircle"
                     Width="10"
                     Height="10"
                     Fill="{DynamicResource PhaseDefaultBrush}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     SnapsToDevicePixels="True" />

            <Grid x:Name="ReadyCheckResponseGlyph"
                  Margin="5"
                  Visibility="Collapsed"
                  IsHitTestVisible="False">
                <controls:LogoCheckGlyph x:Name="ReadyCheckAcceptedGlyph"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Stretch"
                                         Visibility="Collapsed"
                                         SnapsToDevicePixels="True" />
                <Viewbox x:Name="ReadyCheckDeclinedGlyph"
                         Stretch="Uniform"
                         Visibility="Collapsed"
                         SnapsToDevicePixels="True">
                    <Canvas Width="20"
                            Height="20">
                        <Path Data="M5,5 L15,15 M15,5 L5,15"
                              Stroke="{DynamicResource AppSurfaceInsetBrush}"
                              StrokeThickness="5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round" />
                        <Path Data="M5,5 L15,15 M15,5 L5,15"
                              Stroke="{DynamicResource PhaseBanBrush}"
                              StrokeThickness="3"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round" />
                    </Canvas>
                </Viewbox>
            </Grid>

            <Grid x:Name="ChampionGlyph"
                  Margin="4"
                  Visibility="Collapsed">
                <controls:PolyhedronGlyph x:Name="ChampionPolyhedron"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch" />
                <controls:LogoCheckGlyph x:Name="CompletionCheck"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Stretch"
                                         Visibility="Collapsed"
                                         SnapsToDevicePixels="True" />
            </Grid>

            <Grid x:Name="UnavailableWarningGlyph"
                  Width="20"
                  Height="20"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Visibility="Collapsed"
                  IsHitTestVisible="False"
                  SnapsToDevicePixels="True">
                <Viewbox Stretch="Uniform"
                         SnapsToDevicePixels="True">
                    <Canvas Width="20"
                            Height="20">
                        <Ellipse Width="16"
                                 Height="16"
                                 Canvas.Left="2"
                                 Canvas.Top="2"
                                 Fill="{DynamicResource PhaseBanBrush}" />
                        <Path Data="M6,10 L14,10"
                              Stroke="{DynamicResource AppSurfaceInsetBrush}"
                              StrokeThickness="3.2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" />
                    </Canvas>
                </Viewbox>
            </Grid>
        </Grid>
    </Border>
</UserControl>
