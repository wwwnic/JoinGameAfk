<UserControl x:Class="JoinGameAfk.Presentation.View.Controls.DropActionGlyph"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:JoinGameAfk.Presentation.View.Controls"
             Foreground="{DynamicResource AccentBlueTextBrush}"
             IsHitTestVisible="False"
             SnapsToDevicePixels="True">

    <!-- Glyph resources -->
    <UserControl.Resources>

        <!-- Viewbox base style -->
        <Style x:Key="GlyphViewboxStyle" TargetType="Viewbox">
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Path stroke style -->
        <Style x:Key="GlyphPathStyle" TargetType="Path">
            <Setter Property="Fill" Value="Transparent" />
            <Setter Property="Stroke" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type local:DropActionGlyph}}}" />
            <Setter Property="StrokeThickness" Value="2" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <!-- Ellipse outline style -->
        <Style x:Key="GlyphEllipseStrokeStyle" TargetType="Ellipse">
            <Setter Property="Fill" Value="Transparent" />
            <Setter Property="Stroke" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type local:DropActionGlyph}}}" />
            <Setter Property="StrokeThickness" Value="2" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <!-- Ellipse fill style -->
        <Style x:Key="GlyphEllipseFillStyle" TargetType="Ellipse">
            <Setter Property="Fill" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type local:DropActionGlyph}}}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>
    </UserControl.Resources>

    <!-- Glyph container -->
    <Grid>

        <!-- Swap -->
        <Viewbox>
            <Viewbox.Style>
                <Style TargetType="Viewbox" BasedOn="{StaticResource GlyphViewboxStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Kind, RelativeSource={RelativeSource AncestorType={x:Type local:DropActionGlyph}}}"
                                     Value="{x:Static local:DropActionKind.Swap}">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Viewbox.Style>

            <Canvas Width="24" Height="24">
                <!-- Top arrow line -->
                <Path Style="{StaticResource GlyphPathStyle}" Data="M4,7 H18" />

                <!-- Top arrow head -->
                <Path Style="{StaticResource GlyphPathStyle}" Data="M15,4 L18,7 L15,10" />

                <!-- Bottom arrow line -->
                <Path Style="{StaticResource GlyphPathStyle}" Data="M20,17 H6" />

                <!-- Bottom arrow head -->
                <Path Style="{StaticResource GlyphPathStyle}" Data="M9,14 L6,17 L9,20" />
            </Canvas>
        </Viewbox>

        <!-- Append -->
        <Viewbox Stretch="Uniform">
            <Viewbox.Style>
                <Style TargetType="Viewbox" BasedOn="{StaticResource GlyphViewboxStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Kind, RelativeSource={RelativeSource AncestorType={x:Type local:DropActionGlyph}}}"
                                     Value="{x:Static local:DropActionKind.Append}">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Viewbox.Style>

            <Canvas Width="24" Height="24">
                <!-- Down arrow line -->
                <Path Style="{StaticResource GlyphPathStyle}" Data="M12,3 V11" />

                <!-- Down arrow head -->
                <Path Style="{StaticResource GlyphPathStyle}" Data="M8.5,7.5 L12,11 L15.5,7.5" />

                <!-- Plus vertical line -->
                <Path Style="{StaticResource GlyphPathStyle}" Data="M12,14 V20" />

                <!-- Plus horizontal line -->
                <Path Style="{StaticResource GlyphPathStyle}" Data="M9,17 H15" />
            </Canvas>
        </Viewbox>

        <!-- Insert -->
        <Viewbox>
            <Viewbox.Style>
                <Style TargetType="Viewbox" BasedOn="{StaticResource GlyphViewboxStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Kind, RelativeSource={RelativeSource AncestorType={x:Type local:DropActionGlyph}}}"
                                     Value="{x:Static local:DropActionKind.Insert}">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Viewbox.Style>

            <Canvas Width="24" Height="24">
                <!-- Insert arrow line -->
                <Path Style="{StaticResource GlyphPathStyle}" Data="M4,8 H17" />

                <!-- Insert arrow head -->
                <Path Style="{StaticResource GlyphPathStyle}" Data="M17,5 L21,8 L17,11" />

                <!-- Plus vertical line -->
                <Path Style="{StaticResource GlyphPathStyle}" Data="M12,14 V20" />

                <!-- Plus horizontal line -->
                <Path Style="{StaticResource GlyphPathStyle}" Data="M9,17 H15" />
            </Canvas>
        </Viewbox>

        <!-- Move to end -->
        <Viewbox>
            <Viewbox.Style>
                <Style TargetType="Viewbox" BasedOn="{StaticResource GlyphViewboxStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Kind, RelativeSource={RelativeSource AncestorType={x:Type local:DropActionGlyph}}}"
                                     Value="{x:Static local:DropActionKind.MoveAppend}">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Viewbox.Style>

            <Canvas Width="24" Height="24">
                <!-- Move arrow line -->
                <Path Style="{StaticResource GlyphPathStyle}" Data="M12,3 V14" />

                <!-- Move arrow head -->
                <Path Style="{StaticResource GlyphPathStyle}" Data="M8.5,10.5 L12,14 L15.5,10.5" />

                <!-- Destination line -->
                <Path Style="{StaticResource GlyphPathStyle}" Data="M6,19 H18" />
            </Canvas>
        </Viewbox>

        <!-- Duplicate removal -->
        <Viewbox>
            <Viewbox.Style>
                <Style TargetType="Viewbox" BasedOn="{StaticResource GlyphViewboxStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Kind, RelativeSource={RelativeSource AncestorType={x:Type local:DropActionGlyph}}}"
                                     Value="{x:Static local:DropActionKind.DuplicateRemoval}">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Viewbox.Style>

            <Canvas Width="24"
                    Height="24"
                    SnapsToDevicePixels="False"
                    UseLayoutRounding="False">

                <!-- Exclamation vertical bar -->
                <Path Style="{StaticResource GlyphPathStyle}"
                      SnapsToDevicePixels="False"
                      Data="M8,3 V8" />

                <!-- Exclamation dot -->
                <Ellipse Style="{StaticResource GlyphEllipseFillStyle}"
                         Canvas.Left="7"
                         Canvas.Top="10"
                         Width="2"
                         Height="2"
                         SnapsToDevicePixels="False" />

                <!-- Removal circle -->
                <Ellipse Style="{StaticResource GlyphEllipseStrokeStyle}"
                         Canvas.Left="11"
                         Canvas.Top="11"
                         Width="10"
                         Height="10"
                         SnapsToDevicePixels="False" />

                <!-- Removal slash -->
                <Path Style="{StaticResource GlyphPathStyle}"
                      SnapsToDevicePixels="False"
                      Data="M12.5,19.5 L19.5,12.5" />
            </Canvas>
        </Viewbox>
    </Grid>
</UserControl>
