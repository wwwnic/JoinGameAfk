<Page x:Class="JoinGameAfk.Presentation.View.Dashboard.PhaseProgressionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:viewControls="clr-namespace:JoinGameAfk.Presentation.View.Controls"
      Background="Transparent"
      SizeChanged="Page_SizeChanged">
    <Page.Resources>
        <SolidColorBrush x:Key="UnavailableNotOwnedSurfaceBrush" Color="#3A2705" />
        <SolidColorBrush x:Key="UnavailableNotOwnedAccentBrush" Color="#F59E0B" />
        <SolidColorBrush x:Key="UnavailableNotOwnedTextBrush" Color="#FFE8A3" />
        <SolidColorBrush x:Key="UnavailableBannedSurfaceBrush" Color="#351015" />
        <SolidColorBrush x:Key="UnavailableBannedAccentBrush" Color="#EF4444" />
        <SolidColorBrush x:Key="UnavailableBannedTextBrush" Color="#FECACA" />
        <SolidColorBrush x:Key="UnavailableSelectedSurfaceBrush" Color="#261346" />
        <SolidColorBrush x:Key="UnavailableSelectedAccentBrush" Color="#A78BFA" />
        <SolidColorBrush x:Key="UnavailableSelectedTextBrush" Color="#DDD6FE" />
        <SolidColorBrush x:Key="UnavailableFailedSurfaceBrush" Color="#1F2937" />
        <SolidColorBrush x:Key="UnavailableFailedAccentBrush" Color="#94A3B8" />
        <SolidColorBrush x:Key="UnavailableFailedTextBrush" Color="#E5E7EB" />
        <SolidColorBrush x:Key="UnavailableBlockedSurfaceBrush" Color="#102A43" />
        <SolidColorBrush x:Key="UnavailableBlockedAccentBrush" Color="#38BDF8" />
        <SolidColorBrush x:Key="UnavailableBlockedTextBrush" Color="#BAE6FD" />

        <Style x:Key="DraftPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="DraftPanelHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="DraftSlotStyle" TargetType="Border">
            <Setter Property="MinHeight" Value="64" />
            <Setter Property="Padding" Value="11,9" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppMutedBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPlanReference}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DangerSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource DangerAccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding PlanReferenceReasonKind}" Value="Selected">
                    <Setter Property="Background" Value="{StaticResource UnavailableSelectedSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource UnavailableSelectedAccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsOwnAction}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBlueInfoBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DraftAvatarStyle" TargetType="Border">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Background" Value="{DynamicResource AppInputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppStrongBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
            <Setter Property="TextElement.Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPlanReference}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DangerSurfaceRaisedBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource DangerAccentBrush}" />
                    <Setter Property="TextElement.Foreground" Value="{DynamicResource DangerTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding PlanReferenceReasonKind}" Value="Selected">
                    <Setter Property="Background" Value="{StaticResource UnavailableSelectedSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource UnavailableSelectedAccentBrush}" />
                    <Setter Property="TextElement.Foreground" Value="{StaticResource UnavailableSelectedTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsOwnAction}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBlueInfoBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}" />
                    <Setter Property="TextElement.Foreground" Value="{DynamicResource AccentBlueTextBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DraftRoleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPlanReference}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource DangerTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding PlanReferenceReasonKind}" Value="Selected">
                    <Setter Property="Foreground" Value="{StaticResource UnavailableSelectedTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsOwnAction}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource AccentBlueTextBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DraftChampionTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPlanReference}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource DangerTextSoftBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding PlanReferenceReasonKind}" Value="Selected">
                    <Setter Property="Foreground" Value="{StaticResource UnavailableSelectedTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsOwnAction}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource AccentBlueTextBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderBanPanelStyle" TargetType="Border">
            <Setter Property="MinHeight" Value="80" />
            <Setter Property="MaxHeight" Value="144" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Background" Value="{DynamicResource AppSurfaceInsetBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppMutedBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
        </Style>

        <Style x:Key="HeaderBanListFrameStyle" TargetType="Border">
            <Setter Property="MinHeight" Value="64" />
            <Setter Property="MaxHeight" Value="64" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
        </Style>

        <Style x:Key="HeaderBanTileScrollViewerStyle"
               TargetType="ScrollViewer"
               BasedOn="{StaticResource StableVerticalScrollViewerStyle}">
            <Setter Property="MaxHeight" Value="64" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <Style x:Key="HeaderBanPortraitChipStyle"
               TargetType="Border"
               BasedOn="{StaticResource PlannerPortraitChampionChipStyle}" />

        <Style x:Key="HeaderBanPortraitSlotStyle"
               TargetType="Border"
               BasedOn="{StaticResource PlannerChampionPortraitSlotStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPlanReference}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DangerSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource DangerAccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding PlanReferenceReasonKind}" Value="Banned">
                    <Setter Property="Background" Value="{StaticResource UnavailableBannedSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource UnavailableBannedAccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsOwnAction}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBlueInfoBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderBanChampionChipTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource PlannerChampionChipTextStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPlanReference}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource DangerTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding PlanReferenceReasonKind}" Value="Banned">
                    <Setter Property="Foreground" Value="{StaticResource UnavailableBannedTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsOwnAction}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource AccentBlueTextBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderBanPlaceholderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
            <Setter Property="FontStyle" Value="Italic" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="ActionPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppStrongBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
        </Style>

        <Style x:Key="PlannerPlanTileScrollViewerStyle"
               TargetType="ScrollViewer"
               BasedOn="{StaticResource StableVerticalScrollViewerStyle}">
            <Setter Property="MaxHeight" Value="128" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <Style x:Key="DashboardViewSwitchButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppMutedBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="Opacity" Value="0.72" />
            <Style.Triggers>
                <Trigger Property="Tag" Value="Active">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="Background" Value="{DynamicResource AccentBlueInfoBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource AccentBlueTextBrush}" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}" />
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="HeaderBanChampionChipTemplate">
            <Border Style="{StaticResource HeaderBanPortraitChipStyle}"
                    ToolTip="{Binding ToolTipText}">
                <Grid Width="48"
                      Height="64"
                      ClipToBounds="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="0" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            ClipToBounds="True"
                            Style="{StaticResource HeaderBanPortraitSlotStyle}">
                        <Grid>
                            <viewControls:ChampionMysteryGlyph Width="30"
                                                               Height="30"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextSubtleBrush}" />
                            <Image Source="{Binding PortraitImageSource}"
                                   Stretch="UniformToFill"
                                   SnapsToDevicePixels="True" />
                        </Grid>
                    </Border>

                    <Viewbox Grid.Row="2"
                             Style="{StaticResource ChampionTileLabelViewboxStyle}">
                        <TextBlock Text="{Binding ChipDisplayText}"
                                   FontSize="{Binding ChipDisplayFontSize}"
                                   Style="{StaticResource HeaderBanChampionChipTextStyle}" />
                    </Viewbox>
                </Grid>
            </Border>
        </DataTemplate>

    </Page.Resources>

    <ScrollViewer Style="{StaticResource StableVerticalScrollViewerStyle}">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition x:Name="LogRow" Height="190" />
            </Grid.RowDefinitions>

            <Grid x:Name="DashboardContentHost"
                  Grid.Row="0">
                <Grid x:Name="ReadyAcceptTabContent">
                    <viewControls:ReadyAcceptDashboardPanel x:Name="ReadyAcceptPanel" />
                </Grid>

                <Grid x:Name="ChampionSelectTabContent">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

            <Border x:Name="HeaderPanel"
                    Grid.Row="0"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16,11">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="132" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource HeaderBanPanelStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Style="{StaticResource HeaderBanListFrameStyle}">
                                <Grid ClipToBounds="True">
                                    <TextBlock x:Name="MyTeamBansPlaceholderText"
                                               Text="Your team bans"
                                               Style="{StaticResource HeaderBanPlaceholderStyle}"
                                               Margin="2,0"
                                               VerticalAlignment="Center" />
                                    <ScrollViewer Style="{StaticResource HeaderBanTileScrollViewerStyle}">
                                        <ItemsControl x:Name="MyTeamBansList"
                                                      ItemTemplate="{StaticResource HeaderBanChampionChipTemplate}"
                                                      VerticalAlignment="Top">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            MinHeight="68"
                            BorderBrush="{DynamicResource AccentBlueBrush}"
                            BorderThickness="1,0"
                            Padding="10,5"
                            VerticalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="ChampSelectTimerText"
                                       Text="--"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBlueSoftBrush}"
                                       HorizontalAlignment="Center"
                                       LineHeight="34"
                                       LineStackingStrategy="BlockLineHeight" />
                            <TextBlock Text="seconds"
                                       Margin="0,4,0,0"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4"
                            Style="{StaticResource HeaderBanPanelStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Style="{StaticResource HeaderBanListFrameStyle}">
                                <Grid ClipToBounds="True">
                                    <TextBlock x:Name="TheirTeamBansPlaceholderText"
                                               Text="Enemy team bans"
                                               Style="{StaticResource HeaderBanPlaceholderStyle}"
                                               Margin="2,0"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center" />
                                    <ScrollViewer Style="{StaticResource HeaderBanTileScrollViewerStyle}">
                                        <ItemsControl x:Name="TheirTeamBansList"
                                                      ItemTemplate="{StaticResource HeaderBanChampionChipTemplate}"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Top">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="4"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Visibility="Collapsed">
                        <TextBlock x:Name="ConnectionText"
                                   Visibility="Collapsed"
                                   Text="Client offline"
                                   Foreground="{DynamicResource PhaseOfflineForegroundBrush}" />
                        <TextBlock x:Name="ChampSelectSubPhaseText"
                                   Visibility="Collapsed"
                                   Text="Idle" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid x:Name="DraftLayoutGrid"
                  Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" MinWidth="170" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="2.2*" MinWidth="280" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="1.05*" MinWidth="170" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource DraftPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Padding="12,10"
                                BorderBrush="{DynamicResource AppMutedBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <StackPanel>
                                <TextBlock Text="YOUR TEAM"
                                           Style="{StaticResource DraftPanelHeaderStyle}" />
                                <TextBlock Text="Current champions"
                                           Margin="0,2,0,0"
                                           Style="{StaticResource MutedTextStyle}" />
                            </StackPanel>
                        </Border>

                        <ItemsControl x:Name="MyTeamSlotList"
                                      Grid.Row="1">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource DraftSlotStyle}"
                                            ToolTip="{Binding PlanReferenceText}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="9" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    Style="{StaticResource DraftAvatarStyle}">
                                                <Grid>
                                                    <viewControls:ChampionMysteryGlyph Width="28"
                                                                                       Height="28"
                                                                                       HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"
                                                                                       Foreground="{DynamicResource TextSubtleBrush}" />
                                                    <Image Source="{Binding PortraitImageSource}"
                                                           Stretch="UniformToFill"
                                                           SnapsToDevicePixels="True" />
                                                </Grid>
                                            </Border>
                                            <StackPanel Grid.Column="2"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ChampionName}"
                                                           Style="{StaticResource DraftRoleTextStyle}" />
                                                <TextBlock Text="{Binding RoleName}"
                                                           MinHeight="17"
                                                           Style="{StaticResource DraftChampionTextStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource DraftPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Padding="12,10"
                                BorderBrush="{DynamicResource AppMutedBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="PLANNER VIEW"
                                               Style="{StaticResource DraftPanelHeaderStyle}" />
                                    <TextBlock Text="Priority lists from your app settings"
                                               Margin="0,2,0,0"
                                               Style="{StaticResource MutedTextStyle}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Style="{StaticResource ActionPanelStyle}"
                                Margin="12,12,12,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Width="4"
                                            Height="28"
                                            Background="{DynamicResource AccentBlueBrush}"
                                            CornerRadius="2" />
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Pick plan"
                                                   Style="{StaticResource CardTitleStyle}"
                                                   FontSize="14" />
                                        <TextBlock Text="Champion priority"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   Margin="0,1,0,0" />
                                    </StackPanel>
                                    <TextBlock x:Name="PickPlanLockText"
                                               Grid.Column="4"
                                               Text="Lock timing unavailable."
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextAlignment="Right"
                                               TextWrapping="Wrap"
                                               MaxWidth="170"
                                               VerticalAlignment="Center" />
                                </Grid>

                                <Border Grid.Row="2"
                                        Style="{StaticResource PlannerChampionChipListFrameStyle}"
                                        Margin="0,5,0,5">
                                    <Grid>
                                        <TextBlock x:Name="PickChampionPlaceholderText"
                                                   Text="Waiting for champion select."
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSubtleBrush}"
                                                   FontStyle="Italic"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"
                                                   Visibility="Visible" />
                                        <ScrollViewer Style="{StaticResource PlannerPlanTileScrollViewerStyle}">
                                            <ItemsControl x:Name="PickChampionPriorityList"
                                                          VerticalAlignment="Top">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Style="{StaticResource PlannerPortraitChampionChipStyle}"
                                                                ToolTip="{Binding ToolTipText}">
                                                            <Grid Width="48"
                                                                  Height="64"
                                                                  ClipToBounds="True">
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="0" />
                                                                    <RowDefinition Height="Auto" />
                                                                </Grid.RowDefinitions>

                                                                <Border Grid.Row="0"
                                                                        ClipToBounds="True"
                                                                        Style="{StaticResource PlannerChampionPortraitSlotStyle}">
                                                                    <Grid>
                                                                        <viewControls:ChampionMysteryGlyph Width="30"
                                                                                                           Height="30"
                                                                                                           HorizontalAlignment="Center"
                                                                                                           VerticalAlignment="Center"
                                                                                                           Foreground="{DynamicResource TextSubtleBrush}" />
                                                                        <Image Source="{Binding PortraitImageSource}"
                                                                               Stretch="UniformToFill"
                                                                               SnapsToDevicePixels="True" />
                                                                    </Grid>
                                                                </Border>

                                                                <Viewbox Grid.Row="2"
                                                                         Style="{StaticResource ChampionTileLabelViewboxStyle}">
                                                                    <TextBlock Text="{Binding ChipDisplayText}"
                                                                               FontSize="{Binding ChipDisplayFontSize}"
                                                                               Style="{StaticResource PlannerChampionChipTextStyle}" />
                                                                </Viewbox>

                                                                <Border Grid.Row="0"
                                                                        Panel.ZIndex="10"
                                                                        HorizontalAlignment="Right"
                                                                        VerticalAlignment="Top"
                                                                        Margin="0,2,2,0"
                                                                        Style="{StaticResource PlannerUnavailableHelpBadgeStyle}"
                                                                        ToolTip="{Binding StatusText}">
                                                                    <TextBlock Text="?"
                                                                               Style="{StaticResource PlannerUnavailableHelpTextStyle}" />
                                                                </Border>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Row="3"
                                Style="{StaticResource ActionPanelStyle}"
                                Margin="12,0,12,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Width="4"
                                            Height="28"
                                            Background="{DynamicResource DangerAccentBrush}"
                                            CornerRadius="2" />
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Ban plan"
                                                   Style="{StaticResource CardTitleStyle}"
                                                   FontSize="14" />
                                        <TextBlock Text="Champion priority"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   Margin="0,1,0,0" />
                                    </StackPanel>
                                    <TextBlock x:Name="BanPlanLockText"
                                               Grid.Column="4"
                                               Text="Lock timing unavailable."
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextAlignment="Right"
                                               TextWrapping="Wrap"
                                               MaxWidth="170"
                                               VerticalAlignment="Center" />
                                </Grid>

                                <Border Grid.Row="2"
                                        Style="{StaticResource PlannerChampionChipListFrameStyle}"
                                        Margin="0,5,0,5">
                                    <Grid>
                                        <TextBlock x:Name="BanChampionPlaceholderText"
                                                   Text="Waiting for champion select."
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSubtleBrush}"
                                                   FontStyle="Italic"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"
                                                   Visibility="Visible" />
                                        <ScrollViewer Style="{StaticResource PlannerPlanTileScrollViewerStyle}">
                                            <ItemsControl x:Name="BanChampionPriorityList"
                                                          VerticalAlignment="Top">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Style="{StaticResource PlannerPortraitChampionChipStyle}"
                                                                ToolTip="{Binding ToolTipText}">
                                                            <Grid Width="48"
                                                                  Height="64"
                                                                  ClipToBounds="True">
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="0" />
                                                                    <RowDefinition Height="Auto" />
                                                                </Grid.RowDefinitions>

                                                                <Border Grid.Row="0"
                                                                        ClipToBounds="True"
                                                                        Style="{StaticResource PlannerChampionPortraitSlotStyle}">
                                                                    <Grid>
                                                                        <viewControls:ChampionMysteryGlyph Width="30"
                                                                                                           Height="30"
                                                                                                           HorizontalAlignment="Center"
                                                                                                           VerticalAlignment="Center"
                                                                                                           Foreground="{DynamicResource TextSubtleBrush}" />
                                                                        <Image Source="{Binding PortraitImageSource}"
                                                                               Stretch="UniformToFill"
                                                                               SnapsToDevicePixels="True" />
                                                                    </Grid>
                                                                </Border>

                                                                <Viewbox Grid.Row="2"
                                                                         Style="{StaticResource ChampionTileLabelViewboxStyle}">
                                                                    <TextBlock Text="{Binding ChipDisplayText}"
                                                                               FontSize="{Binding ChipDisplayFontSize}"
                                                                               Style="{StaticResource PlannerChampionChipTextStyle}" />
                                                                </Viewbox>

                                                                <Border Grid.Row="0"
                                                                        Panel.ZIndex="10"
                                                                        HorizontalAlignment="Right"
                                                                        VerticalAlignment="Top"
                                                                        Margin="0,2,2,0"
                                                                        Style="{StaticResource PlannerUnavailableHelpBadgeStyle}"
                                                                        ToolTip="{Binding StatusText}">
                                                                    <TextBlock Text="?"
                                                                               Style="{StaticResource PlannerUnavailableHelpTextStyle}" />
                                                                </Border>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="4"
                        Style="{StaticResource DraftPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Padding="12,10"
                                BorderBrush="{DynamicResource AppMutedBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <StackPanel HorizontalAlignment="Right">
                                <TextBlock Text="ENEMY TEAM"
                                           Style="{StaticResource DraftPanelHeaderStyle}"
                                           HorizontalAlignment="Right" />
                                <TextBlock Text="Current champions"
                                           Margin="0,2,0,0"
                                           Style="{StaticResource MutedTextStyle}"
                                           HorizontalAlignment="Right" />
                            </StackPanel>
                        </Border>

                        <ItemsControl x:Name="TheirTeamSlotList"
                                      Grid.Row="1">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource DraftSlotStyle}"
                                            ToolTip="{Binding PlanReferenceText}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="9" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ChampionName}"
                                                           Style="{StaticResource DraftRoleTextStyle}"
                                                           TextAlignment="Right" />
                                                <TextBlock Text="{Binding RoleName}"
                                                           MinHeight="17"
                                                           Style="{StaticResource DraftChampionTextStyle}"
                                                           TextAlignment="Right" />
                                            </StackPanel>
                                            <Border Grid.Column="2"
                                                    Style="{StaticResource DraftAvatarStyle}">
                                                <Grid>
                                                    <viewControls:ChampionMysteryGlyph Width="28"
                                                                                       Height="28"
                                                                                       HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"
                                                                                       Foreground="{DynamicResource TextSubtleBrush}" />
                                                    <Image Source="{Binding PortraitImageSource}"
                                                           Stretch="UniformToFill"
                                                           SnapsToDevicePixels="True" />
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>
                </Grid>
            </Grid>

            <Border Grid.Row="2"
                    Style="{StaticResource DraftPanelStyle}"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="9" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="8"
                                Height="8"
                                Background="{DynamicResource AccentGreenTextBrush}"
                                CornerRadius="4"
                                VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   Text="Live log"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSoftBrush}" />
                        <StackPanel Grid.Column="3"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button x:Name="ReadyAcceptDashboardViewButton"
                                    Content="Ready Accept"
                                    Click="ReadyAcceptDashboardViewButton_Click"
                                    AutomationProperties.Name="Show ready accept dashboard"
                                    ToolTip="Show ready accept"
                                    Style="{StaticResource DashboardViewSwitchButtonStyle}">
                            </Button>
                            <Button x:Name="ChampionSelectDashboardViewButton"
                                    Content="Champion Select"
                                    Click="ChampionSelectDashboardViewButton_Click"
                                    AutomationProperties.Name="Show champion select dashboard"
                                    ToolTip="Show champion select"
                                    Style="{StaticResource DashboardViewSwitchButtonStyle}" />
                        </StackPanel>
                    </Grid>

                    <Frame x:Name="EmbeddedLogsFrame"
                           Grid.Row="2"
                           NavigationUIVisibility="Hidden"
                           Background="Transparent"
                           BorderThickness="0" />
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
