<Page x:Class="JoinGameAfk.Presentation.View.ChampionPriorities.ChampionPrioritiesPage"
      x:Name="RootPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:JoinGameAfk.Controls"
      xmlns:viewControls="clr-namespace:JoinGameAfk.Presentation.View.Controls"
      Background="Transparent"
      AllowDrop="True"
      Focusable="True"
      PreviewKeyDown="Page_PreviewKeyDown"
      PreviewMouseLeftButtonDown="Page_PreviewMouseLeftButtonDown"
      PreviewMouseMove="Page_PreviewMouseMove"
      PreviewMouseLeftButtonUp="Page_PreviewMouseLeftButtonUp"
      DragOver="Page_DragOver"
      DragLeave="Page_DragLeave">
    <Page.Resources>
        <Style x:Key="SearchDeleteDropCardStyle"
               TargetType="Border"
               BasedOn="{StaticResource SectionCardStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=RootPage, Path=IsSearchDeleteDropHintVisible}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DangerSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource DangerAccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SearchDeleteOverlayStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=RootPage, Path=IsSearchDeleteDropHintVisible}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PriorityBoardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="9" />
        </Style>

        <Style x:Key="PriorityLockBannerStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Background" Value="{DynamicResource AppInputFocusBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueSoftBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=RootPage, Path=IsChampionSelectLockActive}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PriorityRowStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppMutedBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="0,2" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style x:Key="PriorityLaneBorderStyle" TargetType="Border">
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="MinHeight" Value="74" />
        </Style>

        <Style x:Key="PriorityHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="PriorityPositionTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>

        <Style x:Key="PriorityPlaceholderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
            <Setter Property="FontStyle" Value="Italic" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ChampionHelpTooltipTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="ChampionHelpTooltipSectionStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AccentBlueTextBrush}" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,7,0,2" />
        </Style>

        <Style x:Key="ChampionHelpTooltipLineStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="LineHeight" Value="15" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,1,0,0" />
        </Style>

        <Style x:Key="PriorityChampionTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource ChampionChipTextStyle}">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="LineHeight" Value="9.5" />
        </Style>

        <Style x:Key="ReferenceChampionTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource ChampionChipTextStyle}">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="LineHeight" Value="9.5" />
        </Style>

        <Style x:Key="ChampionPicturePickerPreviewNameStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource ReferenceChampionTextStyle}">
            <Setter Property="Foreground" Value="{DynamicResource TextInverseBrush}" />
        </Style>

        <Style x:Key="ChampionPictureEditBadgeStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Margin" Value="0,2,2,0" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Background" Value="{DynamicResource AccentBlueBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBluePaleBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsChampionPictureEditMode, RelativeSource={RelativeSource AncestorType={x:Type Page}}}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ChampionPortraitStateBorderStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="BorderBrush" Value="{DynamicResource DangerAccentBrush}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                    <Setter Property="BorderBrush" Value="{DynamicResource DangerAccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSwapDropTarget}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsDuplicateDropTarget}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                    <Setter Property="BorderBrush" Value="{DynamicResource DangerAccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsMoveOriginDropTarget}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                    <Setter Property="BorderBrush" Value="{DynamicResource DangerAccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DuplicateRemovalOverlayStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Background" Value="{DynamicResource DangerOverlayBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DangerAccentBrush}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDuplicateDropTarget}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsMoveOriginDropTarget}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PriorityEndGhostStyle" TargetType="Border">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="64" />
            <Setter Property="Background" Value="{DynamicResource AppInputFocusBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Opacity" Value="0.78" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
        </Style>

        <Style x:Key="RoleFilterBarStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceInsetBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppMutedBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="5" />
        </Style>

        <Style x:Key="RoleFilterRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{DynamicResource AppInputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppStrongBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="GroupName" Value="ChampionRoleFilter" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="OptionBorder"
                                    Background="{Binding Background, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=Transparent}"
                                    BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=Transparent}"
                                    BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=1}"
                                    CornerRadius="8"
                                    Padding="{Binding Padding, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=0}"
                                    TextElement.Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=#E2E8F0}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </Border>
                            <Border x:Name="SelectedRail"
                                    Width="12"
                                    Height="2"
                                    Margin="0,0,0,3"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Bottom"
                                    Background="{DynamicResource AccentBlueBrush}"
                                    CornerRadius="1"
                                    IsHitTestVisible="False"
                                    Opacity="0" />
                            <Border x:Name="KeyboardFocusRing"
                                    BorderBrush="{DynamicResource AccentBluePaleBrush}"
                                    BorderThickness="2"
                                    CornerRadius="8"
                                    IsHitTestVisible="False"
                                    Opacity="0" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OptionBorder" Property="Background" Value="{DynamicResource AppInputHoverBrush}" />
                                <Setter TargetName="OptionBorder" Property="BorderBrush" Value="{DynamicResource AccentBlueSoftBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="KeyboardFocusRing" Property="Opacity" Value="1" />
                                <Setter TargetName="OptionBorder" Property="Background" Value="{DynamicResource AppInputFocusBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="OptionBorder" Property="Background" Value="{DynamicResource AppInputFocusBrush}" />
                                <Setter TargetName="OptionBorder" Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}" />
                                <Setter TargetName="SelectedRail" Property="Opacity" Value="1" />
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="OptionBorder" Property="Opacity" Value="0.76" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="OptionBorder" Property="Opacity" Value="0.55" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchClearButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,5,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
            <Setter Property="ToolTip" Value="Clear search" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{Binding Background, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=Transparent}"
                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=Transparent}"
                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=0}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppInputHoverBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppInputPressedBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PaneGridSplitterStyle" TargetType="{x:Type GridSplitter}">
            <Setter Property="Width" Value="8" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="ResizeBehavior" Value="PreviousAndNext" />
            <Setter Property="ResizeDirection" Value="Columns" />
            <Setter Property="ShowsPreview" Value="False" />
            <Setter Property="Cursor" Value="SizeWE" />
            <Setter Property="ToolTip" Value="Drag to resize priority and champion panels" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type GridSplitter}">
                        <Grid Background="{TemplateBinding Background}"
                              SnapsToDevicePixels="True">
                            <Border x:Name="SplitterRail"
                                    Width="2"
                                    HorizontalAlignment="Center"
                                    Background="{DynamicResource AppStrongBorderBrush}"
                                    CornerRadius="1"
                                    Opacity="0.65" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SplitterRail" Property="Width" Value="4" />
                                <Setter TargetName="SplitterRail" Property="Background" Value="{DynamicResource AccentBlueBrush}" />
                                <Setter TargetName="SplitterRail" Property="Opacity" Value="0.95" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="SplitterRail" Property="Width" Value="4" />
                                <Setter TargetName="SplitterRail" Property="Background" Value="{DynamicResource AccentBlueSoftBrush}" />
                                <Setter TargetName="SplitterRail" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid x:Name="ContentGrid"
          Margin="0"
          ClipToBounds="True">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="28*" MinWidth="370" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="15*" MinWidth="210" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Style="{StaticResource PriorityBoardStyle}">
            <Grid ClipToBounds="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Style="{StaticResource PriorityLockBannerStyle}">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Path Width="14"
                                  Height="14"
                                  Margin="0,0,8,0"
                                  VerticalAlignment="Center"
                                  Stretch="Uniform"
                                  Fill="{DynamicResource TextSecondaryBrush}"
                                  Data="M7,10 V7 A5,5 0 0 1 17,7 V10 H18 A2,2 0 0 1 20,12 V20 A2,2 0 0 1 18,22 H6 A2,2 0 0 1 4,20 V12 A2,2 0 0 1 6,10 H7 M9,10 H15 V7 A3,3 0 0 0 9,7 V10 Z" />
                            <TextBlock Text="Role plans are locked during champion select."
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1"
                          Margin="4,0,4,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Pick"
                                   Style="{StaticResource PriorityHeaderTextStyle}" />
                        <TextBlock Grid.Column="2"
                                   Text="Ban"
                                   Style="{StaticResource PriorityHeaderTextStyle}" />
                    </Grid>

                    <ScrollViewer x:Name="PriorityListScrollViewer"
                                  Grid.Row="3"
                                  Style="{StaticResource StableVerticalScrollViewerStyle}">
                        <ItemsControl x:Name="PositionList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource PriorityRowStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0"
                                                       Text="{Binding PositionName}"
                                                       Style="{StaticResource PriorityPositionTextStyle}" />

                                            <Grid Grid.Row="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="4" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Tag="Pick"
                                                Background="{Binding PickBackgroundBrush, FallbackValue=Transparent}"
                                                BorderBrush="{Binding PickBorderBrush, FallbackValue=Transparent}"
                                                AllowDrop="{Binding IsPriorityEditingEnabled, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                                IsEnabled="{Binding IsPriorityEditingEnabled, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                                Focusable="True"
                                                GotKeyboardFocus="ChampionTarget_GotKeyboardFocus"
                                                KeyDown="ChampionTarget_KeyDown"
                                                ToolTip="Focus this list, then type a champion name and press Enter to add it here."
                                                AutomationProperties.Name="{Binding PositionName, StringFormat={}{0} pick champions}"
                                                MouseLeftButtonDown="ChampionTarget_MouseLeftButtonDown"
                                                DragOver="ChampionList_DragOver"
                                                Drop="ChampionList_Drop"
                                                Style="{StaticResource PriorityLaneBorderStyle}">
                                            <StackPanel VerticalAlignment="Top">
                                                <Grid MinHeight="{Binding PickEndGhostMinHeight}">
                                                    <TextBlock Text="Empty"
                                                               Style="{StaticResource PriorityPlaceholderStyle}"
                                                               Visibility="{Binding PickPlaceholderVisibility}" />
                                                    <ItemsControl ItemsSource="{Binding PickChampions}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Width="48"
                                                                      Height="64"
                                                                      Margin="0"
                                                                      VerticalAlignment="Center"
                                                                      Background="Transparent"
                                                                      AllowDrop="{Binding IsPriorityEditingEnabled, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                                                      DragOver="ChampionItem_DragOver"
                                                                      Drop="ChampionItem_Drop">
                                                                    <Border Tag="ChampionPill"
                                                                            Style="{StaticResource ChampionPillBorderStyle}"
                                                                            AutomationProperties.Name="{Binding DisplayText}"
                                                                            ToolTip="{Binding ToolTipText}"
                                                                            GotKeyboardFocus="ChampionItem_GotKeyboardFocus"
                                                                            KeyDown="ChampionItem_KeyDown"
                                                                            PreviewMouseLeftButtonDown="ChampionItem_PreviewMouseLeftButtonDown"
                                                                            MouseMove="ChampionItem_MouseMove">
                                                                        <Grid Width="48"
                                                                              Height="64"
                                                                              ClipToBounds="True">
                                                                            <Grid.RowDefinitions>
                                                                                <RowDefinition Height="Auto" />
                                                                                <RowDefinition Height="0" />
                                                                                <RowDefinition Height="Auto" />
                                                                            </Grid.RowDefinitions>

                                                                            <Border Grid.Row="0"
                                                                                    ClipToBounds="True"
                                                                                    Style="{StaticResource ChampionPortraitSlotStyle}">
                                                                                <Grid>
                                                                                    <viewControls:ChampionMysteryGlyph Width="30"
                                                                                                                       Height="30"
                                                                                                                       HorizontalAlignment="Center"
                                                                                                                       VerticalAlignment="Center"
                                                                                                                       Foreground="{DynamicResource TextSubtleBrush}" />
                                                                                    <Image Source="{Binding PortraitImageSource}"
                                                                                           Stretch="UniformToFill"
                                                                                           SnapsToDevicePixels="True" />
                                                                                    <Border Style="{StaticResource ChampionPictureEditBadgeStyle}">
                                                                                        <Path Width="9"
                                                                                              Height="9"
                                                                                              HorizontalAlignment="Center"
                                                                                              VerticalAlignment="Center"
                                                                                              Stretch="Uniform"
                                                                                              Stroke="{DynamicResource TextInverseBrush}"
                                                                                              StrokeThickness="2"
                                                                                              StrokeStartLineCap="Round"
                                                                                              StrokeEndLineCap="Round"
                                                                                              StrokeLineJoin="Round"
                                                                                              Data="M4,16 L4,20 L8,20 L18.5,9.5 L14.5,5.5 L4,16 M13.5,6.5 L17.5,10.5" />
                                                                                    </Border>
                                                                                </Grid>
                                                                            </Border>

                                                                            <Viewbox Grid.Row="2"
                                                                                     Style="{StaticResource ChampionTileLabelViewboxStyle}">
                                                                                <TextBlock Text="{Binding ChipDisplayText}"
                                                                                           FontSize="{Binding ChipDisplayFontSize}"
                                                                                           Style="{StaticResource PriorityChampionTextStyle}" />
                                                                            </Viewbox>

                                                                            <Border Grid.Row="0"
                                                                                    Panel.ZIndex="10"
                                                                                    Style="{StaticResource ChampionPortraitStateBorderStyle}" />
                                                                             <Border Grid.Row="0"
                                                                                     Grid.RowSpan="3"
                                                                                     Panel.ZIndex="11"
                                                                                     Style="{StaticResource DuplicateRemovalOverlayStyle}">
                                                                                 <viewControls:DropActionGlyph Width="36"
                                                                                                               Height="36"
                                                                                                               HorizontalAlignment="Center"
                                                                                                               VerticalAlignment="Center"
                                                                                                                Foreground="{DynamicResource DangerTextPaleBrush}"
                                                                                                                Kind="{x:Static viewControls:DropActionKind.DuplicateRemoval}" />
                                                                             </Border>
                                                                          </Grid>
                                                                      </Border>

                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <Canvas Panel.ZIndex="20"
                                                            IsHitTestVisible="False">
                                                        <Border Canvas.Left="{Binding PickEndGhostLeft}"
                                                                Canvas.Top="{Binding PickEndGhostTop}"
                                                                Visibility="{Binding PickEndGhostVisibility}"
                                                                Style="{StaticResource PriorityEndGhostStyle}">
                                                            <viewControls:DropActionGlyph Width="28"
                                                                                           Height="28"
                                                                                           HorizontalAlignment="Center"
                                                                                           VerticalAlignment="Center"
                                                                                           Foreground="{DynamicResource AccentBlueTextBrush}"
                                                                                           Kind="{Binding PickEndGhostEffect}" />
                                                        </Border>
                                                    </Canvas>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="1"
                                                Width="1"
                                                Margin="0,5"
                                                HorizontalAlignment="Center"
                                                Background="{DynamicResource AppMutedBorderBrush}" />

                                        <Border Grid.Column="2"
                                                Tag="Ban"
                                                Background="{Binding BanBackgroundBrush, FallbackValue=Transparent}"
                                                BorderBrush="{Binding BanBorderBrush, FallbackValue=Transparent}"
                                                AllowDrop="{Binding IsPriorityEditingEnabled, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                                IsEnabled="{Binding IsPriorityEditingEnabled, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                                Focusable="True"
                                                GotKeyboardFocus="ChampionTarget_GotKeyboardFocus"
                                                KeyDown="ChampionTarget_KeyDown"
                                                ToolTip="Focus this list, then type a champion name and press Enter to add it here."
                                                AutomationProperties.Name="{Binding PositionName, StringFormat={}{0} ban champions}"
                                                MouseLeftButtonDown="ChampionTarget_MouseLeftButtonDown"
                                                DragOver="ChampionList_DragOver"
                                                Drop="ChampionList_Drop"
                                                Style="{StaticResource PriorityLaneBorderStyle}">
                                            <StackPanel VerticalAlignment="Top">
                                                <Grid MinHeight="{Binding BanEndGhostMinHeight}">
                                                    <TextBlock Text="Empty"
                                                               Style="{StaticResource PriorityPlaceholderStyle}"
                                                               Visibility="{Binding BanPlaceholderVisibility}" />
                                                    <ItemsControl ItemsSource="{Binding BanChampions}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Width="48"
                                                                      Height="64"
                                                                      Margin="0"
                                                                      VerticalAlignment="Center"
                                                                      Background="Transparent"
                                                                      AllowDrop="{Binding IsPriorityEditingEnabled, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                                                      DragOver="ChampionItem_DragOver"
                                                                      Drop="ChampionItem_Drop">
                                                                    <Border Tag="ChampionPill"
                                                                            Style="{StaticResource ChampionPillBorderStyle}"
                                                                            AutomationProperties.Name="{Binding DisplayText}"
                                                                            ToolTip="{Binding ToolTipText}"
                                                                            GotKeyboardFocus="ChampionItem_GotKeyboardFocus"
                                                                            KeyDown="ChampionItem_KeyDown"
                                                                            PreviewMouseLeftButtonDown="ChampionItem_PreviewMouseLeftButtonDown"
                                                                            MouseMove="ChampionItem_MouseMove">
                                                                        <Grid Width="48"
                                                                              Height="64"
                                                                              ClipToBounds="True">
                                                                            <Grid.RowDefinitions>
                                                                                <RowDefinition Height="Auto" />
                                                                                <RowDefinition Height="0" />
                                                                                <RowDefinition Height="Auto" />
                                                                            </Grid.RowDefinitions>

                                                                            <Border Grid.Row="0"
                                                                                    ClipToBounds="True"
                                                                                    Style="{StaticResource ChampionPortraitSlotStyle}">
                                                                                <Grid>
                                                                                    <viewControls:ChampionMysteryGlyph Width="30"
                                                                                                                       Height="30"
                                                                                                                       HorizontalAlignment="Center"
                                                                                                                       VerticalAlignment="Center"
                                                                                                                       Foreground="{DynamicResource TextSubtleBrush}" />
                                                                                    <Image Source="{Binding PortraitImageSource}"
                                                                                           Stretch="UniformToFill"
                                                                                           SnapsToDevicePixels="True" />
                                                                                    <Border Style="{StaticResource ChampionPictureEditBadgeStyle}">
                                                                                        <Path Width="9"
                                                                                              Height="9"
                                                                                              HorizontalAlignment="Center"
                                                                                              VerticalAlignment="Center"
                                                                                              Stretch="Uniform"
                                                                                              Stroke="{DynamicResource TextInverseBrush}"
                                                                                              StrokeThickness="2"
                                                                                              StrokeStartLineCap="Round"
                                                                                              StrokeEndLineCap="Round"
                                                                                              StrokeLineJoin="Round"
                                                                                              Data="M4,16 L4,20 L8,20 L18.5,9.5 L14.5,5.5 L4,16 M13.5,6.5 L17.5,10.5" />
                                                                                    </Border>
                                                                                </Grid>
                                                                            </Border>

                                                                            <Viewbox Grid.Row="2"
                                                                                     Style="{StaticResource ChampionTileLabelViewboxStyle}">
                                                                                <TextBlock Text="{Binding ChipDisplayText}"
                                                                                           FontSize="{Binding ChipDisplayFontSize}"
                                                                                           Style="{StaticResource PriorityChampionTextStyle}" />
                                                                            </Viewbox>

                                                                            <Border Grid.Row="0"
                                                                                    Panel.ZIndex="10"
                                                                                    Style="{StaticResource ChampionPortraitStateBorderStyle}" />
                                                                             <Border Grid.Row="0"
                                                                                     Grid.RowSpan="3"
                                                                                     Panel.ZIndex="11"
                                                                                     Style="{StaticResource DuplicateRemovalOverlayStyle}">
                                                                                 <viewControls:DropActionGlyph Width="36"
                                                                                                               Height="36"
                                                                                                               HorizontalAlignment="Center"
                                                                                                               VerticalAlignment="Center"
                                                                                                                Foreground="{DynamicResource DangerTextPaleBrush}"
                                                                                                                Kind="{x:Static viewControls:DropActionKind.DuplicateRemoval}" />
                                                                             </Border>
                                                                          </Grid>
                                                                      </Border>

                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <Canvas Panel.ZIndex="20"
                                                            IsHitTestVisible="False">
                                                        <Border Canvas.Left="{Binding BanEndGhostLeft}"
                                                                Canvas.Top="{Binding BanEndGhostTop}"
                                                                Visibility="{Binding BanEndGhostVisibility}"
                                                                Style="{StaticResource PriorityEndGhostStyle}">
                                                            <viewControls:DropActionGlyph Width="28"
                                                                                           Height="28"
                                                                                           HorizontalAlignment="Center"
                                                                                           VerticalAlignment="Center"
                                                                                           Foreground="{DynamicResource AccentBlueTextBrush}"
                                                                                           Kind="{Binding BanEndGhostEffect}" />
                                                        </Border>
                                                    </Canvas>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                            </Grid>
                                        </Grid>
                                    </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1"
                      Style="{StaticResource PaneGridSplitterStyle}" />

            <Border x:Name="ChampionSearchCard"
                    Grid.Column="2"
                    AllowDrop="True"
                    ClipToBounds="True"
                    Padding="16"
                    PreviewDragOver="SearchArea_PreviewDragOver"
                    PreviewDrop="SearchArea_PreviewDrop"
                    Style="{StaticResource SearchDeleteDropCardStyle}">
                <Grid ClipToBounds="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            MinHeight="42"
                            Style="{StaticResource RoleFilterBarStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="0" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Text="Drag champions"
                                       TextTrimming="CharacterEllipsis" />

                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right">
                                <Button x:Name="ToggleChampionPictureEditModeButton"
                                        Width="34"
                                        Height="32"
                                        MinHeight="32"
                                        Margin="0,0,6,0"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        AutomationProperties.Name="Edit or download champion images"
                                        Click="ToggleChampionPictureEditModeButton_Click"
                                        IsEnabled="{Binding ElementName=RootPage, Path=IsPriorityEditingEnabled}"
                                        ToolTip="Edit or download champion images">
                                    <Button.Style>
                                        <Style TargetType="Button"
                                               BasedOn="{StaticResource SecondaryButtonStyle}">
                                            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource AppStrongBorderBrush}" />
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=RootPage, Path=IsChampionPictureEditMode}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBlueBrush}" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}" />
                                                    <Setter Property="Foreground" Value="{DynamicResource TextInverseBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Path Width="14"
                                          Height="14"
                                          Stretch="Uniform"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Data="M4,16 L4,20 L8,20 L18.5,9.5 L14.5,5.5 L4,16 M13.5,6.5 L17.5,10.5" />
                                </Button>

                                <Button x:Name="DeleteSelectedButton"
                                        Width="72"
                                        Height="32"
                                        Margin="0,0,6,0"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        AutomationProperties.Name="Delete selected champions"
                                        Click="DeleteSelectedButton_Click"
                                        IsEnabled="{Binding ElementName=RootPage, Path=HasSelectedChampions}"
                                        Style="{StaticResource DeleteSelectedButtonStyle}">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <Path Width="14"
                                              Height="14"
                                              Stretch="Uniform"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Data="M3,6 L21,6 M8,6 L8,4 L16,4 L16,6 M6,6 L7,21 L17,21 L18,6 M10,11 L10,17 M14,11 L14,17" />
                                        <TextBlock Margin="4,0,0,0"
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                   Text="{Binding ElementName=RootPage, Path=SelectedChampionCountText}" />
                                    </StackPanel>
                                </Button>

                                <Button Width="26"
                                        Height="26"
                                        Content="?"
                                        Style="{StaticResource InfoIndicatorStyle}">
                                    <Button.ToolTip>
                                        <StackPanel Width="320">
                                            <TextBlock Text="Role plan controls"
                                                       Style="{StaticResource ChampionHelpTooltipTitleStyle}" />
                                            <TextBlock Text="- Use the pencil on this page to download any missing champion images."
                                                       Style="{StaticResource ChampionHelpTooltipLineStyle}" />

                                            <TextBlock Text="Add champions"
                                                       Style="{StaticResource ChampionHelpTooltipSectionStyle}" />
                                            <TextBlock Text="- Click a pick or ban lane to choose where new champions go."
                                                       Style="{StaticResource ChampionHelpTooltipLineStyle}" />
                                            <TextBlock Text="- Type a champion name or ID, then press Enter to add the first result."
                                                       Style="{StaticResource ChampionHelpTooltipLineStyle}" />
                                            <TextBlock Text="- Click a champion tile to add it to the active lane, or drag it into any lane."
                                                       Style="{StaticResource ChampionHelpTooltipLineStyle}" />

                                            <TextBlock Text="Select and delete"
                                                       Style="{StaticResource ChampionHelpTooltipSectionStyle}" />
                                            <TextBlock Text="- Click a chip to select or unselect it. Shift-click selects a range in the same lane."
                                                       Style="{StaticResource ChampionHelpTooltipLineStyle}" />
                                            <TextBlock Text="- Ctrl+A selects the active lane, or the whole page when no lane is active."
                                                       Style="{StaticResource ChampionHelpTooltipLineStyle}" />
                                            <TextBlock Text="- Press Backspace/Delete, use the trash button, or drag selected chips to this panel."
                                                       Style="{StaticResource ChampionHelpTooltipLineStyle}" />

                                            <TextBlock Text="Drag and reorder"
                                                       Style="{StaticResource ChampionHelpTooltipSectionStyle}" />
                                            <TextBlock Text="- Drag one chip to move it between pick/ban lanes or between roles."
                                                       Style="{StaticResource ChampionHelpTooltipLineStyle}" />
                                            <TextBlock Text="- Drop between chips or at the end to insert. Drop on another chip in the same lane to swap."
                                                       Style="{StaticResource ChampionHelpTooltipLineStyle}" />
                                            <TextBlock Text="- Dragging multiple selected chips is delete-only, so drop them on this panel."
                                                       Style="{StaticResource ChampionHelpTooltipLineStyle}" />

                                            <TextBlock Text="Champion pictures"
                                                       Style="{StaticResource ChampionHelpTooltipSectionStyle}" />
                                            <TextBlock Text="- Use the pencil to edit champion picture choices, then click a champion tile in either panel."
                                                       Style="{StaticResource ChampionHelpTooltipLineStyle}" />
                                        </StackPanel>
                                    </Button.ToolTip>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2">
                        <TextBox x:Name="ChampionSearchBox"
                                 TextChanged="ChampionSearchBox_TextChanged"
                                 PreviewKeyDown="ChampionSearchBox_PreviewKeyDown"
                                 Padding="10,6,34,6"
                                 ToolTip="Type a champion name or ID. Press Enter to add the first result."
                                 Style="{StaticResource SearchTextBoxStyle}" />
                        <Path Width="14"
                              Height="14"
                              Margin="0,0,10,0"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              IsHitTestVisible="False"
                              Stretch="Uniform"
                              Stroke="{DynamicResource TextSubtleBrush}"
                              StrokeThickness="2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Data="M10.5,18 A7.5,7.5 0 1 1 10.5,3 A7.5,7.5 0 0 1 10.5,18 M16,16 L21,21">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=ChampionSearchBox, Path=Text}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                        <Button x:Name="ChampionSearchClearButton"
                                AutomationProperties.Name="Clear champion search"
                                Click="ChampionSearchClearButton_Click">
                            <Button.Style>
                                <Style TargetType="Button"
                                       BasedOn="{StaticResource SearchClearButtonStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=ChampionSearchBox, Path=Text}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Path Width="10"
                                  Height="10"
                                  Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="M6,6 L18,18 M18,6 L6,18" />
                        </Button>
                    </Grid>

                    <Border Grid.Row="4"
                            Style="{StaticResource RoleFilterBarStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="7" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="20"
                                    Height="28"
                                    ToolTip="Role filters">
                                <Path Width="14"
                                      Height="14"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Stretch="Uniform"
                                      Fill="{DynamicResource TextMutedBrush}"
                                      Data="M3,4 H21 L14,12 V20 L10,22 V12 Z" />
                            </Border>

                            <ItemsControl x:Name="RoleFilterList"
                                          Grid.Column="2"
                                          VerticalAlignment="Center">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <RadioButton AutomationProperties.Name="{Binding AutomationName}"
                                                     ToolTip="{Binding ToolTipText}"
                                                     IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                     Click="RoleFilterButton_Click"
                                                     Style="{StaticResource RoleFilterRadioButtonStyle}">
                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="10"
                                                       FontWeight="Bold"
                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                                       Text="{Binding IconText}" />
                                        </RadioButton>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <Border x:Name="ChampionReferenceBorder"
                            Grid.Row="6"
                            Background="{DynamicResource AppSurfaceInsetBrush}"
                            BorderBrush="{DynamicResource AppStrongBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="8">
                        <ScrollViewer x:Name="ChampionReferenceScrollViewer"
                                      Style="{StaticResource StableVerticalScrollViewerStyle}">
                            <ItemsControl x:Name="ChampionReferenceList">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <controls:JustifiedWrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Click="ChampionReferenceButton_Click"
                                                AutomationProperties.Name="{Binding Name}"
                                                ToolTip="{Binding ToolTipText}"
                                                IsEnabled="{Binding IsPriorityEditingEnabled, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                                PreviewMouseLeftButtonDown="ChampionReferenceButton_PreviewMouseLeftButtonDown"
                                                PreviewMouseMove="ChampionReferenceButton_PreviewMouseMove">
                                            <Button.Style>
                                                <Style TargetType="Button"
                                                       BasedOn="{StaticResource ChampionReferenceButtonStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsChampionPictureEditMode, RelativeSource={RelativeSource AncestorType={x:Type Page}}}" Value="True">
                                                            <Setter Property="Cursor" Value="Hand" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <Grid Width="48">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="0" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <Border Grid.Row="0"
                                                        ClipToBounds="True"
                                                        Style="{StaticResource ChampionPortraitSlotStyle}">
                                                    <Grid>
                                                        <viewControls:ChampionMysteryGlyph Width="30"
                                                                                           Height="30"
                                                                                           HorizontalAlignment="Center"
                                                                                           VerticalAlignment="Center"
                                                                                           Foreground="{DynamicResource TextSubtleBrush}" />
                                                        <Image Source="{Binding PortraitImageSource}"
                                                               Stretch="UniformToFill"
                                                               SnapsToDevicePixels="True" />
                                                        <Border Width="18"
                                                                Height="18"
                                                                Margin="0,2,2,0"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Top"
                                                                Background="{DynamicResource AccentBlueBrush}"
                                                                BorderBrush="{DynamicResource AccentBluePaleBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="9">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsChampionPictureEditMode, RelativeSource={RelativeSource AncestorType={x:Type Page}}}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <Path Width="9"
                                                                  Height="9"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"
                                                                  Stretch="Uniform"
                                                                  Stroke="{DynamicResource TextInverseBrush}"
                                                                  StrokeThickness="2"
                                                                  StrokeStartLineCap="Round"
                                                                  StrokeEndLineCap="Round"
                                                                  StrokeLineJoin="Round"
                                                                  Data="M4,16 L4,20 L8,20 L18.5,9.5 L14.5,5.5 L4,16 M13.5,6.5 L17.5,10.5" />
                                                        </Border>
                                                    </Grid>
                                                </Border>

                                                <Viewbox Grid.Row="2"
                                                         Style="{StaticResource ChampionTileLabelViewboxStyle}">
                                                    <TextBlock Text="{Binding ChipDisplayText}"
                                                               FontSize="{Binding ChipDisplayFontSize}"
                                                               Style="{StaticResource ReferenceChampionTextStyle}" />
                                                </Viewbox>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.RowSpan="7"
                            Style="{StaticResource SearchDeleteOverlayStyle}"
                            Background="{DynamicResource DangerOverlayBrush}"
                            BorderBrush="{DynamicResource DangerAccentBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            IsHitTestVisible="False">
                        <Viewbox Width="42"
                                 Height="42"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Path Stroke="{DynamicResource DangerTextPaleBrush}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Data="M3,6 L5,6 M5,6 L21,6 M19,6 L21,6 M8,6 L8,4 L16,4 L16,6 M6,6 L7,21 L17,21 L18,6 M10,11 L10,17 M14,11 L14,17" />
                            </Canvas>
                        </Viewbox>
                    </Border>
                </Grid>
            </Border>

            <Border x:Name="ChampionPicturePickerOverlay"
                    Grid.ColumnSpan="3"
                    Panel.ZIndex="30"
                    Background="#80000000"
                    Visibility="Collapsed"
                    MouseDown="ChampionPicturePickerOverlay_MouseDown">
                <Border Width="640"
                        MaxHeight="620"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{DynamicResource AppSurfaceBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Champion picture"
                                           Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock x:Name="ChampionPicturePickerTitleTextBlock"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>

                            <Button Grid.Column="2"
                                    Width="30"
                                    Height="30"
                                    Padding="0"
                                    Click="ChampionPicturePickerCloseButton_Click"
                                    Style="{StaticResource SearchClearButtonStyle}"
                                    ToolTip="Close champion picture picker"
                                    AutomationProperties.Name="Close champion picture picker">
                                <Path Width="11"
                                      Height="11"
                                      Stretch="Uniform"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Data="M6,6 L18,18 M18,6 L6,18" />
                            </Button>
                        </Grid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="64" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0"
                                  Width="48"
                                  Height="64"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="0" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        ClipToBounds="True"
                                        Style="{StaticResource ChampionPortraitSlotStyle}">
                                    <Grid>
                                        <viewControls:ChampionMysteryGlyph Width="30"
                                                                           Height="30"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{DynamicResource TextSubtleBrush}" />
                                        <Image x:Name="ChampionPicturePickerPreviewImage"
                                               Stretch="UniformToFill"
                                               SnapsToDevicePixels="True" />
                                    </Grid>
                                </Border>

                                <Viewbox Grid.Row="2"
                                         Style="{StaticResource ChampionTileLabelViewboxStyle}">
                                    <TextBlock x:Name="ChampionPicturePickerPreviewNameTextBlock"
                                               Style="{StaticResource ChampionPicturePickerPreviewNameStyle}" />
                                </Viewbox>
                            </Grid>

                            <StackPanel Grid.Column="2"
                                        VerticalAlignment="Center">
                                <TextBlock x:Name="ChampionPicturePickerStatusTextBlock"
                                           Foreground="{DynamicResource TextSoftBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="ChampionPicturePickerDownloadStatusTextBlock"
                                           Foreground="{DynamicResource TextSoftBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"
                                           Visibility="Collapsed" />
                            </StackPanel>

                            <StackPanel Grid.Column="4"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Button x:Name="ChampionPicturePickerDownloadAllButton"
                                        Content="Download All Images"
                                        Click="ChampionPicturePickerDownloadAllButton_Click"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Padding="12,8"
                                        MinWidth="146"
                                        ToolTip="Download every available Riot Data Dragon picture for this champion." />
                                <Button x:Name="ChampionPicturePickerUseDefaultButton"
                                        Content="Use Default"
                                        Click="ChampionPicturePickerUseDefaultButton_Click"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="12,8"
                                        Margin="8,0,0,0"
                                        ToolTip="Remove the custom picture selection for this champion." />
                            </StackPanel>
                        </Grid>

                        <ListBox x:Name="ChampionPicturePickerTileListBox"
                                 Grid.Row="4"
                                 MinHeight="170"
                                 MaxHeight="330"
                                 Padding="8"
                                 Background="{DynamicResource AppInputBrush}"
                                 BorderBrush="{DynamicResource AppStrongBorderBrush}"
                                 BorderThickness="1"
                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 SelectionChanged="ChampionPicturePickerTileListBox_SelectionChanged"
                                 SelectionMode="Single"
                                 KeyboardNavigation.DirectionalNavigation="Contained"
                                 ToolTip="Available pictures for the selected champion.">
                            <ListBox.Resources>
                                <Style TargetType="ScrollBar"
                                       BasedOn="{StaticResource SlimVerticalScrollBarStyle}" />
                            </ListBox.Resources>
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Width" Value="86" />
                                    <Setter Property="Height" Value="94" />
                                    <Setter Property="Margin" Value="0,0,8,8" />
                                    <Setter Property="Padding" Value="4" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource AppMutedBorderBrush}" />
                                    <Setter Property="BorderThickness" Value="2" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="TileBorder"
                                                        Background="{Binding Background, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=Transparent}"
                                                        BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=Transparent}"
                                                        BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=1}"
                                                        CornerRadius="6"
                                                        Padding="{Binding Padding, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=0}"
                                                        TextElement.Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=#E2E8F0}">
                                                    <ContentPresenter HorizontalAlignment="{Binding HorizontalContentAlignment, RelativeSource={RelativeSource TemplatedParent}}"
                                                                      VerticalAlignment="{Binding VerticalContentAlignment, RelativeSource={RelativeSource TemplatedParent}}" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="TileBorder" Property="Background" Value="{DynamicResource AppInputHoverBrush}" />
                                                        <Setter TargetName="TileBorder" Property="BorderBrush" Value="{DynamicResource AppHoverBorderBrush}" />
                                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                    </Trigger>
                                                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                        <Setter TargetName="TileBorder" Property="Background" Value="{DynamicResource AppInputFocusBrush}" />
                                                        <Setter TargetName="TileBorder" Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}" />
                                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="TileBorder" Property="Background" Value="{DynamicResource AccentBlueActionBrush}" />
                                                        <Setter TargetName="TileBorder" Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}" />
                                                        <Setter Property="Foreground" Value="{DynamicResource TextInverseBrush}" />
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="TileBorder" Property="Opacity" Value="0.55" />
                                                        <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="76"
                                          ToolTip="{Binding FileName}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="4" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0"
                                                Width="62"
                                                Height="62"
                                                HorizontalAlignment="Center"
                                                Background="{DynamicResource AppSurfaceRaisedBrush}"
                                                BorderBrush="{DynamicResource AppMutedBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                ClipToBounds="True">
                                            <Grid>
                                                <viewControls:ChampionMysteryGlyph Width="44"
                                                                                   Height="44"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center"
                                                                                   Foreground="{DynamicResource TextSubtleBrush}" />
                                                <Image Source="{Binding ImageSource}"
                                                       Stretch="UniformToFill"
                                                       SnapsToDevicePixels="True" />
                                            </Grid>
                                        </Border>

                                        <TextBlock Grid.Row="2"
                                                   Text="{Binding ShortDisplayName}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   TextAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Grid.Row="6"
                                Background="{DynamicResource AppInputBrush}"
                                BorderBrush="{DynamicResource AppMutedBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10,8">
                            <StackPanel>
                                <TextBlock Text="Legal notice"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="JoinGameAfk is a free, non-commercial fan project. Champion pictures are Riot Games-owned assets provided through Riot Data Dragon. Riot Games does not endorse or sponsor this project."
                                           Foreground="{DynamicResource TextSubtleBrush}"
                                           FontSize="10.5"
                                           LineHeight="14"
                                           TextWrapping="Wrap"
                                           Margin="0,3,0,0" />
                            </StackPanel>
                        </Border>

                    </Grid>
                </Border>
            </Border>

            <Canvas Grid.ColumnSpan="3"
                    Panel.ZIndex="100"
                    ClipToBounds="False"
                    IsHitTestVisible="False">
                <Border x:Name="DragPreviewOverlay"
                        Background="{DynamicResource AppInputFocusBrush}"
                        BorderBrush="{DynamicResource AccentBlueBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="5"
                        Opacity="0.95"
                        Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border x:Name="DragPreviewImageFrame"
                                Width="34"
                                Height="34"
                                Margin="0,0,8,0"
                                Background="{DynamicResource AppSurfaceRaisedBrush}"
                                BorderBrush="{DynamicResource AppMutedBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="3"
                                ClipToBounds="True">
                            <Grid>
                                <viewControls:ChampionMysteryGlyph Width="24"
                                                                   Height="24"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource TextSubtleBrush}" />
                                <Image x:Name="DragPreviewImage"
                                       Stretch="UniformToFill"
                                       SnapsToDevicePixels="True" />
                            </Grid>
                        </Border>
                        <TextBlock x:Name="DragPreviewText"
                                   MaxWidth="150"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
            </Canvas>
        </Grid>
</Page>
