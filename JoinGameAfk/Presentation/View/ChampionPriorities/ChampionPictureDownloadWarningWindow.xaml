<Window x:Class="JoinGameAfk.Presentation.View.ChampionPriorities.ChampionPictureDownloadWarningWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Download Champion Pictures"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource AppBackgroundBrush}">
    <Border Width="460"
            Background="{DynamicResource AppSurfaceBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}"
            BorderThickness="1"
            Padding="18">
        <StackPanel>
            <TextBlock Text="Download champion pictures"
                       Style="{StaticResource SectionTitleStyle}" />
            <TextBlock x:Name="MessageTextBlock"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="12.5"
                       LineHeight="17"
                       TextWrapping="Wrap"
                       Margin="0,8,0,0" />
            <TextBlock Text="Existing local pictures for this champion are kept unless Riot Data Dragon has a different file for the same tile."
                       Foreground="{DynamicResource TextSubtleBrush}"
                       FontSize="11.5"
                       LineHeight="16"
                       TextWrapping="Wrap"
                       Margin="0,8,0,0" />

            <CheckBox x:Name="DontShowAgainCheckBox"
                      Content="Don't show this again"
                      Style="{StaticResource AppCheckBoxStyle}"
                      Margin="0,16,0,0" />

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button Content="Cancel"
                        IsCancel="True"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="16,8" />
                <Button Content="Download"
                        IsDefault="True"
                        Click="DownloadButton_Click"
                        Style="{StaticResource AccentButtonStyle}"
                        Padding="18,8"
                        Margin="8,0,0,0" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
