<Window x:Class="JoinGameAfk.View.PhaseProgressionTestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Phase Progression Tester"
        Width="720"
        Height="640"
        MinWidth="640"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}">
    <Window.Resources>
        <Style x:Key="TesterSectionStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="TesterLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="TesterInputStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource BaseTextBoxStyle}">
            <Setter Property="MinWidth" Value="150" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="TesterActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="TesterClearButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Width" Value="28" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
    </Window.Resources>

    <ScrollViewer Style="{StaticResource StableVerticalScrollViewerStyle}">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Margin="0,0,0,12">
                <TextBlock Text="Phase Progression Tester"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock Text="Manual data for the stopped watcher state."
                           Margin="0,3,0,0"
                           Style="{StaticResource MutedTextStyle}" />
            </StackPanel>

            <StackPanel Grid.Row="1">
                <Border Style="{StaticResource TesterSectionStyle}">
                    <StackPanel>
                        <TextBlock Text="Bans"
                                   Style="{StaticResource TesterLabelStyle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="MyBanBox"
                                     Grid.Column="0"
                                     Style="{StaticResource TesterInputStyle}" />
                            <Button Grid.Column="1"
                                    Content="x"
                                    Click="ClearTextBox_Click"
                                    Tag="{Binding ElementName=MyBanBox}"
                                    Style="{StaticResource TesterClearButtonStyle}" />
                            <Button Grid.Column="2"
                                    Content="Add your ban"
                                    Click="AddMyBan_Click"
                                    Style="{StaticResource TesterActionButtonStyle}" />

                            <TextBox x:Name="EnemyBanBox"
                                     Grid.Column="4"
                                     Style="{StaticResource TesterInputStyle}" />
                            <Button Grid.Column="5"
                                    Content="x"
                                    Click="ClearTextBox_Click"
                                    Tag="{Binding ElementName=EnemyBanBox}"
                                    Style="{StaticResource TesterClearButtonStyle}" />
                            <Button Grid.Column="6"
                                    Content="Add enemy ban"
                                    Click="AddEnemyBan_Click"
                                    Style="{StaticResource TesterActionButtonStyle}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource TesterSectionStyle}">
                    <StackPanel>
                        <TextBlock Text="Your team"
                                   Style="{StaticResource TesterLabelStyle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="MyTeamChampionBox"
                                     Grid.Column="0"
                                     Style="{StaticResource TesterInputStyle}" />
                            <Button Grid.Column="1"
                                    Content="x"
                                    Click="ClearTextBox_Click"
                                    Tag="{Binding ElementName=MyTeamChampionBox}"
                                    Style="{StaticResource TesterClearButtonStyle}" />
                            <TextBox x:Name="MyTeamRoleBox"
                                     Grid.Column="2"
                                     Style="{StaticResource TesterInputStyle}" />
                            <Button Grid.Column="3"
                                    Content="x"
                                    Click="ClearTextBox_Click"
                                    Tag="{Binding ElementName=MyTeamRoleBox}"
                                    Style="{StaticResource TesterClearButtonStyle}" />
                            <Button Grid.Column="4"
                                    Content="Add champion"
                                    Click="AddMyTeamChampion_Click"
                                    Style="{StaticResource TesterActionButtonStyle}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource TesterSectionStyle}">
                    <StackPanel>
                        <TextBlock Text="Enemy team"
                                   Style="{StaticResource TesterLabelStyle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="EnemyTeamChampionBox"
                                     Grid.Column="0"
                                     Style="{StaticResource TesterInputStyle}" />
                            <Button Grid.Column="1"
                                    Content="x"
                                    Click="ClearTextBox_Click"
                                    Tag="{Binding ElementName=EnemyTeamChampionBox}"
                                    Style="{StaticResource TesterClearButtonStyle}" />
                            <TextBox x:Name="EnemyTeamRoleBox"
                                     Grid.Column="2"
                                     Style="{StaticResource TesterInputStyle}" />
                            <Button Grid.Column="3"
                                    Content="x"
                                    Click="ClearTextBox_Click"
                                    Tag="{Binding ElementName=EnemyTeamRoleBox}"
                                    Style="{StaticResource TesterClearButtonStyle}" />
                            <Button Grid.Column="4"
                                    Content="Add champion"
                                    Click="AddEnemyTeamChampion_Click"
                                    Style="{StaticResource TesterActionButtonStyle}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource TesterSectionStyle}">
                    <StackPanel>
                        <TextBlock Text="Plans"
                                   Style="{StaticResource TesterLabelStyle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="PickPlanBox"
                                     Grid.Column="0"
                                     Style="{StaticResource TesterInputStyle}" />
                            <Button Grid.Column="1"
                                    Content="x"
                                    Click="ClearTextBox_Click"
                                    Tag="{Binding ElementName=PickPlanBox}"
                                    Style="{StaticResource TesterClearButtonStyle}" />
                            <Button Grid.Column="2"
                                    Content="Add pick"
                                    Click="AddPickPlan_Click"
                                    Style="{StaticResource TesterActionButtonStyle}" />

                            <TextBox x:Name="BanPlanBox"
                                     Grid.Column="4"
                                     Style="{StaticResource TesterInputStyle}" />
                            <Button Grid.Column="5"
                                    Content="x"
                                    Click="ClearTextBox_Click"
                                    Tag="{Binding ElementName=BanPlanBox}"
                                    Style="{StaticResource TesterClearButtonStyle}" />
                            <Button Grid.Column="6"
                                    Content="Add ban plan"
                                    Click="AddBanPlan_Click"
                                    Style="{StaticResource TesterActionButtonStyle}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource TesterSectionStyle}">
                    <StackPanel>
                        <TextBlock Text="Log"
                                   Style="{StaticResource TesterLabelStyle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="LogLineBox"
                                     Grid.Column="0"
                                     Style="{StaticResource TesterInputStyle}" />
                            <Button Grid.Column="1"
                                    Content="x"
                                    Click="ClearTextBox_Click"
                                    Tag="{Binding ElementName=LogLineBox}"
                                    Style="{StaticResource TesterClearButtonStyle}" />
                            <Button Grid.Column="2"
                                    Content="Add log"
                                    Click="AddLog_Click"
                                    Style="{StaticResource TesterActionButtonStyle}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Grid Grid.Row="2"
                  Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Clear test dashboard"
                        Click="ClearDashboard_Click"
                        Style="{StaticResource TesterActionButtonStyle}" />
                <Button Grid.Column="2"
                        Content="Close"
                        Click="Close_Click"
                        Style="{StaticResource TesterActionButtonStyle}" />
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>
