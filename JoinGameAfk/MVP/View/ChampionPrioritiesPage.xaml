<Page x:Class="JoinGameAfk.View.ChampionPrioritiesPage"
      x:Name="RootPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:JoinGameAfk.Controls"
      xmlns:viewControls="clr-namespace:JoinGameAfk.View.Controls"
      Background="Transparent"
      AllowDrop="True"
      PreviewTextInput="Page_PreviewTextInput"
      PreviewKeyDown="Page_PreviewKeyDown"
      PreviewMouseMove="Page_PreviewMouseMove"
      PreviewMouseLeftButtonUp="Page_PreviewMouseLeftButtonUp"
      DragOver="Page_DragOver"
      DragLeave="Page_DragLeave">
    <Page.Resources>
        <Style x:Key="SearchDeleteDropCardStyle"
               TargetType="Border"
               BasedOn="{StaticResource SectionCardStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=RootPage, Path=IsSearchDeleteDropTarget}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DangerSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource DangerAccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SearchDeleteOverlayStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=RootPage, Path=IsSearchDeleteDropTarget}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PriorityBoardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="9" />
        </Style>

        <Style x:Key="PriorityLockBannerStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Background" Value="{DynamicResource AppInputFocusBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueSoftBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=RootPage, Path=IsChampionSelectLockActive}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PriorityRowStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppMutedBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="0,2" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style x:Key="PriorityLaneBorderStyle" TargetType="Border">
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="MinHeight" Value="74" />
        </Style>

        <Style x:Key="PriorityHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="PriorityPositionTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>

        <Style x:Key="PriorityPlaceholderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
            <Setter Property="FontStyle" Value="Italic" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="PriorityChampionTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource ChampionChipTextStyle}">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="LineHeight" Value="9.5" />
        </Style>

        <Style x:Key="ReferenceChampionTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource ChampionChipTextStyle}">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="LineHeight" Value="9.5" />
        </Style>

        <Style x:Key="ChampionPortraitSlotStyle" TargetType="Border">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource AppSurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppMutedBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
        </Style>

        <Style x:Key="ChampionTileLabelViewboxStyle" TargetType="Viewbox">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="16" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="StretchDirection" Value="DownOnly" />
        </Style>

        <Style x:Key="ChampionPortraitStateBorderStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSwapDropTarget}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsDuplicateDropTarget}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                    <Setter Property="BorderBrush" Value="{DynamicResource DangerAccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DuplicateRemovalOverlayStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Background" Value="{DynamicResource DangerOverlayBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DangerAccentBrush}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDuplicateDropTarget}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PriorityEndGhostStyle" TargetType="Border">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="64" />
            <Setter Property="Background" Value="{DynamicResource AppInputFocusBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Opacity" Value="0.78" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
        </Style>

        <Style x:Key="RoleFilterButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="36" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Background" Value="{DynamicResource AppInputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppStrongBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{Binding Background, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=Transparent}"
                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=Transparent}"
                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=1}"
                                CornerRadius="6"
                                Padding="{Binding Padding, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=0}"
                                TextElement.Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=#E2E8F0}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppInputHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}" />
                </Trigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBlueActionBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueStrongBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource TextInverseBrush}" />
                </DataTrigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppInputPressedBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueSoftBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SearchClearButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,5,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
            <Setter Property="ToolTip" Value="Clear search" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{Binding Background, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=Transparent}"
                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=Transparent}"
                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=0}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppInputHoverBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppInputPressedBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PaneGridSplitterStyle" TargetType="{x:Type GridSplitter}">
            <Setter Property="Width" Value="8" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="ResizeBehavior" Value="PreviousAndNext" />
            <Setter Property="ResizeDirection" Value="Columns" />
            <Setter Property="ShowsPreview" Value="False" />
            <Setter Property="Cursor" Value="SizeWE" />
            <Setter Property="ToolTip" Value="Drag to resize priority and champion panels" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type GridSplitter}">
                        <Grid Background="{TemplateBinding Background}"
                              SnapsToDevicePixels="True">
                            <Border x:Name="SplitterRail"
                                    Width="2"
                                    HorizontalAlignment="Center"
                                    Background="{DynamicResource AppStrongBorderBrush}"
                                    CornerRadius="1"
                                    Opacity="0.65" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SplitterRail" Property="Width" Value="4" />
                                <Setter TargetName="SplitterRail" Property="Background" Value="{DynamicResource AccentBlueBrush}" />
                                <Setter TargetName="SplitterRail" Property="Opacity" Value="0.95" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="SplitterRail" Property="Width" Value="4" />
                                <Setter TargetName="SplitterRail" Property="Background" Value="{DynamicResource AccentBlueSoftBrush}" />
                                <Setter TargetName="SplitterRail" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid x:Name="ContentGrid"
          Margin="0"
          ClipToBounds="True">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="7*" MinWidth="360" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="300" MinWidth="230" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Style="{StaticResource PriorityBoardStyle}">
            <Grid ClipToBounds="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Style="{StaticResource PriorityLockBannerStyle}">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Path Width="14"
                                  Height="14"
                                  Margin="0,0,8,0"
                                  VerticalAlignment="Center"
                                  Stretch="Uniform"
                                  Fill="{DynamicResource TextSecondaryBrush}"
                                  Data="M7,10 V7 A5,5 0 0 1 17,7 V10 H18 A2,2 0 0 1 20,12 V20 A2,2 0 0 1 18,22 H6 A2,2 0 0 1 4,20 V12 A2,2 0 0 1 6,10 H7 M9,10 H15 V7 A3,3 0 0 0 9,7 V10 Z" />
                            <TextBlock Text="Champion priorities are locked during champion select."
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1"
                          Margin="4,0,4,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Pick"
                                   Style="{StaticResource PriorityHeaderTextStyle}" />
                        <TextBlock Grid.Column="2"
                                   Text="Ban"
                                   Style="{StaticResource PriorityHeaderTextStyle}" />
                    </Grid>

                    <ScrollViewer x:Name="PriorityListScrollViewer"
                                  Grid.Row="3"
                                  Style="{StaticResource StableVerticalScrollViewerStyle}">
                        <ItemsControl x:Name="PositionList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource PriorityRowStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0"
                                                       Text="{Binding PositionName}"
                                                       Style="{StaticResource PriorityPositionTextStyle}" />

                                            <Grid Grid.Row="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="4" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Tag="Pick"
                                                Background="{Binding PickBackgroundBrush, FallbackValue=Transparent}"
                                                BorderBrush="{Binding PickBorderBrush, FallbackValue=Transparent}"
                                                AllowDrop="{Binding IsPriorityEditingEnabled, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                                IsEnabled="{Binding IsPriorityEditingEnabled, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                                Focusable="True"
                                                GotKeyboardFocus="ChampionTarget_GotKeyboardFocus"
                                                KeyDown="ChampionTarget_KeyDown"
                                                ToolTip="Focus this list, then type a champion name and press Enter to add it here."
                                                AutomationProperties.Name="{Binding PositionName, StringFormat={}{0} pick champions}"
                                                MouseLeftButtonDown="ChampionTarget_MouseLeftButtonDown"
                                                DragOver="ChampionList_DragOver"
                                                Drop="ChampionList_Drop"
                                                Style="{StaticResource PriorityLaneBorderStyle}">
                                            <StackPanel VerticalAlignment="Top">
                                                <Grid MinHeight="{Binding PickEndGhostMinHeight}">
                                                    <TextBlock Text="Empty"
                                                               Style="{StaticResource PriorityPlaceholderStyle}"
                                                               Visibility="{Binding PickPlaceholderVisibility}" />
                                                    <ItemsControl ItemsSource="{Binding PickChampions}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Width="48"
                                                                      Height="64"
                                                                      Margin="0"
                                                                      VerticalAlignment="Center"
                                                                      Background="Transparent"
                                                                      AllowDrop="{Binding IsPriorityEditingEnabled, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                                                      DragOver="ChampionItem_DragOver"
                                                                      Drop="ChampionItem_Drop">
                                                                    <Border Tag="ChampionPill"
                                                                            Style="{StaticResource ChampionPillBorderStyle}"
                                                                            AutomationProperties.Name="{Binding DisplayText}"
                                                                            ToolTip="{Binding ToolTipText}"
                                                                            GotKeyboardFocus="ChampionItem_GotKeyboardFocus"
                                                                            KeyDown="ChampionItem_KeyDown"
                                                                            PreviewMouseLeftButtonDown="ChampionItem_PreviewMouseLeftButtonDown"
                                                                            MouseMove="ChampionItem_MouseMove">
                                                                        <Grid Width="48"
                                                                              Height="64"
                                                                              ClipToBounds="True">
                                                                            <Grid.RowDefinitions>
                                                                                <RowDefinition Height="Auto" />
                                                                                <RowDefinition Height="0" />
                                                                                <RowDefinition Height="Auto" />
                                                                            </Grid.RowDefinitions>

                                                                            <Border Grid.Row="0"
                                                                                    ClipToBounds="True"
                                                                                    Style="{StaticResource ChampionPortraitSlotStyle}">
                                                                                <Image Source="{Binding PortraitImageSource}"
                                                                                       Stretch="UniformToFill"
                                                                                       SnapsToDevicePixels="True" />
                                                                            </Border>

                                                                            <Viewbox Grid.Row="2"
                                                                                     Style="{StaticResource ChampionTileLabelViewboxStyle}">
                                                                                <TextBlock Text="{Binding ChipDisplayText}"
                                                                                           FontSize="{Binding ChipDisplayFontSize}"
                                                                                           Style="{StaticResource PriorityChampionTextStyle}" />
                                                                            </Viewbox>

                                                                            <Border Grid.Row="0"
                                                                                    Panel.ZIndex="10"
                                                                                    Style="{StaticResource ChampionPortraitStateBorderStyle}" />
                                                                            <Border Grid.Row="0"
                                                                                    Grid.RowSpan="3"
                                                                                    Panel.ZIndex="11"
                                                                                    Style="{StaticResource DuplicateRemovalOverlayStyle}">
                                                                                <viewControls:DropActionGlyph Width="36"
                                                                                                               Height="36"
                                                                                                               HorizontalAlignment="Center"
                                                                                                               VerticalAlignment="Center"
                                                                                                               Foreground="{DynamicResource DangerTextPaleBrush}"
                                                                                                               Kind="{x:Static viewControls:DropActionKind.DuplicateRemoval}" />
                                                                            </Border>
                                                                        </Grid>
                                                                    </Border>

                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <Canvas Panel.ZIndex="20"
                                                            IsHitTestVisible="False">
                                                        <Border Canvas.Left="{Binding PickEndGhostLeft}"
                                                                Canvas.Top="{Binding PickEndGhostTop}"
                                                                Visibility="{Binding PickEndGhostVisibility}"
                                                                Style="{StaticResource PriorityEndGhostStyle}">
                                                            <viewControls:DropActionGlyph Width="28"
                                                                                           Height="28"
                                                                                           HorizontalAlignment="Center"
                                                                                           VerticalAlignment="Center"
                                                                                           Foreground="{DynamicResource AccentBlueTextBrush}"
                                                                                           Kind="{Binding PickEndGhostEffect}" />
                                                        </Border>
                                                    </Canvas>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="1"
                                                Width="1"
                                                Margin="0,5"
                                                HorizontalAlignment="Center"
                                                Background="{DynamicResource AppMutedBorderBrush}" />

                                        <Border Grid.Column="2"
                                                Tag="Ban"
                                                Background="{Binding BanBackgroundBrush, FallbackValue=Transparent}"
                                                BorderBrush="{Binding BanBorderBrush, FallbackValue=Transparent}"
                                                AllowDrop="{Binding IsPriorityEditingEnabled, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                                IsEnabled="{Binding IsPriorityEditingEnabled, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                                Focusable="True"
                                                GotKeyboardFocus="ChampionTarget_GotKeyboardFocus"
                                                KeyDown="ChampionTarget_KeyDown"
                                                ToolTip="Focus this list, then type a champion name and press Enter to add it here."
                                                AutomationProperties.Name="{Binding PositionName, StringFormat={}{0} ban champions}"
                                                MouseLeftButtonDown="ChampionTarget_MouseLeftButtonDown"
                                                DragOver="ChampionList_DragOver"
                                                Drop="ChampionList_Drop"
                                                Style="{StaticResource PriorityLaneBorderStyle}">
                                            <StackPanel VerticalAlignment="Top">
                                                <Grid MinHeight="{Binding BanEndGhostMinHeight}">
                                                    <TextBlock Text="Empty"
                                                               Style="{StaticResource PriorityPlaceholderStyle}"
                                                               Visibility="{Binding BanPlaceholderVisibility}" />
                                                    <ItemsControl ItemsSource="{Binding BanChampions}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Width="48"
                                                                      Height="64"
                                                                      Margin="0"
                                                                      VerticalAlignment="Center"
                                                                      Background="Transparent"
                                                                      AllowDrop="{Binding IsPriorityEditingEnabled, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                                                      DragOver="ChampionItem_DragOver"
                                                                      Drop="ChampionItem_Drop">
                                                                    <Border Tag="ChampionPill"
                                                                            Style="{StaticResource ChampionPillBorderStyle}"
                                                                            AutomationProperties.Name="{Binding DisplayText}"
                                                                            ToolTip="{Binding ToolTipText}"
                                                                            GotKeyboardFocus="ChampionItem_GotKeyboardFocus"
                                                                            KeyDown="ChampionItem_KeyDown"
                                                                            PreviewMouseLeftButtonDown="ChampionItem_PreviewMouseLeftButtonDown"
                                                                            MouseMove="ChampionItem_MouseMove">
                                                                        <Grid Width="48"
                                                                              Height="64"
                                                                              ClipToBounds="True">
                                                                            <Grid.RowDefinitions>
                                                                                <RowDefinition Height="Auto" />
                                                                                <RowDefinition Height="0" />
                                                                                <RowDefinition Height="Auto" />
                                                                            </Grid.RowDefinitions>

                                                                            <Border Grid.Row="0"
                                                                                    ClipToBounds="True"
                                                                                    Style="{StaticResource ChampionPortraitSlotStyle}">
                                                                                <Image Source="{Binding PortraitImageSource}"
                                                                                       Stretch="UniformToFill"
                                                                                       SnapsToDevicePixels="True" />
                                                                            </Border>

                                                                            <Viewbox Grid.Row="2"
                                                                                     Style="{StaticResource ChampionTileLabelViewboxStyle}">
                                                                                <TextBlock Text="{Binding ChipDisplayText}"
                                                                                           FontSize="{Binding ChipDisplayFontSize}"
                                                                                           Style="{StaticResource PriorityChampionTextStyle}" />
                                                                            </Viewbox>

                                                                            <Border Grid.Row="0"
                                                                                    Panel.ZIndex="10"
                                                                                    Style="{StaticResource ChampionPortraitStateBorderStyle}" />
                                                                            <Border Grid.Row="0"
                                                                                    Grid.RowSpan="3"
                                                                                    Panel.ZIndex="11"
                                                                                    Style="{StaticResource DuplicateRemovalOverlayStyle}">
                                                                                <viewControls:DropActionGlyph Width="36"
                                                                                                               Height="36"
                                                                                                               HorizontalAlignment="Center"
                                                                                                               VerticalAlignment="Center"
                                                                                                               Foreground="{DynamicResource DangerTextPaleBrush}"
                                                                                                               Kind="{x:Static viewControls:DropActionKind.DuplicateRemoval}" />
                                                                            </Border>
                                                                        </Grid>
                                                                    </Border>

                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <Canvas Panel.ZIndex="20"
                                                            IsHitTestVisible="False">
                                                        <Border Canvas.Left="{Binding BanEndGhostLeft}"
                                                                Canvas.Top="{Binding BanEndGhostTop}"
                                                                Visibility="{Binding BanEndGhostVisibility}"
                                                                Style="{StaticResource PriorityEndGhostStyle}">
                                                            <viewControls:DropActionGlyph Width="28"
                                                                                           Height="28"
                                                                                           HorizontalAlignment="Center"
                                                                                           VerticalAlignment="Center"
                                                                                           Foreground="{DynamicResource AccentBlueTextBrush}"
                                                                                           Kind="{Binding BanEndGhostEffect}" />
                                                        </Border>
                                                    </Canvas>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                            </Grid>
                                        </Grid>
                                    </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1"
                      Style="{StaticResource PaneGridSplitterStyle}" />

            <Border x:Name="ChampionSearchCard"
                    Grid.Column="2"
                    AllowDrop="True"
                    ClipToBounds="True"
                    Padding="16"
                    PreviewDragOver="SearchArea_PreviewDragOver"
                    PreviewDrop="SearchArea_PreviewDrop"
                    Style="{StaticResource SearchDeleteDropCardStyle}">
                <Grid ClipToBounds="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="0" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <TextBox x:Name="ChampionSearchBox"
                                     TextChanged="ChampionSearchBox_TextChanged"
                                     PreviewKeyDown="ChampionSearchBox_PreviewKeyDown"
                                     Padding="10,6,34,6"
                                     ToolTip="Type a champion name or ID. Press Enter to add the first result."
                                     Style="{StaticResource SearchTextBoxStyle}" />
                            <Button x:Name="ChampionSearchClearButton"
                                    AutomationProperties.Name="Clear champion search"
                                    Click="ChampionSearchClearButton_Click">
                                <Button.Style>
                                    <Style TargetType="Button"
                                           BasedOn="{StaticResource SearchClearButtonStyle}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=ChampionSearchBox, Path=Text}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Path Width="10"
                                      Height="10"
                                      Stretch="Uniform"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Data="M6,6 L18,18 M18,6 L6,18" />
                            </Button>
                        </Grid>

                        <Button x:Name="DeleteSelectedButton"
                                Grid.Column="2"
                                Width="54"
                                Height="30"
                                Padding="0"
                                VerticalAlignment="Center"
                                AutomationProperties.Name="Delete selected champions"
                                Click="DeleteSelectedButton_Click"
                                IsEnabled="{Binding ElementName=RootPage, Path=HasSelectedChampions}"
                                Style="{StaticResource DeleteSelectedButtonStyle}">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Path Width="14"
                                      Height="14"
                                      Stretch="Uniform"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Data="M3,6 L21,6 M8,6 L8,4 L16,4 L16,6 M6,6 L7,21 L17,21 L18,6 M10,11 L10,17 M14,11 L14,17" />
                                <TextBlock Margin="4,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                           Text="{Binding ElementName=RootPage, Path=SelectedChampionCountText}" />
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="4"
                                Content="?"
                                Style="{StaticResource InfoIndicatorStyle}"
                                ToolTip="Click or drag a champion chip into the active pick or ban list. Drop selected chips here to remove them." />
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="24"
                                Height="30"
                                ToolTip="Role filters">
                            <Path Width="14"
                                  Height="14"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Stretch="Uniform"
                                  Fill="{DynamicResource TextMutedBrush}"
                                  Data="M3,4 H21 L14,12 V20 L10,22 V12 Z" />
                        </Border>

                        <ItemsControl x:Name="RoleFilterList"
                                      Grid.Column="2"
                                      VerticalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding DisplayText}"
                                            AutomationProperties.Name="{Binding AutomationName}"
                                            ToolTip="{Binding ToolTipText}"
                                            Click="RoleFilterButton_Click"
                                            Style="{StaticResource RoleFilterButtonStyle}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <Border x:Name="ChampionReferenceBorder"
                            Grid.Row="4"
                            Background="{DynamicResource AppSurfaceInsetBrush}"
                            BorderBrush="{DynamicResource AppStrongBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="8">
                        <ScrollViewer x:Name="ChampionReferenceScrollViewer"
                                      Style="{StaticResource StableVerticalScrollViewerStyle}">
                            <ItemsControl x:Name="ChampionReferenceList">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <controls:JustifiedWrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Click="ChampionReferenceButton_Click"
                                                AutomationProperties.Name="{Binding Name}"
                                                ToolTip="{Binding ToolTipText}"
                                                IsEnabled="{Binding IsPriorityEditingEnabled, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                                PreviewMouseLeftButtonDown="ChampionReferenceButton_PreviewMouseLeftButtonDown"
                                                PreviewMouseMove="ChampionReferenceButton_PreviewMouseMove"
                                                Style="{StaticResource ChampionReferenceButtonStyle}">
                                            <Grid Width="48">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="0" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <Border Grid.Row="0"
                                                        ClipToBounds="True"
                                                        Style="{StaticResource ChampionPortraitSlotStyle}">
                                                    <Image Source="{Binding PortraitImageSource}"
                                                           Stretch="UniformToFill"
                                                           SnapsToDevicePixels="True" />
                                                </Border>

                                                <Viewbox Grid.Row="2"
                                                         Style="{StaticResource ChampionTileLabelViewboxStyle}">
                                                    <TextBlock Text="{Binding ChipDisplayText}"
                                                               FontSize="{Binding ChipDisplayFontSize}"
                                                               Style="{StaticResource ReferenceChampionTextStyle}" />
                                                </Viewbox>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.RowSpan="5"
                            Style="{StaticResource SearchDeleteOverlayStyle}"
                            Background="{DynamicResource DangerOverlayBrush}"
                            BorderBrush="{DynamicResource DangerAccentBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            IsHitTestVisible="False">
                        <Viewbox Width="42"
                                 Height="42"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Path Stroke="{DynamicResource DangerTextPaleBrush}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Data="M3,6 L5,6 M5,6 L21,6 M19,6 L21,6 M8,6 L8,4 L16,4 L16,6 M6,6 L7,21 L17,21 L18,6 M10,11 L10,17 M14,11 L14,17" />
                            </Canvas>
                        </Viewbox>
                    </Border>
                </Grid>
            </Border>

            <Popup x:Name="DragPreviewPopup"
                   Grid.ColumnSpan="3"
                   Placement="RelativePoint"
                   PlacementTarget="{Binding ElementName=RootPage}"
                   AllowsTransparency="True"
                   IsHitTestVisible="False"
                   PopupAnimation="None"
                   StaysOpen="True">
                <Border Background="{DynamicResource AppInputFocusBrush}"
                        BorderBrush="{DynamicResource AccentBlueBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="5"
                        Opacity="0.95">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border x:Name="DragPreviewImageFrame"
                                Width="34"
                                Height="34"
                                Margin="0,0,8,0"
                                Background="{DynamicResource AppSurfaceRaisedBrush}"
                                BorderBrush="{DynamicResource AppMutedBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="3"
                                ClipToBounds="True">
                            <Image x:Name="DragPreviewImage"
                                   Stretch="UniformToFill"
                                   SnapsToDevicePixels="True" />
                        </Border>
                        <TextBlock x:Name="DragPreviewText"
                                   MaxWidth="150"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
</Page>
