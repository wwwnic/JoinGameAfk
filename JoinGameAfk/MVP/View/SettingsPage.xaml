<Page x:Class="JoinGameAfk.View.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Page.Resources>
        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#F8FAFC" />
        </Style>

        <Style x:Key="PageDescriptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#94A3B8" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#12121A" />
            <Setter Property="BorderBrush" Value="#1E1E2A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#E2E8F0" />
        </Style>

        <Style x:Key="SectionDescriptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#94A3B8" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="SettingRowStyle" TargetType="Border">
            <Setter Property="Background" Value="#0F172A" />
            <Setter Property="BorderBrush" Value="#1E293B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,10,0,0" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#CBD5E1" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="FieldHintStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,3,0,0" />
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Width" Value="110" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#182338" />
            <Setter Property="Foreground" Value="#E2E8F0" />
            <Setter Property="CaretBrush" Value="#E2E8F0" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="InputBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="#60A5FA" />
                                <Setter TargetName="InputBorder" Property="Background" Value="#1E293B" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="InputBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InfoIndicatorStyle" TargetType="Button">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#BFDBFE" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Background" Value="#102647" />
            <Setter Property="BorderBrush" Value="#1D4ED8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="150" />
            <Setter Property="ToolTipService.ShowDuration" Value="20000" />
            <Setter Property="ToolTipService.Placement" Value="Mouse" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="InfoBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="11">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="InfoBorder" Property="Background" Value="#1E3A8A" />
                                <Setter TargetName="InfoBorder" Property="BorderBrush" Value="#60A5FA" />
                                <Setter Property="Foreground" Value="#EFF6FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AppCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CBD5E1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="CheckBorder"
                                    Width="20"
                                    Height="20"
                                    Background="#182338"
                                    BorderBrush="#334155"
                                    BorderThickness="1"
                                    CornerRadius="5">
                                <Path x:Name="CheckMark"
                                      Data="M4,10 L8,14 L16,6"
                                      Stroke="#FFFFFF"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter Grid.Column="2"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#60A5FA" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBorder" Property="Background" Value="#2563EB" />
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#60A5FA" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="CheckBorder" Property="Opacity" Value="0.55" />
                                <Setter Property="Foreground" Value="#64748B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.75" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource AccentButtonStyle}">
            <Setter Property="Background" Value="#1E293B" />
            <Setter Property="Foreground" Value="#E2E8F0" />
        </Style>

        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#0F172A" />
            <Setter Property="Foreground" Value="#E2E8F0" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HasDropShadow" Value="True" />
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#0B0E14"
                    BorderBrush="#232836"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="18,16"
                    Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Settings"
                                   Style="{StaticResource PageTitleStyle}" />
                        <TextBlock Text="Tune automation timing, locking behavior, and app storage."
                                   Style="{StaticResource PageDescriptionStyle}"
                                   Margin="0,4,24,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Style="{StaticResource SectionCardStyle}">
                <StackPanel>
                    <TextBlock Text="Matchmaking"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="Ready check behavior."
                               Style="{StaticResource SectionDescriptionStyle}"
                               Margin="0,4,0,0" />

                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Auto accept delay"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <Button Style="{StaticResource InfoIndicatorStyle}"
                                            Content="?"
                                            Margin="8,0,0,0"
                                            ToolTip="Seconds to wait before accepting a ready check. Use 0 to accept immediately." />
                                </StackPanel>
                                <TextBlock Text="Seconds before the app accepts the ready check."
                                           Style="{StaticResource FieldHintStyle}" />
                            </StackPanel>

                            <TextBox x:Name="ReadyCheckAcceptDelayBox"
                                     Grid.Column="2"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     ToolTip="Number of seconds to wait before auto-accepting a ready check." />
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Style="{StaticResource SectionCardStyle}">
                <StackPanel>
                    <TextBlock Text="Champion Select"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="Hover and lock timing."
                               Style="{StaticResource SectionDescriptionStyle}"
                               Margin="0,4,0,0" />

                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox x:Name="AutoLockSelectionCheckBox"
                                              Content="Lock picks and bans automatically"
                                              Style="{StaticResource AppCheckBoxStyle}"
                                              ToolTip="When enabled, the app locks the current pick or ban using the timers below." />
                                    <Button Style="{StaticResource InfoIndicatorStyle}"
                                            Content="?"
                                            Margin="8,0,0,0"
                                            ToolTip="Turn this off if you want hover automation without automatic lock-in." />
                                </StackPanel>
                                <TextBlock Text="Uses your current selected champion when the timer reaches the lock point."
                                           Style="{StaticResource FieldHintStyle}"
                                           Margin="30,3,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Champion hover delay"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <Button Style="{StaticResource InfoIndicatorStyle}"
                                            Content="?"
                                            Margin="8,0,0,0"
                                            ToolTip="Seconds to wait before hovering your configured champion." />
                                </StackPanel>
                                <TextBlock Text="Seconds after a matching pick or ban action is detected."
                                           Style="{StaticResource FieldHintStyle}" />
                            </StackPanel>

                            <TextBox x:Name="ChampionHoverDelayBox"
                                     Grid.Column="2"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     ToolTip="Number of seconds to wait before auto-hovering a configured champion." />
                        </Grid>
                    </Border>

                    <UniformGrid Columns="2"
                                 Margin="0,10,0,0">
                        <Border Background="#0F172A"
                                BorderBrush="#1E293B"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,5,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Pick lock timer"
                                                   Style="{StaticResource FieldLabelStyle}" />
                                        <Button Style="{StaticResource InfoIndicatorStyle}"
                                                Content="?"
                                                Margin="8,0,0,0"
                                                ToolTip="Seconds remaining at which the app locks your pick." />
                                    </StackPanel>
                                    <TextBlock Text="Seconds remaining."
                                               Style="{StaticResource FieldHintStyle}" />
                                </StackPanel>

                                <TextBox x:Name="PickLockDelayBox"
                                         Grid.Column="2"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         ToolTip="Number of seconds remaining at which the app locks your pick." />
                            </Grid>
                        </Border>

                        <Border Background="#0F172A"
                                BorderBrush="#1E293B"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="5,0,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Ban lock timer"
                                                   Style="{StaticResource FieldLabelStyle}" />
                                        <Button Style="{StaticResource InfoIndicatorStyle}"
                                                Content="?"
                                                Margin="8,0,0,0"
                                                ToolTip="Seconds remaining at which the app locks your ban." />
                                    </StackPanel>
                                    <TextBlock Text="Seconds remaining."
                                               Style="{StaticResource FieldHintStyle}" />
                                </StackPanel>

                                <TextBox x:Name="BanLockDelayBox"
                                         Grid.Column="2"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         ToolTip="Number of seconds remaining at which the app locks your ban." />
                            </Grid>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border Grid.Row="3"
                    Style="{StaticResource SectionCardStyle}">
                <StackPanel>
                    <TextBlock Text="Performance"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="How often the app refreshes live champion select data."
                               Style="{StaticResource SectionDescriptionStyle}"
                               Margin="0,4,0,0" />

                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Polling interval"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <Button Style="{StaticResource InfoIndicatorStyle}"
                                            Content="?"
                                            Margin="8,0,0,0"
                                            ToolTip="Milliseconds between champ select refreshes. Values save between 100 and 5000 ms." />
                                </StackPanel>
                                <TextBlock Text="Milliseconds between refreshes. Smaller values react faster."
                                           Style="{StaticResource FieldHintStyle}" />
                            </StackPanel>

                            <TextBox x:Name="ChampSelectPollIntervalBox"
                                     Grid.Column="2"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     ToolTip="Polling interval in milliseconds for champ select monitoring." />
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="4"
                    Style="{StaticResource SectionCardStyle}">
                <StackPanel>
                    <TextBlock Text="Storage"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="Local files used by JoinGameAfk."
                               Style="{StaticResource SectionDescriptionStyle}"
                               Margin="0,4,0,0" />

                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="StoragePathTextBlock"
                                       Grid.Row="0"
                                       Foreground="#CBD5E1"
                                       FontSize="12"
                                       TextWrapping="Wrap" />

                            <Button Grid.Row="1"
                                    Content="Open Storage Folder"
                                    Click="OpenStorageFolderButton_Click"
                                    Background="#1E293B"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="18,9"
                                    Margin="0,12,0,0"
                                    HorizontalAlignment="Left" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="5"
                    Background="#0B0E14"
                    BorderBrush="#232836"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="SaveButton"
                            Grid.Column="0"
                            Content="Save Settings"
                            Click="SaveButton_Click"
                            Background="#2E7D32"
                            Style="{StaticResource AccentButtonStyle}"
                            Padding="24,10"
                            HorizontalAlignment="Left" />

                    <TextBlock x:Name="SavedLabel"
                               Grid.Column="2"
                               Text="Settings saved."
                               Foreground="#7DD3A3"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Visibility="Collapsed" />
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
