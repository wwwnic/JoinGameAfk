<Page x:Class="JoinGameAfk.View.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="18,16"
                    Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Settings"
                                   Style="{StaticResource PageTitleStyle}" />
                        <TextBlock Text="Tune automation timing, locking behavior, and app storage."
                                   Style="{StaticResource PageDescriptionStyle}"
                                   Margin="0,4,24,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button x:Name="SaveButton"
                                Content="Save Settings"
                                Click="SaveButton_Click"
                                Background="{DynamicResource AccentGreenBrush}"
                                Style="{StaticResource AccentButtonStyle}"
                                Padding="24,10"
                                HorizontalAlignment="Right" />

                        <TextBlock x:Name="SavedLabel"
                                   Text="Settings saved."
                                   Foreground="{DynamicResource AccentGreenTextBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Margin="0,7,0,0"
                                   HorizontalAlignment="Right"
                                   Visibility="Collapsed" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Style="{StaticResource SectionCardStyle}"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Appearance"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="Soft, vibrant, and classic app color themes."
                               Style="{StaticResource SectionDescriptionStyle}"
                               Margin="0,4,0,0" />

                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Theme"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <TextBlock Text="Choose the app palette. Saving a new theme reloads the window."
                                           Style="{StaticResource FieldHintStyle}" />
                            </StackPanel>

                            <ComboBox x:Name="ThemeComboBox"
                                      Grid.Column="2"
                                      Width="220"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Key"
                                      Style="{StaticResource AppComboBoxStyle}" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Style="{StaticResource SectionCardStyle}"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Matchmaking"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="Ready check behavior."
                               Style="{StaticResource SectionDescriptionStyle}"
                               Margin="0,4,0,0" />

                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Auto accept delay"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <Button Style="{StaticResource InfoIndicatorStyle}"
                                            Content="?"
                                            Margin="8,0,0,0"
                                            ToolTip="Seconds to wait before accepting a ready check. Use 0 to accept immediately." />
                                </StackPanel>
                                <TextBlock Text="Seconds before the app accepts the ready check."
                                           Style="{StaticResource FieldHintStyle}" />
                            </StackPanel>

                            <TextBox x:Name="ReadyCheckAcceptDelayBox"
                                     Grid.Column="2"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     ToolTip="Number of seconds to wait before auto-accepting a ready check." />
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="3"
                    Style="{StaticResource SectionCardStyle}"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Champion Select"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="Hover and lock timing."
                               Style="{StaticResource SectionDescriptionStyle}"
                               Margin="0,4,0,0" />

                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Lock picks and bans automatically"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <Button Style="{StaticResource InfoIndicatorStyle}"
                                            Content="?"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            ToolTip="Turn this off if you want hover automation without automatic lock-in." />
                                </StackPanel>
                                <TextBlock Text="Uses your current selected champion when the timer reaches the lock point."
                                           Style="{StaticResource FieldHintStyle}"
                                           Margin="0,3,0,0" />
                            </StackPanel>

                            <CheckBox x:Name="AutoLockSelectionCheckBox"
                                      Grid.Column="2"
                                      Style="{StaticResource AppCheckBoxStyle}"
                                      VerticalAlignment="Center"
                                      ToolTip="When enabled, the app locks the current pick or ban using the timers below." />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Champion hover delay"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <Button Style="{StaticResource InfoIndicatorStyle}"
                                            Content="?"
                                            Margin="8,0,0,0"
                                            ToolTip="Seconds to wait before hovering your configured champion." />
                                </StackPanel>
                                <TextBlock Text="Seconds after a matching pick or ban action is detected."
                                           Style="{StaticResource FieldHintStyle}" />
                            </StackPanel>

                            <TextBox x:Name="ChampionHoverDelayBox"
                                     Grid.Column="2"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     ToolTip="Number of seconds to wait before auto-hovering a configured champion." />
                        </Grid>
                    </Border>

                    <UniformGrid Columns="2"
                                 Margin="0,10,0,0">
                        <Border Background="{DynamicResource AppSurfaceRaisedBrush}"
                                BorderBrush="{DynamicResource AppStrongBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,5,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Pick lock timer"
                                                   Style="{StaticResource FieldLabelStyle}" />
                                        <Button Style="{StaticResource InfoIndicatorStyle}"
                                                Content="?"
                                                Margin="8,0,0,0"
                                                ToolTip="Seconds remaining at which the app locks your pick." />
                                    </StackPanel>
                                    <TextBlock Text="Seconds remaining."
                                               Style="{StaticResource FieldHintStyle}" />
                                </StackPanel>

                                <TextBox x:Name="PickLockDelayBox"
                                         Grid.Column="2"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         ToolTip="Number of seconds remaining at which the app locks your pick." />
                            </Grid>
                        </Border>

                        <Border Background="{DynamicResource AppSurfaceRaisedBrush}"
                                BorderBrush="{DynamicResource AppStrongBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="5,0,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Ban lock timer"
                                                   Style="{StaticResource FieldLabelStyle}" />
                                        <Button Style="{StaticResource InfoIndicatorStyle}"
                                                Content="?"
                                                Margin="8,0,0,0"
                                                ToolTip="Seconds remaining at which the app locks your ban." />
                                    </StackPanel>
                                    <TextBlock Text="Seconds remaining."
                                               Style="{StaticResource FieldHintStyle}" />
                                </StackPanel>

                                <TextBox x:Name="BanLockDelayBox"
                                         Grid.Column="2"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         ToolTip="Number of seconds remaining at which the app locks your ban." />
                            </Grid>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border Grid.Row="4"
                    Style="{StaticResource SectionCardStyle}"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Performance"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="How often the app refreshes live champion select data."
                               Style="{StaticResource SectionDescriptionStyle}"
                               Margin="0,4,0,0" />

                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Polling interval"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <Button Style="{StaticResource InfoIndicatorStyle}"
                                            Content="?"
                                            Margin="8,0,0,0"
                                            ToolTip="Milliseconds between champ select refreshes. Values save between 100 and 5000 ms." />
                                </StackPanel>
                                <TextBlock Text="Milliseconds between refreshes. Smaller values react faster."
                                           Style="{StaticResource FieldHintStyle}" />
                            </StackPanel>

                            <TextBox x:Name="ChampSelectPollIntervalBox"
                                     Grid.Column="2"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     ToolTip="Polling interval in milliseconds for champ select monitoring." />
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="5"
                    Style="{StaticResource SectionCardStyle}"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Storage"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="Local files used by JoinGameAfk."
                               Style="{StaticResource SectionDescriptionStyle}"
                               Margin="0,4,0,0" />

                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="StoragePathTextBlock"
                                       Grid.Row="0"
                                       Foreground="{DynamicResource TextSoftBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />

                            <Button Grid.Row="1"
                                    Content="Open Storage Folder"
                                    Click="OpenStorageFolderButton_Click"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Padding="18,9"
                                    Margin="0,12,0,0"
                                    HorizontalAlignment="Left" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>
</Page>
