<Page x:Class="JoinGameAfk.View.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:viewControls="clr-namespace:JoinGameAfk.View.Controls"
      Background="Transparent">
    <Grid>
    <ScrollViewer x:Name="SettingsScrollViewer"
                  Style="{StaticResource StableVerticalScrollViewerStyle}">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="18,16"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Settings"
                                   Style="{StaticResource PageTitleStyle}" />
                        <TextBlock Text="Tune startup behavior, automation timing, sounds, locking behavior, and app storage."
                                   Style="{StaticResource PageDescriptionStyle}"
                                   Margin="0,4,24,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button x:Name="ResetDefaultsButton"
                                    Content="Reset Defaults"
                                    Click="ResetDefaultsButton_Click"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="18,10"
                                    HorizontalAlignment="Right"
                                    ToolTip="Restore startup, automation, sound, timing, performance, and theme defaults without changing champion priorities." />

                            <Button x:Name="SaveButton"
                                    Content="Save Settings"
                                    Click="SaveButton_Click"
                                    Background="{DynamicResource AccentGreenBrush}"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Padding="24,10"
                                    Margin="10,0,0,0"
                                    HorizontalAlignment="Right" />
                        </StackPanel>

                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Style="{StaticResource SectionCardStyle}"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Appearance"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="Soft, vibrant, and classic app color themes."
                               Style="{StaticResource SectionDescriptionStyle}"
                               Margin="0,4,0,0" />

                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Theme"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <TextBlock Text="Choose the app palette. Saving a new theme reloads the window."
                                           Style="{StaticResource FieldHintStyle}" />
                            </StackPanel>

                            <ComboBox x:Name="ThemeComboBox"
                                      Grid.Column="2"
                                      Width="220"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Key"
                                      Style="{StaticResource AppComboBoxStyle}" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Style="{StaticResource SectionCardStyle}"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Startup"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="Choose what happens when the app opens."
                               Style="{StaticResource SectionDescriptionStyle}"
                               Margin="0,4,0,0" />

                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Start watcher on app launch"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <Button Style="{StaticResource InfoIndicatorStyle}"
                                            Content="?"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            ToolTip="When enabled, the watcher starts automatically after the app window opens." />
                                </StackPanel>
                                <TextBlock Text="The app begins watching for the League Client without pressing Start watcher."
                                           Style="{StaticResource FieldHintStyle}"
                                           Margin="0,3,0,0" />
                            </StackPanel>

                            <CheckBox x:Name="StartWatcherOnStartupCheckBox"
                                      Grid.Column="2"
                                      Style="{StaticResource AppCheckBoxStyle}"
                                      VerticalAlignment="Center"
                                      ToolTip="When disabled, the watcher starts only from the toolbar button." />
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="3"
                    Style="{StaticResource SectionCardStyle}"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="In Queue"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="Ready check behavior."
                               Style="{StaticResource SectionDescriptionStyle}"
                               Margin="0,4,0,0" />

                    <Border x:Name="InQueueAutomationMasterRow"
                            Style="{StaticResource AutomationMasterRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="In queue automation"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <Button Style="{StaticResource InfoIndicatorStyle}"
                                            Content="?"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            ToolTip="Turn this off if you want the app to take no automated actions while you are in queue." />
                                </StackPanel>
                                <TextBlock Text="Master switch for ready check actions."
                                           Style="{StaticResource FieldHintStyle}"
                                           Margin="0,3,0,0" />
                            </StackPanel>

                            <CheckBox x:Name="InQueueAutomationCheckBox"
                                      Grid.Column="2"
                                      Style="{StaticResource AutomationMasterCheckBoxStyle}"
                                      VerticalAlignment="Center"
                                      Checked="InQueueAutomationCheckBox_StateChanged"
                                      Unchecked="InQueueAutomationCheckBox_StateChanged"
                                      ToolTip="When disabled, the app monitors queue state but does not accept ready checks." />
                        </Grid>
                    </Border>

                    <StackPanel x:Name="InQueueAutomationOptionsPanel">
                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Accept ready checks automatically"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <Button Style="{StaticResource InfoIndicatorStyle}"
                                            Content="?"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            ToolTip="Turn this off if you want the app to detect ready checks but never accept them." />
                                </StackPanel>
                                <TextBlock Text="Controls whether ready check automation sends the accept action."
                                           Style="{StaticResource FieldHintStyle}"
                                           Margin="0,3,0,0" />
                            </StackPanel>

                            <CheckBox x:Name="AutoReadyCheckCheckBox"
                                      Grid.Column="2"
                                      Style="{StaticResource AppCheckBoxStyle}"
                                      VerticalAlignment="Center"
                                      Checked="AutomationCheckBox_StateChanged"
                                      Unchecked="AutomationCheckBox_StateChanged"
                                      ToolTip="When enabled, the app accepts ready checks after the configured delay." />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Play sound when ready check appears"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <Button Style="{StaticResource InfoIndicatorStyle}"
                                            Content="?"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            ToolTip="Plays a short cue as soon as the ready check popup is detected." />
                                </StackPanel>
                                <TextBlock Text="A cue plays when the accept popup appears, before any configured auto-accept delay."
                                           Style="{StaticResource FieldHintStyle}"
                                           Margin="0,3,0,0" />
                            </StackPanel>

                            <CheckBox x:Name="ReadyCheckSoundNotificationCheckBox"
                                      Grid.Column="2"
                                      Style="{StaticResource AppCheckBoxStyle}"
                                      VerticalAlignment="Center"
                                      Checked="AutomationCheckBox_StateChanged"
                                      Unchecked="AutomationCheckBox_StateChanged"
                                      ToolTip="When enabled, the app plays a short sound when a ready check popup appears." />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Ready check sound"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <Button Style="{StaticResource InfoIndicatorStyle}"
                                            Content="?"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            ToolTip="Choose the cue that plays when a ready check popup appears." />
                                </StackPanel>
                                <TextBlock Text="Preview the selected cue before saving."
                                           Style="{StaticResource FieldHintStyle}"
                                           Margin="0,3,0,0" />
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <ComboBox x:Name="ReadyCheckSoundComboBox"
                                          Width="230"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Key"
                                          Style="{StaticResource AppComboBoxStyle}"
                                          ToolTip="Sound used when a ready check is detected." />
                                <Button x:Name="ReadyCheckSoundPreviewButton"
                                        Content="Preview"
                                        Click="PreviewReadyCheckSoundButton_Click"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="16,9"
                                        Margin="10,0,0,0"
                                        ToolTip="Play the selected ready check sound." />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Auto accept delay"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <Button Style="{StaticResource InfoIndicatorStyle}"
                                            Content="?"
                                            Margin="8,0,0,0"
                                            ToolTip="Seconds to wait before accepting a ready check. Use 0 to accept immediately." />
                                </StackPanel>
                                <TextBlock Text="Seconds before the app accepts the ready check."
                                           Style="{StaticResource FieldHintStyle}" />
                            </StackPanel>

                            <TextBox x:Name="ReadyCheckAcceptDelayBox"
                                     Grid.Column="2"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     ToolTip="Number of seconds to wait before auto-accepting a ready check." />
                        </Grid>
                    </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="4"
                    Style="{StaticResource SectionCardStyle}"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Champion Select"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="Hover, lock, and timing behavior."
                               Style="{StaticResource SectionDescriptionStyle}"
                               Margin="0,4,0,0" />

                    <Border x:Name="ChampionSelectAutomationMasterRow"
                            Style="{StaticResource AutomationMasterRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Champion select automation"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <Button Style="{StaticResource InfoIndicatorStyle}"
                                            Content="?"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            ToolTip="Turn this off if you want the app to take no automated pick or ban actions during champion select." />
                                </StackPanel>
                                <TextBlock Text="Master switch for champion hover and lock actions."
                                           Style="{StaticResource FieldHintStyle}"
                                           Margin="0,3,0,0" />
                            </StackPanel>

                            <CheckBox x:Name="ChampionSelectAutomationCheckBox"
                                      Grid.Column="2"
                                      Style="{StaticResource AutomationMasterCheckBoxStyle}"
                                      VerticalAlignment="Center"
                                      Checked="ChampionSelectAutomationCheckBox_StateChanged"
                                      Unchecked="ChampionSelectAutomationCheckBox_StateChanged"
                                      ToolTip="When disabled, the app monitors champion select but does not hover or lock champions." />
                        </Grid>
                    </Border>

                    <StackPanel x:Name="ChampionSelectAutomationOptionsPanel">
                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Hover configured champions automatically"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <Button Style="{StaticResource InfoIndicatorStyle}"
                                            Content="?"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            ToolTip="Turn this off if you want champion priorities shown without sending hover actions." />
                                </StackPanel>
                                <TextBlock Text="Uses your pick and ban priorities to select a champion during your action."
                                           Style="{StaticResource FieldHintStyle}"
                                           Margin="0,3,0,0" />
                            </StackPanel>

                            <CheckBox x:Name="AutoHoverChampionCheckBox"
                                      Grid.Column="2"
                                      Style="{StaticResource AppCheckBoxStyle}"
                                      VerticalAlignment="Center"
                                      Checked="AutomationCheckBox_StateChanged"
                                      Unchecked="AutomationCheckBox_StateChanged"
                                      ToolTip="When enabled, the app hovers configured pick and ban priorities." />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Lock picks and bans automatically"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <Button Style="{StaticResource InfoIndicatorStyle}"
                                            Content="?"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            ToolTip="Turn this off if you want hover automation without automatic lock-in." />
                                </StackPanel>
                                <TextBlock Text="Uses your current selected champion when the timer reaches the lock point."
                                           Style="{StaticResource FieldHintStyle}"
                                           Margin="0,3,0,0" />
                            </StackPanel>

                            <CheckBox x:Name="AutoLockSelectionCheckBox"
                                      Grid.Column="2"
                                      Style="{StaticResource AppCheckBoxStyle}"
                                      VerticalAlignment="Center"
                                      Checked="AutomationCheckBox_StateChanged"
                                      Unchecked="AutomationCheckBox_StateChanged"
                                      ToolTip="When enabled, the app locks the current pick or ban using the timers below." />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Champion hover delay"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <Button Style="{StaticResource InfoIndicatorStyle}"
                                            Content="?"
                                            Margin="8,0,0,0"
                                            ToolTip="Seconds after a pick or ban action starts before hovering your configured champion." />
                                </StackPanel>
                                <TextBlock Text="Used after a pick or ban action starts."
                                           Style="{StaticResource FieldHintStyle}" />
                            </StackPanel>

                            <TextBox x:Name="ChampionHoverDelayBox"
                                     Grid.Column="2"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     ToolTip="Number of seconds to wait before auto-hovering a configured champion." />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Planning hover delay"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <Button Style="{StaticResource InfoIndicatorStyle}"
                                            Content="?"
                                            Margin="8,0,0,0"
                                            ToolTip="Minimum seconds after planning phase starts before hovering your configured pick." />
                                </StackPanel>
                                <TextBlock Text="Planning uses the larger of this delay and the champion hover delay."
                                           Style="{StaticResource FieldHintStyle}" />
                            </StackPanel>

                            <TextBox x:Name="PlanningHoverDelayBox"
                                     Grid.Column="2"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     ToolTip="Minimum number of seconds to wait before auto-hovering during planning phase." />
                        </Grid>
                    </Border>

                    <UniformGrid Columns="2"
                                 Margin="0,10,0,0">
                        <Border Background="{DynamicResource AppSurfaceRaisedBrush}"
                                BorderBrush="{DynamicResource AppStrongBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,5,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Pick lock timer"
                                                   Style="{StaticResource FieldLabelStyle}" />
                                        <Button Style="{StaticResource InfoIndicatorStyle}"
                                                Content="?"
                                                Margin="8,0,0,0"
                                                ToolTip="Seconds remaining at which the app locks your pick." />
                                    </StackPanel>
                                    <TextBlock Text="Seconds remaining."
                                               Style="{StaticResource FieldHintStyle}" />
                                </StackPanel>

                                <TextBox x:Name="PickLockDelayBox"
                                         Grid.Column="2"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         ToolTip="Number of seconds remaining at which the app locks your pick." />
                            </Grid>
                        </Border>

                        <Border Background="{DynamicResource AppSurfaceRaisedBrush}"
                                BorderBrush="{DynamicResource AppStrongBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="5,0,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Ban lock timer"
                                                   Style="{StaticResource FieldLabelStyle}" />
                                        <Button Style="{StaticResource InfoIndicatorStyle}"
                                                Content="?"
                                                Margin="8,0,0,0"
                                                ToolTip="Seconds remaining at which the app locks your ban." />
                                    </StackPanel>
                                    <TextBlock Text="Seconds remaining."
                                               Style="{StaticResource FieldHintStyle}" />
                                </StackPanel>

                                <TextBox x:Name="BanLockDelayBox"
                                         Grid.Column="2"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         ToolTip="Number of seconds remaining at which the app locks your ban." />
                            </Grid>
                        </Border>
                    </UniformGrid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="5"
                    Style="{StaticResource SectionCardStyle}"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Mini Overlay"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="Pick/ban overlay window behavior."
                               Style="{StaticResource SectionDescriptionStyle}"
                               Margin="0,4,0,0" />

                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Open when champion select starts"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <Button Style="{StaticResource InfoIndicatorStyle}"
                                            Content="?"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            ToolTip="When enabled, the mini overlay opens automatically for champion select and planning phases." />
                                </StackPanel>
                                <TextBlock Text="Manual close still suppresses reopening for the current champion select."
                                           Style="{StaticResource FieldHintStyle}"
                                           Margin="0,3,0,0" />
                            </StackPanel>

                            <CheckBox x:Name="AutoShowPickBanOverlayCheckBox"
                                      Grid.Column="2"
                                      Style="{StaticResource AppCheckBoxStyle}"
                                      VerticalAlignment="Center"
                                      ToolTip="When disabled, the mini overlay only opens from the toolbar button or startup option." />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Close when champion select is over"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <Button Style="{StaticResource InfoIndicatorStyle}"
                                            Content="?"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            ToolTip="When enabled, an overlay that was visible during champion select closes after champion select ends, the watcher stops, or the League Client disconnects." />
                                </StackPanel>
                                <TextBlock Text="Keeps the overlay from staying open after the draft context is gone."
                                           Style="{StaticResource FieldHintStyle}"
                                           Margin="0,3,0,0" />
                            </StackPanel>

                            <CheckBox x:Name="AutoClosePickBanOverlayCheckBox"
                                      Grid.Column="2"
                                      Style="{StaticResource AppCheckBoxStyle}"
                                      VerticalAlignment="Center"
                                      ToolTip="When disabled, the mini overlay stays open until closed manually." />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Open on app startup"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <Button Style="{StaticResource InfoIndicatorStyle}"
                                            Content="?"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            ToolTip="When enabled, the mini overlay opens after the main app window appears." />
                                </StackPanel>
                                <TextBlock Text="Uses the last saved overlay position when available."
                                           Style="{StaticResource FieldHintStyle}"
                                           Margin="0,3,0,0" />
                            </StackPanel>

                            <CheckBox x:Name="OpenPickBanOverlayOnStartupCheckBox"
                                      Grid.Column="2"
                                      Style="{StaticResource AppCheckBoxStyle}"
                                      VerticalAlignment="Center"
                                      ToolTip="When disabled, startup leaves the mini overlay closed." />
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="6"
                    Style="{StaticResource SectionCardStyle}"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Champion Data"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="Riot Data Dragon sync."
                               Style="{StaticResource SectionDescriptionStyle}"
                               Margin="0,4,0,0" />

                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Check champion data updates on startup"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <Button Style="{StaticResource InfoIndicatorStyle}"
                                            Content="?"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            ToolTip="When enabled, startup checks Riot Data Dragon's latest version, then downloads champion names or picture assets only when the local version is different." />
                                </StackPanel>
                                <TextBlock Text="Fetches the latest version first; champion names and picture archive download only when an update is available."
                                           Style="{StaticResource FieldHintStyle}"
                                           Margin="0,3,0,0" />
                            </StackPanel>

                            <CheckBox x:Name="AutoUpdateChampionCatalogOnStartupCheckBox"
                                      Grid.Column="2"
                                      Style="{StaticResource AppCheckBoxStyle}"
                                      VerticalAlignment="Center"
                                      Checked="AutoUpdateChampionCatalogOnStartupCheckBox_Checked"
                                      ToolTip="When enabled, startup compares the local champion data version with the latest Riot Data Dragon version before downloading updates." />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingRowStyle}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Champion list"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Text="Shows a confirmation before downloading the latest Riot Data Dragon champion names."
                                               Style="{StaticResource FieldHintStyle}" />
                                </StackPanel>

                                <Button x:Name="RefreshChampionCatalogButton"
                                        Grid.Column="2"
                                        Content="Update Champion List"
                                        Click="RefreshChampionCatalogButton_Click"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Padding="18,9"
                                        HorizontalAlignment="Right"
                                        ToolTip="Fetches Riot Data Dragon versions and champion data, then updates the local champions.json file." />
                            </Grid>

                            <TextBlock x:Name="ChampionCatalogSyncStatusTextBlock"
                                       Foreground="{DynamicResource TextSoftBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Margin="0,10,0,0" />

                            <TextBlock x:Name="ChampionCatalogRefreshStatusLabel"
                                       Foreground="{DynamicResource TextSoftBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0"
                                       Visibility="Collapsed" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Champion picture archive"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Text="Download Riot Data Dragon's dragontail archive, extract champion tile jpg files, then remove the archive."
                                               Style="{StaticResource FieldHintStyle}" />
                                    <TextBlock Text="The archive is deleted after extraction so only champion tiles stay on disk."
                                               Style="{StaticResource FieldHintStyle}"
                                               Margin="0,4,0,0" />
                                </StackPanel>

                                <Button x:Name="DownloadChampionPictureArchiveButton"
                                        Grid.Column="2"
                                        Content="Download Archive"
                                        Click="DownloadChampionPictureArchiveButton_Click"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Padding="18,9"
                                        MinWidth="168"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        ToolTip="Download the latest Riot Data Dragon dragontail archive, extract champion tiles into the local cache, then delete the archive." />
                            </Grid>

                            <TextBlock x:Name="ChampionPictureCacheStatusTextBlock"
                                       Grid.Row="1"
                                       Foreground="{DynamicResource TextSoftBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Margin="0,10,0,0" />
                            <TextBlock x:Name="ChampionPictureDownloadStatusLabel"
                                       Grid.Row="2"
                                       Foreground="{DynamicResource TextSoftBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0"
                                       Visibility="Collapsed" />
                            <ProgressBar x:Name="ChampionPictureDownloadProgressBar"
                                         Grid.Row="3"
                                         Height="8"
                                         Minimum="0"
                                         Maximum="100"
                                         Margin="0,8,0,0"
                                         Visibility="Collapsed" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Champion pictures"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <TextBlock Text="Choose which local Data Dragon champion tile appears in champion priority chips."
                                           Style="{StaticResource FieldHintStyle}" />
                                <TextBlock x:Name="ChampionPictureFolderPathTextBlock"
                                           Foreground="{DynamicResource TextSoftBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0" />
                                <TextBlock x:Name="ChampionPictureStatusTextBlock"
                                           Foreground="{DynamicResource TextSoftBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0" />
                            </StackPanel>

                            <Grid Grid.Column="2"
                                  Width="570">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ComboBox x:Name="ChampionPictureChampionComboBox"
                                          Grid.Row="0"
                                          Grid.Column="0"
                                          Grid.ColumnSpan="3"
                                          Width="390"
                                          MaxDropDownHeight="360"
                                          SelectionChanged="ChampionPictureChampionComboBox_SelectionChanged"
                                          Style="{StaticResource AppComboBoxStyle}"
                                          ToolTip="Champion to configure. Open the list to preview the picture currently applied to each champion.">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid MinWidth="180"
                                                  Margin="0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="42" />
                                                    <ColumnDefinition Width="10" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0"
                                                        Width="38"
                                                        Height="38"
                                                        Background="{DynamicResource AppSurfaceRaisedBrush}"
                                                        BorderBrush="{DynamicResource AppMutedBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        ClipToBounds="True">
                                                    <Grid>
                                                        <viewControls:ChampionMysteryGlyph Width="26"
                                                                                           Height="26"
                                                                                           HorizontalAlignment="Center"
                                                                                           VerticalAlignment="Center"
                                                                                           Foreground="{DynamicResource TextSubtleBrush}" />
                                                        <Image Source="{Binding ImageSource}"
                                                               Stretch="UniformToFill"
                                                               SnapsToDevicePixels="True" />
                                                    </Grid>
                                                </Border>

                                                <StackPanel Grid.Column="2"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding AppliedPictureText}"
                                                               FontSize="10"
                                                               Opacity="0.72"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <Button x:Name="ResetChampionPictureButton"
                                        Grid.Row="0"
                                        Grid.Column="4"
                                        Content="Use Default"
                                        Click="ResetChampionPictureButton_Click"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="12,8"
                                        ToolTip="Remove the custom picture selection for this champion." />

                                <Border Grid.Column="6"
                                        Grid.RowSpan="3"
                                        Width="52"
                                        Height="52"
                                        Background="{DynamicResource AppSurfaceRaisedBrush}"
                                        BorderBrush="{DynamicResource AppMutedBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        ClipToBounds="True">
                                    <Grid>
                                        <viewControls:ChampionMysteryGlyph Width="36"
                                                                           Height="36"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{DynamicResource TextSubtleBrush}" />
                                        <Image x:Name="ChampionPicturePreviewImage"
                                               Stretch="UniformToFill"
                                               SnapsToDevicePixels="True" />
                                    </Grid>
                                </Border>

                                <ListBox x:Name="ChampionPictureTileListBox"
                                         Grid.Row="2"
                                         Grid.Column="0"
                                         Grid.ColumnSpan="5"
                                         MinHeight="104"
                                         MaxHeight="184"
                                         Padding="8"
                                         Background="{DynamicResource AppInputBrush}"
                                         BorderBrush="{DynamicResource AppStrongBorderBrush}"
                                         BorderThickness="1"
                                         Foreground="{DynamicResource TextSecondaryBrush}"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         SelectionChanged="ChampionPictureTileListBox_SelectionChanged"
                                         SelectionMode="Single"
                                         KeyboardNavigation.DirectionalNavigation="Contained"
                                         ToolTip="Available pictures for the selected champion. Use mouse, arrow keys, or space to select a tile.">
                                    <ListBox.Resources>
                                        <Style TargetType="ScrollBar"
                                               BasedOn="{StaticResource SlimVerticalScrollBarStyle}" />
                                    </ListBox.Resources>
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Width" Value="86" />
                                            <Setter Property="Height" Value="94" />
                                            <Setter Property="Margin" Value="0,0,8,8" />
                                            <Setter Property="Padding" Value="4" />
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource AppMutedBorderBrush}" />
                                            <Setter Property="BorderThickness" Value="2" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="TileBorder"
                                                                Background="{Binding Background, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=Transparent}"
                                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=Transparent}"
                                                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=1}"
                                                                CornerRadius="6"
                                                                Padding="{Binding Padding, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=0}"
                                                                TextElement.Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=#E2E8F0}">
                                                            <ContentPresenter HorizontalAlignment="{Binding HorizontalContentAlignment, RelativeSource={RelativeSource TemplatedParent}}"
                                                                              VerticalAlignment="{Binding VerticalContentAlignment, RelativeSource={RelativeSource TemplatedParent}}" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="TileBorder" Property="Background" Value="{DynamicResource AppInputHoverBrush}" />
                                                                <Setter TargetName="TileBorder" Property="BorderBrush" Value="{DynamicResource AppHoverBorderBrush}" />
                                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                            </Trigger>
                                                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                                <Setter TargetName="TileBorder" Property="Background" Value="{DynamicResource AppInputFocusBrush}" />
                                                                <Setter TargetName="TileBorder" Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}" />
                                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="TileBorder" Property="Background" Value="{DynamicResource AccentBlueActionBrush}" />
                                                                <Setter TargetName="TileBorder" Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}" />
                                                                <Setter Property="Foreground" Value="{DynamicResource TextInverseBrush}" />
                                                            </Trigger>
                                                            <MultiTrigger>
                                                                <MultiTrigger.Conditions>
                                                                    <Condition Property="IsSelected" Value="True" />
                                                                    <Condition Property="IsKeyboardFocusWithin" Value="True" />
                                                                </MultiTrigger.Conditions>
                                                                <Setter TargetName="TileBorder" Property="BorderBrush" Value="{DynamicResource AccentBluePaleBrush}" />
                                                            </MultiTrigger>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter TargetName="TileBorder" Property="Opacity" Value="0.55" />
                                                                <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Width="76"
                                                  ToolTip="{Binding FileName}">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="4" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <Border Grid.Row="0"
                                                        Width="62"
                                                        Height="62"
                                                        HorizontalAlignment="Center"
                                                        Background="{DynamicResource AppSurfaceRaisedBrush}"
                                                        BorderBrush="{DynamicResource AppMutedBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        ClipToBounds="True">
                                                    <Grid>
                                                        <viewControls:ChampionMysteryGlyph Width="44"
                                                                                           Height="44"
                                                                                           HorizontalAlignment="Center"
                                                                                           VerticalAlignment="Center"
                                                                                           Foreground="{DynamicResource TextSubtleBrush}" />
                                                        <Image Source="{Binding ImageSource}"
                                                               Stretch="UniformToFill"
                                                               SnapsToDevicePixels="True" />
                                                    </Grid>
                                                </Border>

                                                <TextBlock Grid.Row="2"
                                                           Text="{Binding ShortDisplayName}"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           TextAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <WrapPanel Grid.Row="4"
                                           Grid.Column="0"
                                           Grid.ColumnSpan="5"
                                           HorizontalAlignment="Right">
                                    <Button x:Name="OpenChampionPictureFolderButton"
                                            Content="Open Pictures Folder"
                                            Click="OpenChampionPictureFolderButton_Click"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Padding="12,8"
                                            ToolTip="Open the local folder where champion tile jpg files are stored." />
                                    <Button x:Name="ReloadChampionPicturesButton"
                                            Content="Reload Pictures"
                                            Click="ReloadChampionPicturesButton_Click"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Padding="12,8"
                                            Margin="8,0,0,0"
                                            ToolTip="Rescan the local champion picture folder." />
                                </WrapPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="7"
                    Style="{StaticResource SectionCardStyle}"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Legal"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="Riot Games notice."
                               Style="{StaticResource SectionDescriptionStyle}"
                               Margin="0,4,0,0" />

                    <Border Style="{StaticResource SettingRowStyle}">
                        <StackPanel>
                            <TextBlock Text="JoinGameAfk uses public champion names from Riot Data Dragon to identify player-configured pick/ban preferences. Champion pictures, when configured, are Riot Games-owned assets provided through Riot Data Dragon and loaded from your local app storage."
                                       Style="{StaticResource FieldHintStyle}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="JoinGameAfk was created under Riot Games' Legal Jibber Jabber policy using assets owned by Riot Games. Riot Games does not endorse or sponsor this project."
                                       Style="{StaticResource FieldHintStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0" />
                            <TextBlock Text="JoinGameAfk is not endorsed by Riot Games and does not reflect the views or opinions of Riot Games or anyone officially involved in producing or managing Riot Games properties. Riot Games and all associated properties are trademarks or registered trademarks of Riot Games, Inc."
                                       Style="{StaticResource FieldHintStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="8"
                    Style="{StaticResource SectionCardStyle}"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Performance"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="Choose live LCU events or regular polling for League Client updates."
                               Style="{StaticResource SectionDescriptionStyle}"
                               Margin="0,4,0,0" />

                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Use live LCU events (recommended)"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <Button Style="{StaticResource InfoIndicatorStyle}"
                                            Content="?"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            ToolTip="Recommended. When enabled, websocket events are used for live League Client updates." />
                                </StackPanel>
                                <TextBlock Text="Recommended for faster updates and fewer idle requests. Turn this off to use regular HTTP polling only."
                                           Style="{StaticResource FieldHintStyle}" />
                            </StackPanel>

                            <CheckBox x:Name="UseLiveEventsCheckBox"
                                      Grid.Column="2"
                                      Style="{StaticResource AppCheckBoxStyle}"
                                      VerticalAlignment="Center"
                                      Checked="PerformanceCheckBox_StateChanged"
                                      Unchecked="PerformanceCheckBox_StateChanged"
                                      ToolTip="Recommended. When disabled, the app uses the regular polling interval instead of live LCU events." />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Regular polling interval"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <Button Style="{StaticResource InfoIndicatorStyle}"
                                            Content="?"
                                            Margin="8,0,0,0"
                                            ToolTip="Milliseconds between regular HTTP refreshes when live events are disabled. This value is also used automatically if the event stream is unavailable." />
                                </StackPanel>
                                <TextBlock Text="Editable when live events are off; also used automatically if live events become unavailable."
                                           Style="{StaticResource FieldHintStyle}" />
                            </StackPanel>

                            <TextBox x:Name="ChampSelectPollIntervalBox"
                                     Grid.Column="2"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     ToolTip="Regular polling interval in milliseconds for League Client monitoring when live events are not active." />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Fallback polling while live events are connected"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <Button Style="{StaticResource InfoIndicatorStyle}"
                                            Content="?"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            ToolTip="Optional safety refresh while the websocket event stream is connected. Leave this off for the lowest idle activity." />
                                </StackPanel>
                                <TextBlock Text="Off by default. If live events fail, the app still uses regular polling automatically."
                                           Style="{StaticResource FieldHintStyle}"
                                           Margin="0,3,0,0" />
                            </StackPanel>

                            <CheckBox x:Name="EventFallbackPollingCheckBox"
                                      Grid.Column="2"
                                      Style="{StaticResource AppCheckBoxStyle}"
                                      VerticalAlignment="Center"
                                      Checked="PerformanceCheckBox_StateChanged"
                                      Unchecked="PerformanceCheckBox_StateChanged"
                                      ToolTip="When enabled, the app periodically refreshes over HTTP even while live LCU events are connected." />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Event fallback polling interval"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <Button Style="{StaticResource InfoIndicatorStyle}"
                                            Content="?"
                                            Margin="8,0,0,0"
                                            ToolTip="Safety refresh interval when fallback polling is enabled. Values save between 1000 and 30000 ms." />
                                </StackPanel>
                                <TextBlock Text="Used only when fallback polling is enabled while live events are connected."
                                           Style="{StaticResource FieldHintStyle}" />
                            </StackPanel>

                            <TextBox x:Name="EventFallbackPollIntervalBox"
                                     Grid.Column="2"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     ToolTip="Fallback polling interval in milliseconds while live LCU events are connected." />
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="9"
                    Style="{StaticResource SectionCardStyle}"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Storage"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="Local files used by JoinGameAfk."
                               Style="{StaticResource SectionDescriptionStyle}"
                               Margin="0,4,0,0" />

                    <Border Style="{StaticResource SettingRowStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="StoragePathTextBlock"
                                       Grid.Row="0"
                                       Foreground="{DynamicResource TextSoftBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />

                            <Button Grid.Row="1"
                                    Content="Open Storage Folder"
                                    Click="OpenStorageFolderButton_Click"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Padding="18,9"
                                    Margin="0,12,0,0"
                                    HorizontalAlignment="Left" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>

    <Border x:Name="DirtySettingsBar"
            Panel.ZIndex="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom"
            Margin="0,0,18,16"
            Background="{DynamicResource AppSurfaceBrush}"
            BorderBrush="{DynamicResource AccentGreenBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Height="76"
            Padding="14,10"
            Visibility="Collapsed">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        VerticalAlignment="Center">
                <TextBlock Text="Unsaved settings changes"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock Text="Save to keep the current settings."
                           Style="{StaticResource FieldHintStyle}" />
            </StackPanel>

            <Button x:Name="FloatingSaveButton"
                    Grid.Column="2"
                    Content="Save Settings"
                    Click="SaveButton_Click"
                    Background="{DynamicResource AccentGreenBrush}"
                    Style="{StaticResource AccentButtonStyle}"
                    Padding="24,10"
                    VerticalAlignment="Center"
                    AutomationProperties.Name="Save dirty settings" />
        </Grid>
    </Border>

    <Border x:Name="FloatingSettingsStatusBar"
            Panel.ZIndex="2"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom"
            Margin="0,0,18,16"
            Background="{DynamicResource AppSurfaceBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Height="76"
            Padding="14,10"
            Visibility="Collapsed">
        <TextBlock x:Name="FloatingSettingsStatusText"
                   FontSize="13"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap"
                   VerticalAlignment="Center" />
    </Border>
    </Grid>
</Page>
