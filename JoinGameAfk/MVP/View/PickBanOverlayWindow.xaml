<Window x:Class="JoinGameAfk.View.PickBanOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:JoinGameAfk.View.Controls"
        Title="Pick/Ban Overlay"
        Width="360"
        Height="435"
        MinWidth="300"
        MinHeight="260"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowActivated="False"
        ShowInTaskbar="True"
        Topmost="True"
        Closed="Window_Closed">
    <Window.Resources>
        <Style x:Key="OverlayTitleButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource TitleBarButtonStyle}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="5,0,0,0" />
        </Style>

        <Style x:Key="OverlayCloseButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource CloseButtonStyle}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="5,0,0,0" />
        </Style>

        <Style x:Key="OverlaySectionStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppStrongBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="0,10,0,0" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="OverlayHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="OverlayPlaceholderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
            <Setter Property="FontStyle" Value="Italic" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Border x:Name="OverlayPanel"
            Background="{DynamicResource AppSurfaceBrush}"
            BorderBrush="{DynamicResource AccentBlueBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Opacity="0.94"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource AppSurfaceRaisedBrush}"
                    BorderBrush="{DynamicResource AppMutedBorderBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="10,10,0,0"
                    Padding="10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0"
                          Background="Transparent"
                          MouseLeftButtonDown="DragHandle_MouseLeftButtonDown">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <controls:PhaseStatusIndicator x:Name="OverlayPhaseIndicator"
                                                       Grid.Column="0"
                                                       VerticalAlignment="Center" />

                        <StackPanel Grid.Column="2"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Pick/Ban Overlay"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock x:Name="StatusText"
                                       Text="Stopped"
                                       Margin="0,1,0,0"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal">
                        <Button x:Name="TopmostButton"
                                ToolTip="Unpin overlay from top"
                                AutomationProperties.Name="Unpin overlay from top"
                                Click="TopmostButton_Click"
                                Style="{StaticResource OverlayTitleButtonStyle}">
                            <Path x:Name="TopmostIcon"
                                  Width="13"
                                  Height="13"
                                  Data="M12,3 L17,8 L14,8 L14,14 L10,14 L10,8 L7,8 Z M8,19 H16"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Stretch="Uniform" />
                        </Button>
                        <Button ToolTip="Close overlay"
                                AutomationProperties.Name="Close pick ban overlay"
                                Click="CloseButton_Click"
                                Style="{StaticResource OverlayCloseButtonStyle}">
                            <Path Width="12"
                                  Height="12"
                                  Data="M6,6 L18,18 M18,6 L6,18"
                                  Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          Style="{StaticResource StableVerticalScrollViewerStyle}">
                <StackPanel Margin="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="74" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="74" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="PhaseText"
                                       Text="Idle"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock x:Name="PositionText"
                                       Text="No role"
                                       Margin="0,2,0,0"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <Border Grid.Column="2"
                                Background="{DynamicResource AppSurfaceInsetBrush}"
                                BorderBrush="{DynamicResource AppStrongBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="6"
                                MinHeight="56">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock x:Name="TimerText"
                                           Text="--"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource AccentBlueSoftBrush}"
                                           HorizontalAlignment="Center"
                                           LineHeight="25"
                                           LineStackingStrategy="BlockLineHeight" />
                                <TextBlock Text="sec"
                                           Margin="0,2,0,0"
                                           FontSize="9"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="4"
                                Background="{DynamicResource AppSurfaceInsetBrush}"
                                BorderBrush="{DynamicResource AppStrongBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="6"
                                MinHeight="56">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock x:Name="LockTimerText"
                                           Text="--"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource DangerTextBrush}"
                                           HorizontalAlignment="Center"
                                           LineHeight="25"
                                           LineStackingStrategy="BlockLineHeight" />
                                <TextBlock x:Name="LockTimerLabel"
                                           Text="lock"
                                           Margin="0,2,0,0"
                                           FontSize="9"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Style="{StaticResource OverlaySectionStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Width="4"
                                        Height="24"
                                        Background="{DynamicResource AccentBlueBrush}"
                                        CornerRadius="2" />
                                <TextBlock Grid.Column="2"
                                           Text="Pick plan"
                                           Style="{StaticResource CardTitleStyle}"
                                           FontSize="14"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="PickLockText"
                                           Grid.Column="3"
                                           Text="Lock timing unavailable."
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           TextAlignment="Right"
                                           TextWrapping="Wrap"
                                           MaxWidth="116"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Border Grid.Row="2"
                                    Style="{StaticResource PlannerChampionChipListFrameStyle}"
                                    Margin="0,6,0,6">
                                <Grid>
                                    <TextBlock x:Name="PickPlaceholderText"
                                               Text="Waiting for champion select."
                                               Style="{StaticResource OverlayPlaceholderStyle}" />
                                    <ItemsControl x:Name="PickPlanList"
                                                  VerticalAlignment="Top">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource PlannerPortraitChampionChipStyle}"
                                                        ToolTip="{Binding ToolTipText}">
                                                    <Grid Width="48"
                                                          Height="64"
                                                          ClipToBounds="True">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="0" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>

                                                        <Border Grid.Row="0"
                                                                ClipToBounds="True"
                                                                Style="{StaticResource PlannerChampionPortraitSlotStyle}">
                                                            <Grid>
                                                                <controls:ChampionMysteryGlyph Width="30"
                                                                                                Height="30"
                                                                                                HorizontalAlignment="Center"
                                                                                                VerticalAlignment="Center"
                                                                                                Foreground="{DynamicResource TextSubtleBrush}" />
                                                                <Image Source="{Binding PortraitImageSource}"
                                                                       Stretch="UniformToFill"
                                                                       SnapsToDevicePixels="True" />
                                                            </Grid>
                                                        </Border>

                                                        <Viewbox Grid.Row="2"
                                                                 Style="{StaticResource ChampionTileLabelViewboxStyle}">
                                                            <TextBlock Text="{Binding ChipDisplayText}"
                                                                       FontSize="{Binding ChipDisplayFontSize}"
                                                                       Style="{StaticResource PlannerChampionChipTextStyle}" />
                                                        </Viewbox>

                                                        <Border Grid.Row="0"
                                                                Panel.ZIndex="10"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Top"
                                                                Margin="0,2,2,0"
                                                                Style="{StaticResource PlannerUnavailableHelpBadgeStyle}"
                                                                ToolTip="{Binding StatusText}">
                                                            <TextBlock Text="?"
                                                                       Style="{StaticResource PlannerUnavailableHelpTextStyle}" />
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource OverlaySectionStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Width="4"
                                        Height="24"
                                        Background="{DynamicResource DangerAccentBrush}"
                                        CornerRadius="2" />
                                <TextBlock Grid.Column="2"
                                           Text="Ban plan"
                                           Style="{StaticResource CardTitleStyle}"
                                           FontSize="14"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="BanLockText"
                                           Grid.Column="3"
                                           Text="Lock timing unavailable."
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           TextAlignment="Right"
                                           TextWrapping="Wrap"
                                           MaxWidth="116"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Border Grid.Row="2"
                                    Style="{StaticResource PlannerChampionChipListFrameStyle}"
                                    Margin="0,6,0,6">
                                <Grid>
                                    <TextBlock x:Name="BanPlaceholderText"
                                               Text="Waiting for champion select."
                                               Style="{StaticResource OverlayPlaceholderStyle}" />
                                    <ItemsControl x:Name="BanPlanList"
                                                  VerticalAlignment="Top">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource PlannerPortraitChampionChipStyle}"
                                                        ToolTip="{Binding ToolTipText}">
                                                    <Grid Width="48"
                                                          Height="64"
                                                          ClipToBounds="True">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="0" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>

                                                        <Border Grid.Row="0"
                                                                ClipToBounds="True"
                                                                Style="{StaticResource PlannerChampionPortraitSlotStyle}">
                                                            <Grid>
                                                                <controls:ChampionMysteryGlyph Width="30"
                                                                                                Height="30"
                                                                                                HorizontalAlignment="Center"
                                                                                                VerticalAlignment="Center"
                                                                                                Foreground="{DynamicResource TextSubtleBrush}" />
                                                                <Image Source="{Binding PortraitImageSource}"
                                                                       Stretch="UniformToFill"
                                                                       SnapsToDevicePixels="True" />
                                                            </Grid>
                                                        </Border>

                                                        <Viewbox Grid.Row="2"
                                                                 Style="{StaticResource ChampionTileLabelViewboxStyle}">
                                                            <TextBlock Text="{Binding ChipDisplayText}"
                                                                       FontSize="{Binding ChipDisplayFontSize}"
                                                                       Style="{StaticResource PlannerChampionChipTextStyle}" />
                                                        </Viewbox>

                                                        <Border Grid.Row="0"
                                                                Panel.ZIndex="10"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Top"
                                                                Margin="0,2,2,0"
                                                                Style="{StaticResource PlannerUnavailableHelpBadgeStyle}"
                                                                ToolTip="{Binding StatusText}">
                                                            <TextBlock Text="?"
                                                                       Style="{StaticResource PlannerUnavailableHelpTextStyle}" />
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
