<Window x:Class="JoinGameAfk.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="JoinGameAfk"
        Width="900"
        Height="900"
        MinWidth="850"
        MinHeight="800"
        Background="{DynamicResource AppBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        WindowStyle="None"
        PreviewKeyDown="Window_PreviewKeyDown"
        KeyboardNavigation.TabNavigation="Cycle">
    <Window.Resources>
        <Storyboard x:Key="TitleChampionSelectStoryboard"
                    RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TitleChampionOuterRotate"
                                           Storyboard.TargetProperty="Angle">
                <LinearDoubleKeyFrame KeyTime="0:0:0"
                                      Value="0" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.75"
                                      Value="92" />
                <LinearDoubleKeyFrame KeyTime="0:0:1.5"
                                      Value="210" />
                <LinearDoubleKeyFrame KeyTime="0:0:2.25"
                                      Value="360" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TitleChampionGlyphScale"
                                           Storyboard.TargetProperty="ScaleX">
                <LinearDoubleKeyFrame KeyTime="0:0:0"
                                      Value="1" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.75"
                                      Value="0.66" />
                <LinearDoubleKeyFrame KeyTime="0:0:1.5"
                                      Value="1.12" />
                <LinearDoubleKeyFrame KeyTime="0:0:2.25"
                                      Value="1" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TitleChampionGlyphScale"
                                           Storyboard.TargetProperty="ScaleY">
                <LinearDoubleKeyFrame KeyTime="0:0:0"
                                      Value="1" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.75"
                                      Value="1.14" />
                <LinearDoubleKeyFrame KeyTime="0:0:1.5"
                                      Value="0.72" />
                <LinearDoubleKeyFrame KeyTime="0:0:2.25"
                                      Value="1" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TitleChampionGlyphSkew"
                                           Storyboard.TargetProperty="AngleX">
                <LinearDoubleKeyFrame KeyTime="0:0:0"
                                      Value="0" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.75"
                                      Value="-16" />
                <LinearDoubleKeyFrame KeyTime="0:0:1.5"
                                      Value="14" />
                <LinearDoubleKeyFrame KeyTime="0:0:2.25"
                                      Value="0" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TitleChampionGlyphSkew"
                                           Storyboard.TargetProperty="AngleY">
                <LinearDoubleKeyFrame KeyTime="0:0:0"
                                      Value="0" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.75"
                                      Value="10" />
                <LinearDoubleKeyFrame KeyTime="0:0:1.5"
                                      Value="-12" />
                <LinearDoubleKeyFrame KeyTime="0:0:2.25"
                                      Value="0" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TitleChampionShadowRotate"
                                           Storyboard.TargetProperty="Angle">
                <LinearDoubleKeyFrame KeyTime="0:0:0"
                                      Value="45" />
                <LinearDoubleKeyFrame KeyTime="0:0:2.25"
                                      Value="405" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TitleChampionPulseScale"
                                           Storyboard.TargetProperty="ScaleX">
                <LinearDoubleKeyFrame KeyTime="0:0:0"
                                      Value="0.72" />
                <LinearDoubleKeyFrame KeyTime="0:0:1.1"
                                      Value="1.35" />
                <LinearDoubleKeyFrame KeyTime="0:0:2.25"
                                      Value="0.72" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TitleChampionPulseScale"
                                           Storyboard.TargetProperty="ScaleY">
                <LinearDoubleKeyFrame KeyTime="0:0:0"
                                      Value="0.72" />
                <LinearDoubleKeyFrame KeyTime="0:0:1.1"
                                      Value="1.35" />
                <LinearDoubleKeyFrame KeyTime="0:0:2.25"
                                      Value="0.72" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TitleChampionPulse"
                                           Storyboard.TargetProperty="Opacity">
                <LinearDoubleKeyFrame KeyTime="0:0:0"
                                      Value="0.1" />
                <LinearDoubleKeyFrame KeyTime="0:0:1.1"
                                      Value="0.72" />
                <LinearDoubleKeyFrame KeyTime="0:0:2.25"
                                      Value="0.1" />
            </DoubleAnimationUsingKeyFrames>
            <ColorAnimationUsingKeyFrames Storyboard.TargetName="TitleChampionCoreBrush"
                                          Storyboard.TargetProperty="Color">
                <LinearColorKeyFrame KeyTime="0:0:0"
                                     Value="#22D3EE" />
                <LinearColorKeyFrame KeyTime="0:0:0.75"
                                     Value="#A78BFA" />
                <LinearColorKeyFrame KeyTime="0:0:1.5"
                                     Value="#F59E0B" />
                <LinearColorKeyFrame KeyTime="0:0:2.25"
                                     Value="#22D3EE" />
            </ColorAnimationUsingKeyFrames>
            <ColorAnimationUsingKeyFrames Storyboard.TargetName="TitleChampionShadowBrush"
                                          Storyboard.TargetProperty="Color">
                <LinearColorKeyFrame KeyTime="0:0:0"
                                     Value="#7C3AED" />
                <LinearColorKeyFrame KeyTime="0:0:0.75"
                                     Value="#EF4444" />
                <LinearColorKeyFrame KeyTime="0:0:1.5"
                                     Value="#38BDF8" />
                <LinearColorKeyFrame KeyTime="0:0:2.25"
                                     Value="#7C3AED" />
            </ColorAnimationUsingKeyFrames>
        </Storyboard>
    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6,4,6,6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="WindowBorder"
            Style="{StaticResource AppWindowBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource AppSurfaceAltBrush}"
                    BorderBrush="{DynamicResource AppSubtleBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="14,10,14,8"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Width="28"
                                Height="28"
                                Background="{DynamicResource AppSurfaceInsetBrush}"
                                BorderBrush="{DynamicResource AppMutedBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="0,0,10,0">
                            <Grid Width="18"
                                  Height="18"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  ClipToBounds="False">
                                <Ellipse x:Name="TitlePhaseCircle"
                                         Width="10"
                                         Height="10"
                                         Fill="{DynamicResource PhaseDefaultBrush}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center" />

                                <Grid x:Name="TitleChampionGlyph"
                                      Width="18"
                                      Height="18"
                                      RenderTransformOrigin="0.5,0.5"
                                      Visibility="Collapsed">
                                    <Grid.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform x:Name="TitleChampionGlyphScale" />
                                            <SkewTransform x:Name="TitleChampionGlyphSkew" />
                                            <RotateTransform x:Name="TitleChampionOuterRotate" />
                                        </TransformGroup>
                                    </Grid.RenderTransform>

                                    <Ellipse x:Name="TitleChampionPulse"
                                             Width="13"
                                             Height="13"
                                             Stroke="#80FFFFFF"
                                             StrokeThickness="1"
                                             Opacity="0.1"
                                             RenderTransformOrigin="0.5,0.5"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center">
                                        <Ellipse.RenderTransform>
                                            <ScaleTransform x:Name="TitleChampionPulseScale"
                                                            ScaleX="0.72"
                                                            ScaleY="0.72" />
                                        </Ellipse.RenderTransform>
                                    </Ellipse>

                                    <Path Width="16"
                                          Height="16"
                                          Data="M9,1 L16,5 L14,14 L6,17 L2,8 Z"
                                          Opacity="0.55"
                                          Stretch="Fill"
                                          RenderTransformOrigin="0.5,0.5"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center">
                                        <Path.Fill>
                                            <SolidColorBrush x:Name="TitleChampionShadowBrush"
                                                             Color="#7C3AED" />
                                        </Path.Fill>
                                        <Path.RenderTransform>
                                            <RotateTransform x:Name="TitleChampionShadowRotate"
                                                             Angle="45" />
                                        </Path.RenderTransform>
                                    </Path>

                                    <Path Width="13"
                                          Height="13"
                                          Data="M9,2 L15,9 L9,16 L3,9 Z"
                                          Stretch="Fill"
                                          Stroke="#99FFFFFF"
                                          StrokeThickness="0.8"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center">
                                        <Path.Fill>
                                            <SolidColorBrush x:Name="TitleChampionCoreBrush"
                                                             Color="#22D3EE" />
                                        </Path.Fill>
                                    </Path>
                                </Grid>
                            </Grid>
                        </Border>
                        <TextBlock Text="JoinGameAfk"
                                   VerticalAlignment="Center"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                    </StackPanel>

                    <Border Grid.Column="2"
                            Height="30"
                            VerticalAlignment="Center"
                            Background="Transparent" />

                    <StackPanel Grid.Column="4"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Style="{StaticResource TitleBarButtonStyle}"
                                ToolTip="Minimize"
                                AutomationProperties.Name="Minimize"
                                Click="MinimizeButton_Click">
                            <Path Data="M5,12 H19"
                                  Width="14"
                                  Height="14"
                                  Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" />
                        </Button>
                        <Button x:Name="MaximizeRestoreButton"
                                Style="{StaticResource TitleBarButtonStyle}"
                                ToolTip="Maximize"
                                AutomationProperties.Name="Maximize"
                                Click="MaximizeRestoreButton_Click">
                            <Path x:Name="MaximizeRestoreIcon"
                                  Data="M6,6 H18 V18 H6 Z"
                                  Width="13"
                                  Height="13"
                                  Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="2"
                                  StrokeLineJoin="Round" />
                        </Button>
                        <Button Style="{StaticResource CloseButtonStyle}"
                                ToolTip="Close"
                                AutomationProperties.Name="Close"
                                Click="CloseButton_Click">
                            <Path Data="M6,6 L18,18 M18,6 L6,18"
                                  Width="13"
                                  Height="13"
                                  Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1"
                  Margin="18,8,18,12"
                  KeyboardNavigation.DirectionalNavigation="Contained">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="184" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="184" />
                </Grid.ColumnDefinitions>

                <Button x:Name="GlobalWatcherButton"
                        Grid.Column="0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="{DynamicResource WatcherStartBrush}"
                        Content="Start watcher"
                        AutomationProperties.Name="Start watcher"
                        Click="GlobalWatcherButton_Click"
                        Style="{StaticResource WatcherButtonStyle}" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Button x:Name="TabDashboard"
                            Content="Dashboard"
                            AutomationProperties.Name="Dashboard tab"
                            Click="TabDashboard_Click"
                            Style="{StaticResource TabButtonStyle}" />
                    <Button x:Name="TabChampionPriorities"
                            Content="Champion Priorities"
                            AutomationProperties.Name="Champion priorities tab"
                            Click="TabChampionPriorities_Click"
                            Style="{StaticResource TabButtonStyle}" />
                    <Button x:Name="TabSettings"
                            Content="Settings"
                            AutomationProperties.Name="Settings tab"
                            Click="TabSettings_Click"
                            Style="{StaticResource TabButtonStyle}" />
                </StackPanel>

                <Border Grid.Column="2"
                        Style="{StaticResource MainStatusPillStyle}">
                    <TextBlock x:Name="GlobalPhaseText"
                               Text="Stopped"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Center" />
                </Border>
            </Grid>

            <Grid Grid.Row="2"
                  Margin="16,0,16,16">
                <Frame x:Name="DashboardFrame"
                       NavigationUIVisibility="Hidden"
                       Background="Transparent"
                       BorderThickness="0" />
                <Frame x:Name="ChampionPrioritiesFrame"
                       NavigationUIVisibility="Hidden"
                       Background="Transparent"
                       BorderThickness="0"
                       Visibility="Collapsed" />
                <Frame x:Name="SettingsFrame"
                       NavigationUIVisibility="Hidden"
                       Background="Transparent"
                       BorderThickness="0"
                       Visibility="Collapsed" />
            </Grid>
        </Grid>
    </Border>
</Window>
