<Window x:Class="JoinGameAfk.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="JoinGameAfk"
        Width="900"
        Height="900"
        MinWidth="560"
        MinHeight="440"
        Background="{DynamicResource AppBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        WindowStyle="None"
        PreviewKeyDown="Window_PreviewKeyDown"
        KeyboardNavigation.TabNavigation="Cycle">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6,4,6,6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="WindowBorder"
            Style="{StaticResource AppWindowBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="Transparent"
                    Padding="14,10,14,8"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Width="28"
                                Height="28"
                                Background="{DynamicResource AppSurfaceInsetBrush}"
                                BorderBrush="{DynamicResource AppMutedBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="0,0,10,0">
                            <Grid>
                                <Border x:Name="TitlePhaseIndicator"
                                        Width="10"
                                        Height="10"
                                        Background="{DynamicResource PhaseDefaultBrush}"
                                        CornerRadius="5"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <TextBlock Text="JoinGameAfk"
                                   VerticalAlignment="Center"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                    </StackPanel>

                    <Border Grid.Column="2"
                            Height="30"
                            VerticalAlignment="Center"
                            Background="Transparent" />

                    <StackPanel Grid.Column="4"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Style="{StaticResource TitleBarButtonStyle}"
                                ToolTip="Minimize"
                                AutomationProperties.Name="Minimize"
                                Click="MinimizeButton_Click">
                            <Path Data="M5,12 H19"
                                  Width="14"
                                  Height="14"
                                  Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" />
                        </Button>
                        <Button x:Name="MaximizeRestoreButton"
                                Style="{StaticResource TitleBarButtonStyle}"
                                ToolTip="Maximize"
                                AutomationProperties.Name="Maximize"
                                Click="MaximizeRestoreButton_Click">
                            <Path x:Name="MaximizeRestoreIcon"
                                  Data="M6,6 H18 V18 H6 Z"
                                  Width="13"
                                  Height="13"
                                  Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="2"
                                  StrokeLineJoin="Round" />
                        </Button>
                        <Button Style="{StaticResource CloseButtonStyle}"
                                ToolTip="Close"
                                AutomationProperties.Name="Close"
                                Click="CloseButton_Click">
                            <Path Data="M6,6 L18,18 M18,6 L6,18"
                                  Width="13"
                                  Height="13"
                                  Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1"
                  Margin="18,0,18,12"
                  KeyboardNavigation.DirectionalNavigation="Contained">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button x:Name="GlobalWatcherButton"
                        Grid.Column="0"
                        MinHeight="36"
                        Padding="12,7"
                        Margin="0,0,10,0"
                        FontSize="13"
                        FontWeight="SemiBold"
                        VerticalAlignment="Top"
                        Background="{DynamicResource WatcherStartBrush}"
                        Content="Start watcher"
                        AutomationProperties.Name="Start watcher"
                        Click="GlobalWatcherButton_Click"
                        Style="{StaticResource AccentButtonStyle}" />

                <WrapPanel Grid.Column="2"
                           Orientation="Horizontal"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Top">
                    <Button x:Name="TabDashboard"
                            Content="Dashboard"
                            AutomationProperties.Name="Dashboard tab"
                            Click="TabDashboard_Click"
                            Style="{StaticResource TabButtonStyle}" />
                    <Button x:Name="TabChampSelect"
                            Content="Champion Select"
                            AutomationProperties.Name="Champion Select tab"
                            Click="TabChampSelect_Click"
                            Style="{StaticResource TabButtonStyle}" />
                    <Button x:Name="TabSettings"
                            Content="Settings"
                            AutomationProperties.Name="Settings tab"
                            Click="TabSettings_Click"
                            Style="{StaticResource TabButtonStyle}" />
                </WrapPanel>

                <Border Grid.Column="4"
                        MinWidth="124"
                        MinHeight="36"
                        Padding="12,0"
                        Background="{DynamicResource AppSurfaceInsetBrush}"
                        BorderBrush="{DynamicResource AppMutedBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        VerticalAlignment="Top">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="GlobalPhaseIndicator"
                                Grid.Column="0"
                                Width="9"
                                Height="9"
                                Background="{DynamicResource PhaseDefaultBrush}"
                                CornerRadius="5"
                                VerticalAlignment="Center" />

                        <TextBlock x:Name="GlobalPhaseText"
                                   Grid.Column="2"
                                   Text="Stopped"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="2"
                  Margin="16,0,16,16">
                <Frame x:Name="DashboardFrame"
                       NavigationUIVisibility="Hidden"
                       Background="Transparent"
                       BorderThickness="0" />
                <Frame x:Name="ChampSelectFrame"
                       NavigationUIVisibility="Hidden"
                       Background="Transparent"
                       BorderThickness="0"
                       Visibility="Collapsed" />
                <Frame x:Name="SettingsFrame"
                       NavigationUIVisibility="Hidden"
                       Background="Transparent"
                       BorderThickness="0"
                       Visibility="Collapsed" />
            </Grid>
        </Grid>
    </Border>
</Window>
