<UserControl x:Class="JoinGameAfk.View.Controls.ChampionMysteryGlyph"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:JoinGameAfk.View.Controls"
             Foreground="{DynamicResource TextSubtleBrush}"
             IsHitTestVisible="False"
             SnapsToDevicePixels="True">
    <Viewbox Stretch="Uniform">
        <Canvas Width="24"
                Height="24">
            <Ellipse Canvas.Left="3"
                     Canvas.Top="3"
                     Width="18"
                     Height="18"
                     Fill="Transparent"
                     Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type local:ChampionMysteryGlyph}}}"
                     StrokeThickness="2"
                     SnapsToDevicePixels="True" />

            <Ellipse Canvas.Left="9.5"
                     Canvas.Top="6.5"
                     Width="5"
                     Height="5"
                     Fill="Transparent"
                     Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type local:ChampionMysteryGlyph}}}"
                     StrokeThickness="2"
                     SnapsToDevicePixels="True" />

            <Path Data="M7.5,18 C8.4,15 10.2,13.5 12,13.5 C13.8,13.5 15.6,15 16.5,18"
                  Fill="Transparent"
                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type local:ChampionMysteryGlyph}}}"
                  StrokeThickness="2"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  StrokeLineJoin="Round"
                  SnapsToDevicePixels="True" />
        </Canvas>
    </Viewbox>
</UserControl>
