<UserControl x:Class="JoinGameAfk.View.Controls.PhaseStatusIndicator"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="28"
             Height="28">
    <UserControl.Resources>
        <Storyboard x:Key="ChampionSelectStoryboard"
                    RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ChampionOuterRotate"
                                           Storyboard.TargetProperty="Angle">
                <LinearDoubleKeyFrame KeyTime="0:0:0"
                                      Value="0" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.75"
                                      Value="92" />
                <LinearDoubleKeyFrame KeyTime="0:0:1.5"
                                      Value="210" />
                <LinearDoubleKeyFrame KeyTime="0:0:2.25"
                                      Value="360" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ChampionGlyphScale"
                                           Storyboard.TargetProperty="ScaleX">
                <LinearDoubleKeyFrame KeyTime="0:0:0"
                                      Value="1" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.75"
                                      Value="0.66" />
                <LinearDoubleKeyFrame KeyTime="0:0:1.5"
                                      Value="1.12" />
                <LinearDoubleKeyFrame KeyTime="0:0:2.25"
                                      Value="1" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ChampionGlyphScale"
                                           Storyboard.TargetProperty="ScaleY">
                <LinearDoubleKeyFrame KeyTime="0:0:0"
                                      Value="1" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.75"
                                      Value="1.14" />
                <LinearDoubleKeyFrame KeyTime="0:0:1.5"
                                      Value="0.72" />
                <LinearDoubleKeyFrame KeyTime="0:0:2.25"
                                      Value="1" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ChampionGlyphSkew"
                                           Storyboard.TargetProperty="AngleX">
                <LinearDoubleKeyFrame KeyTime="0:0:0"
                                      Value="0" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.75"
                                      Value="-16" />
                <LinearDoubleKeyFrame KeyTime="0:0:1.5"
                                      Value="14" />
                <LinearDoubleKeyFrame KeyTime="0:0:2.25"
                                      Value="0" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ChampionGlyphSkew"
                                           Storyboard.TargetProperty="AngleY">
                <LinearDoubleKeyFrame KeyTime="0:0:0"
                                      Value="0" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.75"
                                      Value="10" />
                <LinearDoubleKeyFrame KeyTime="0:0:1.5"
                                      Value="-12" />
                <LinearDoubleKeyFrame KeyTime="0:0:2.25"
                                      Value="0" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ChampionShadowRotate"
                                           Storyboard.TargetProperty="Angle">
                <LinearDoubleKeyFrame KeyTime="0:0:0"
                                      Value="45" />
                <LinearDoubleKeyFrame KeyTime="0:0:2.25"
                                      Value="405" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ChampionPulseScale"
                                           Storyboard.TargetProperty="ScaleX">
                <LinearDoubleKeyFrame KeyTime="0:0:0"
                                      Value="0.72" />
                <LinearDoubleKeyFrame KeyTime="0:0:1.1"
                                      Value="1.35" />
                <LinearDoubleKeyFrame KeyTime="0:0:2.25"
                                      Value="0.72" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ChampionPulseScale"
                                           Storyboard.TargetProperty="ScaleY">
                <LinearDoubleKeyFrame KeyTime="0:0:0"
                                      Value="0.72" />
                <LinearDoubleKeyFrame KeyTime="0:0:1.1"
                                      Value="1.35" />
                <LinearDoubleKeyFrame KeyTime="0:0:2.25"
                                      Value="0.72" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ChampionPulse"
                                           Storyboard.TargetProperty="Opacity">
                <LinearDoubleKeyFrame KeyTime="0:0:0"
                                      Value="0.1" />
                <LinearDoubleKeyFrame KeyTime="0:0:1.1"
                                      Value="0.72" />
                <LinearDoubleKeyFrame KeyTime="0:0:2.25"
                                      Value="0.1" />
            </DoubleAnimationUsingKeyFrames>
            <ColorAnimationUsingKeyFrames Storyboard.TargetName="ChampionCoreBrush"
                                          Storyboard.TargetProperty="Color">
                <LinearColorKeyFrame KeyTime="0:0:0"
                                     Value="#22D3EE" />
                <LinearColorKeyFrame KeyTime="0:0:0.75"
                                     Value="#A78BFA" />
                <LinearColorKeyFrame KeyTime="0:0:1.5"
                                     Value="#F59E0B" />
                <LinearColorKeyFrame KeyTime="0:0:2.25"
                                     Value="#22D3EE" />
            </ColorAnimationUsingKeyFrames>
            <ColorAnimationUsingKeyFrames Storyboard.TargetName="ChampionShadowBrush"
                                          Storyboard.TargetProperty="Color">
                <LinearColorKeyFrame KeyTime="0:0:0"
                                     Value="#7C3AED" />
                <LinearColorKeyFrame KeyTime="0:0:0.75"
                                     Value="#EF4444" />
                <LinearColorKeyFrame KeyTime="0:0:1.5"
                                     Value="#38BDF8" />
                <LinearColorKeyFrame KeyTime="0:0:2.25"
                                     Value="#7C3AED" />
            </ColorAnimationUsingKeyFrames>
        </Storyboard>
    </UserControl.Resources>

    <Border Background="{DynamicResource AppSurfaceInsetBrush}"
            BorderBrush="{DynamicResource AppMutedBorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid Width="18"
              Height="18"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              ClipToBounds="False">
            <Ellipse x:Name="PhaseCircle"
                     Width="10"
                     Height="10"
                     Fill="{DynamicResource PhaseDefaultBrush}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />

            <Grid x:Name="ChampionGlyph"
                  Width="18"
                  Height="18"
                  RenderTransformOrigin="0.5,0.5"
                  Visibility="Collapsed">
                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="ChampionGlyphScale" />
                        <SkewTransform x:Name="ChampionGlyphSkew" />
                        <RotateTransform x:Name="ChampionOuterRotate" />
                    </TransformGroup>
                </Grid.RenderTransform>

                <Ellipse x:Name="ChampionPulse"
                         Width="13"
                         Height="13"
                         Stroke="#80FFFFFF"
                         StrokeThickness="1"
                         Opacity="0.1"
                         RenderTransformOrigin="0.5,0.5"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center">
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="ChampionPulseScale"
                                        ScaleX="0.72"
                                        ScaleY="0.72" />
                    </Ellipse.RenderTransform>
                </Ellipse>

                <Path Width="16"
                      Height="16"
                      Data="M9,1 L16,5 L14,14 L6,17 L2,8 Z"
                      Opacity="0.55"
                      Stretch="Fill"
                      RenderTransformOrigin="0.5,0.5"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                    <Path.Fill>
                        <SolidColorBrush x:Name="ChampionShadowBrush"
                                         Color="#7C3AED" />
                    </Path.Fill>
                    <Path.RenderTransform>
                        <RotateTransform x:Name="ChampionShadowRotate"
                                         Angle="45" />
                    </Path.RenderTransform>
                </Path>

                <Path Width="13"
                      Height="13"
                      Data="M9,2 L15,9 L9,16 L3,9 Z"
                      Stretch="Fill"
                      Stroke="#99FFFFFF"
                      StrokeThickness="0.8"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                    <Path.Fill>
                        <SolidColorBrush x:Name="ChampionCoreBrush"
                                         Color="#22D3EE" />
                    </Path.Fill>
                </Path>
            </Grid>
        </Grid>
    </Border>
</UserControl>
