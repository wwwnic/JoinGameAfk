<Page x:Class="JoinGameAfk.View.ChampSelectSettingsPage"
      x:Name="RootPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      AllowDrop="True"
      SizeChanged="Page_SizeChanged"
      PreviewTextInput="Page_PreviewTextInput"
      PreviewKeyDown="Page_PreviewKeyDown"
      PreviewMouseLeftButtonUp="Page_PreviewMouseLeftButtonUp"
      DragOver="Page_DragOver"
      DragLeave="Page_DragLeave">
    <Page.Resources>
        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#12121A" />
            <Setter Property="BorderBrush" Value="#1E1E2A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#E2E8F0" />
        </Style>

        <Style x:Key="SectionDescriptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#94A3B8" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Page.Resources>

    <ScrollViewer x:Name="PageScrollViewer"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid x:Name="ContentGrid" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Champion Select"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="#E2E8F0"
                   Margin="0,0,0,6" />

        <TextBlock Grid.Row="1"
                   Text="Configure which champions to pick and ban for each assigned position. Select a pick or ban list, then search champions below and click to add them. Drag champions with the mouse to reorder priority. Champion changes are saved automatically."
                   FontSize="12"
                   Foreground="#94A3B8"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16" />

        <Border Grid.Row="2"
                Style="{StaticResource SectionCardStyle}"
                Margin="0,0,0,10"
                Padding="16,12">
            <TextBlock x:Name="ActiveTargetLabel"
                       Text="Select a pick or ban list, then search champions and click to add them. Drag champions to reorder them."
                       FontSize="12"
                       Foreground="#64B5F6"
                       FontStyle="Italic"
                       TextWrapping="Wrap" />
        </Border>

        <Border Grid.Row="3"
                Grid.RowSpan="2"
                Style="{StaticResource SectionCardStyle}"
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Champion Preferences"
                           Style="{StaticResource SectionTitleStyle}"
                           Margin="0,0,0,4" />

                <TextBlock Text="Choose your pick and ban priorities for each position."
                           Style="{StaticResource SectionDescriptionStyle}"
                           Margin="0,0,0,12" />

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Position"
                               FontWeight="SemiBold"
                               Foreground="#CBD5E1"
                               Margin="0,0,0,6" />
                    <TextBlock Grid.Column="1"
                               Text="Pick Champions"
                               FontWeight="SemiBold"
                               Foreground="#CBD5E1"
                               Margin="6,0,0,6" />
                    <TextBlock Grid.Column="2"
                               Text="Ban Champions"
                               FontWeight="SemiBold"
                               Foreground="#CBD5E1"
                               Margin="6,0,0,6" />
                </Grid>

                <ItemsControl x:Name="PositionList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding PositionName}"
                                           VerticalAlignment="Top"
                                           Foreground="#E2E8F0"
                                           FontSize="14"
                                           Margin="0,10,0,0" />

                                <Border Grid.Column="1"
                                        Tag="Pick"
                                        Background="{Binding PickBackgroundBrush}"
                                        BorderBrush="{Binding PickBorderBrush}"
                                        BorderThickness="2"
                                        CornerRadius="8"
                                        AllowDrop="True"
                                        Padding="8"
                                        Margin="6,0,0,0"
                                        MinHeight="56"
                                        MouseLeftButtonDown="ChampionTarget_MouseLeftButtonDown"
                                        DragOver="ChampionList_DragOver"
                                        Drop="ChampionList_Drop">
                                    <StackPanel>
                                        <TextBlock Text="Use search below to add champions"
                                                   FontSize="11"
                                                   Foreground="#64748B"
                                                   FontStyle="Italic"
                                                   Margin="0,0,0,6"
                                                   Visibility="{Binding PickPlaceholderVisibility}" />
                                        <ItemsControl ItemsSource="{Binding PickChampions}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,6,6"
                                                          Background="Transparent"
                                                          AllowDrop="True"
                                                          DragOver="ChampionItem_DragOver"
                                                          Drop="ChampionItem_Drop">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <Border Grid.Column="0"
                                                                Width="3"
                                                                Margin="0,4,4,4"
                                                                Background="#60A5FA"
                                                                CornerRadius="2"
                                                                Visibility="{Binding InsertBeforeIndicatorVisibility}" />

                                                        <Border Grid.Column="1"
                                                                Background="#0F172A"
                                                                BorderBrush="#334155"
                                                                BorderThickness="1"
                                                                CornerRadius="10"
                                                                Padding="8,4"
                                                                Cursor="SizeAll"
                                                                PreviewMouseLeftButtonDown="ChampionItem_PreviewMouseLeftButtonDown"
                                                                MouseMove="ChampionItem_MouseMove">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding DisplayText}"
                                                                           FontSize="12"
                                                                           Foreground="#CBD5E1"
                                                                           VerticalAlignment="Center" />
                                                                <Button Content="×"
                                                                        Click="RemoveChampionButton_Click"
                                                                        Margin="8,0,0,0"
                                                                        Padding="4,0"
                                                                        MinWidth="20"
                                                                        Background="#1E293B"
                                                                        Foreground="#E2E8F0"
                                                                        BorderBrush="#475569"
                                                                        Cursor="Hand" />
                                                            </StackPanel>
                                                        </Border>

                                                        <Border Grid.Column="2"
                                                                Width="3"
                                                                Margin="4,4,0,4"
                                                                Background="#60A5FA"
                                                                CornerRadius="2"
                                                                Visibility="{Binding InsertAfterIndicatorVisibility}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <Border Width="3"
                                                Height="28"
                                                Margin="4,2,0,0"
                                                Background="#60A5FA"
                                                CornerRadius="2"
                                                HorizontalAlignment="Left"
                                                Visibility="{Binding PickDropIndicatorVisibility}" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2"
                                        Tag="Ban"
                                        Background="{Binding BanBackgroundBrush}"
                                        BorderBrush="{Binding BanBorderBrush}"
                                        BorderThickness="2"
                                        CornerRadius="8"
                                        AllowDrop="True"
                                        Padding="8"
                                        Margin="6,0,0,0"
                                        MinHeight="56"
                                        MouseLeftButtonDown="ChampionTarget_MouseLeftButtonDown"
                                        DragOver="ChampionList_DragOver"
                                        Drop="ChampionList_Drop">
                                    <StackPanel>
                                        <TextBlock Text="Use search below to add champions"
                                                   FontSize="11"
                                                   Foreground="#64748B"
                                                   FontStyle="Italic"
                                                   Margin="0,0,0,6"
                                                   Visibility="{Binding BanPlaceholderVisibility}" />
                                        <ItemsControl ItemsSource="{Binding BanChampions}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,6,6"
                                                          Background="Transparent"
                                                          AllowDrop="True"
                                                          DragOver="ChampionItem_DragOver"
                                                          Drop="ChampionItem_Drop">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <Border Grid.Column="0"
                                                                Width="3"
                                                                Margin="0,4,4,4"
                                                                Background="#60A5FA"
                                                                CornerRadius="2"
                                                                Visibility="{Binding InsertBeforeIndicatorVisibility}" />

                                                        <Border Grid.Column="1"
                                                                Background="#0F172A"
                                                                BorderBrush="#334155"
                                                                BorderThickness="1"
                                                                CornerRadius="10"
                                                                Padding="8,4"
                                                                Cursor="SizeAll"
                                                                PreviewMouseLeftButtonDown="ChampionItem_PreviewMouseLeftButtonDown"
                                                                MouseMove="ChampionItem_MouseMove">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding DisplayText}"
                                                                           FontSize="12"
                                                                           Foreground="#CBD5E1"
                                                                           VerticalAlignment="Center" />
                                                                <Button Content="×"
                                                                        Click="RemoveChampionButton_Click"
                                                                        Margin="8,0,0,0"
                                                                        Padding="4,0"
                                                                        MinWidth="20"
                                                                        Background="#1E293B"
                                                                        Foreground="#E2E8F0"
                                                                        BorderBrush="#475569"
                                                                        Cursor="Hand" />
                                                            </StackPanel>
                                                        </Border>

                                                        <Border Grid.Column="2"
                                                                Width="3"
                                                                Margin="4,4,0,4"
                                                                Background="#60A5FA"
                                                                CornerRadius="2"
                                                                Visibility="{Binding InsertAfterIndicatorVisibility}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <Border Width="3"
                                                Height="28"
                                                Margin="4,2,0,0"
                                                Background="#60A5FA"
                                                CornerRadius="2"
                                                HorizontalAlignment="Left"
                                                Visibility="{Binding BanDropIndicatorVisibility}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Border Grid.Row="5"
                Grid.RowSpan="4"
                Style="{StaticResource SectionCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Champion Search"
                           Style="{StaticResource SectionTitleStyle}"
                           Margin="0,0,0,4" />

                <TextBlock Grid.Row="1"
                           Text="Search by champion name or ID, then click to add to the selected list."
                           Style="{StaticResource SectionDescriptionStyle}"
                           Margin="0,0,0,8" />

                <TextBox x:Name="ChampionSearchBox"
                         Grid.Row="2"
                         TextChanged="ChampionSearchBox_TextChanged"
                         PreviewKeyDown="ChampionSearchBox_PreviewKeyDown"
                         Padding="8,6"
                         FontSize="13"
                         Background="#1E293B"
                         CaretBrush="#E2E8F0"
                         Foreground="#E2E8F0"
                         BorderBrush="#334155"
                         Margin="0,0,0,8" />

                <Border x:Name="ChampionReferenceBorder"
                        Grid.Row="3"
                        Background="#0F172A"
                        BorderBrush="#334155"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8">
                    <ScrollViewer x:Name="ChampionReferenceScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="ChampionReferenceList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Click="ChampionReferenceButton_Click"
                                            Background="#1E293B"
                                            BorderBrush="#475569"
                                            Foreground="#E2E8F0"
                                            Cursor="Hand"
                                            Margin="3"
                                            Padding="8,4"
                                            ToolTip="Click to add to the selected list">
                                        <TextBlock FontSize="12">
                                            <Run Text="+ " Foreground="#60A5FA" />
                                            <Run Text="{Binding Name, Mode=OneWay}" />
                                        </TextBlock>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <Popup x:Name="DragPreviewPopup"
               Placement="RelativePoint"
               PlacementTarget="{Binding ElementName=RootPage}"
               AllowsTransparency="True"
               IsHitTestVisible="False"
               PopupAnimation="None"
               StaysOpen="True">
            <Border Background="#1E293B"
                    BorderBrush="#60A5FA"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="10,5"
                    Opacity="0.95">
                <TextBlock x:Name="DragPreviewText"
                           Foreground="#E2E8F0"
                           FontSize="12"
                           FontWeight="SemiBold" />
            </Border>
        </Popup>
        </Grid>
    </ScrollViewer>
</Page>
