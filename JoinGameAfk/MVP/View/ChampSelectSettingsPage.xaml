<Page x:Class="JoinGameAfk.View.ChampSelectSettingsPage"
      x:Name="RootPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      AllowDrop="True"
      SizeChanged="Page_SizeChanged"
      PreviewTextInput="Page_PreviewTextInput"
      PreviewKeyDown="Page_PreviewKeyDown"
      PreviewMouseMove="Page_PreviewMouseMove"
      PreviewMouseLeftButtonUp="Page_PreviewMouseLeftButtonUp"
      DragOver="Page_DragOver"
      DragLeave="Page_DragLeave">
    <Page.Resources>
        <Style x:Key="SearchDeleteDropCardStyle"
               TargetType="Border"
               BasedOn="{StaticResource SectionCardStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=RootPage, Path=IsSearchDeleteDropTarget}" Value="True">
                    <Setter Property="Background" Value="{StaticResource DangerSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource DangerAccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SearchDeleteOverlayStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=RootPage, Path=IsSearchDeleteDropTarget}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <ScrollViewer x:Name="PageScrollViewer"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid x:Name="ContentGrid" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

        <Border Grid.Row="3"
                Grid.RowSpan="2"
                Style="{StaticResource SectionCardStyle}"
                Margin="0,0,0,16">
            <StackPanel>

                    <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Position"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSoftBrush}"
                               Margin="0,0,0,6" />
                    <TextBlock Grid.Column="1"
                               Text="Pick Champions"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSoftBrush}"
                               Margin="6,0,0,6" />
                    <TextBlock Grid.Column="2"
                               Text="Ban Champions"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSoftBrush}"
                               Margin="6,0,0,6" />

                    <Button x:Name="DeleteSelectedButton"
                            Grid.Column="2"
                            Content="Delete selected"
                            Margin="12,0,0,6"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Click="DeleteSelectedButton_Click"
                            IsEnabled="{Binding ElementName=RootPage, Path=HasSelectedChampions}"
                            Style="{StaticResource DeleteSelectedButtonStyle}" />
                </Grid>

                <ItemsControl x:Name="PositionList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding PositionName}"
                                           VerticalAlignment="Top"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="14"
                                           Margin="0,10,0,0" />

                                <Border Grid.Column="1"
                                        Tag="Pick"
                                        Background="{Binding PickBackgroundBrush}"
                                        BorderBrush="{Binding PickBorderBrush}"
                                        BorderThickness="2"
                                        CornerRadius="8"
                                        AllowDrop="True"
                                        Padding="6"
                                        Margin="6,0,0,0"
                                        MinHeight="46"
                                        MouseLeftButtonDown="ChampionTarget_MouseLeftButtonDown"
                                        DragOver="ChampionList_DragOver"
                                        Drop="ChampionList_Drop">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Empty"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextSubtleBrush}"
                                                   FontStyle="Italic"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding PickPlaceholderVisibility}" />
                                        <ItemsControl ItemsSource="{Binding PickChampions}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,3,6,3"
                                                          VerticalAlignment="Center"
                                                          Background="Transparent"
                                                          AllowDrop="True"
                                                          DragOver="ChampionItem_DragOver"
                                                          Drop="ChampionItem_Drop">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <Border Grid.Column="0"
                                                                Width="3"
                                                                Margin="0,4,4,4"
                                                                Background="{StaticResource AccentBlueBrush}"
                                                                CornerRadius="2"
                                                                Visibility="{Binding InsertBeforeIndicatorVisibility}" />

                                                        <Border Grid.Column="1"
                                                                Tag="ChampionPill"
                                                                Style="{StaticResource ChampionPillBorderStyle}"
                                                                PreviewMouseLeftButtonDown="ChampionItem_PreviewMouseLeftButtonDown"
                                                                MouseMove="ChampionItem_MouseMove">
                                                            <TextBlock Text="{Binding DisplayText}"
                                                                       Style="{StaticResource ChampionChipTextStyle}" />
                                                        </Border>

                                                        <Border Grid.Column="2"
                                                                Width="3"
                                                                Margin="4,4,0,4"
                                                                Background="{StaticResource AccentBlueBrush}"
                                                                CornerRadius="2"
                                                                Visibility="{Binding InsertAfterIndicatorVisibility}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <Border Width="3"
                                                Height="28"
                                                Margin="4,2,0,0"
                                                Background="{StaticResource AccentBlueBrush}"
                                                CornerRadius="2"
                                                HorizontalAlignment="Left"
                                                Visibility="{Binding PickDropIndicatorVisibility}" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2"
                                        Tag="Ban"
                                        Background="{Binding BanBackgroundBrush}"
                                        BorderBrush="{Binding BanBorderBrush}"
                                        BorderThickness="2"
                                        CornerRadius="8"
                                        AllowDrop="True"
                                        Padding="6"
                                        Margin="6,0,0,0"
                                        MinHeight="46"
                                        MouseLeftButtonDown="ChampionTarget_MouseLeftButtonDown"
                                        DragOver="ChampionList_DragOver"
                                        Drop="ChampionList_Drop">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Empty"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextSubtleBrush}"
                                                   FontStyle="Italic"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding BanPlaceholderVisibility}" />
                                        <ItemsControl ItemsSource="{Binding BanChampions}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,3,6,3"
                                                          VerticalAlignment="Center"
                                                          Background="Transparent"
                                                          AllowDrop="True"
                                                          DragOver="ChampionItem_DragOver"
                                                          Drop="ChampionItem_Drop">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <Border Grid.Column="0"
                                                                Width="3"
                                                                Margin="0,4,4,4"
                                                                Background="{StaticResource AccentBlueBrush}"
                                                                CornerRadius="2"
                                                                Visibility="{Binding InsertBeforeIndicatorVisibility}" />

                                                        <Border Grid.Column="1"
                                                                Tag="ChampionPill"
                                                                Style="{StaticResource ChampionPillBorderStyle}"
                                                                PreviewMouseLeftButtonDown="ChampionItem_PreviewMouseLeftButtonDown"
                                                                MouseMove="ChampionItem_MouseMove">
                                                            <TextBlock Text="{Binding DisplayText}"
                                                                       Style="{StaticResource ChampionChipTextStyle}" />
                                                        </Border>

                                                        <Border Grid.Column="2"
                                                                Width="3"
                                                                Margin="4,4,0,4"
                                                                Background="{StaticResource AccentBlueBrush}"
                                                                CornerRadius="2"
                                                                Visibility="{Binding InsertAfterIndicatorVisibility}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <Border Width="3"
                                                Height="28"
                                                Margin="4,2,0,0"
                                                Background="{StaticResource AccentBlueBrush}"
                                                CornerRadius="2"
                                                HorizontalAlignment="Left"
                                                Visibility="{Binding BanDropIndicatorVisibility}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Border x:Name="ChampionSearchCard"
                Grid.Row="5"
                Grid.RowSpan="4"
                AllowDrop="True"
                PreviewDragOver="SearchArea_PreviewDragOver"
                PreviewDrop="SearchArea_PreviewDrop"
                Style="{StaticResource SearchDeleteDropCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Champion Search"
                           Style="{StaticResource SectionTitleStyle}"
                           Margin="0,0,0,4" />

                <TextBlock Grid.Row="1"
                           Text="Search by champion name or ID, then click to add to the selected list."
                           Style="{StaticResource SectionDescriptionStyle}"
                           Margin="0,0,0,8" />

                <TextBox x:Name="ChampionSearchBox"
                         Grid.Row="2"
                         TextChanged="ChampionSearchBox_TextChanged"
                         PreviewKeyDown="ChampionSearchBox_PreviewKeyDown"
                         Margin="0,0,0,8"
                         Style="{StaticResource SearchTextBoxStyle}" />

                <Border x:Name="ChampionReferenceBorder"
                        Grid.Row="3"
                        Background="{StaticResource AppSurfaceInsetBrush}"
                        BorderBrush="{StaticResource AppStrongBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8">
                    <ScrollViewer x:Name="ChampionReferenceScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="ChampionReferenceList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Click="ChampionReferenceButton_Click"
                                            PreviewMouseLeftButtonDown="ChampionReferenceButton_PreviewMouseLeftButtonDown"
                                            PreviewMouseMove="ChampionReferenceButton_PreviewMouseMove"
                                            Style="{StaticResource ChampionReferenceButtonStyle}">
                                        <TextBlock Style="{StaticResource ChampionChipTextStyle}">
                                            <Run Text="+ " Foreground="{StaticResource AccentBlueBrush}" />
                                            <Run Text="{Binding Name, Mode=OneWay}" />
                                        </TextBlock>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <Border Grid.RowSpan="4"
                        Style="{StaticResource SearchDeleteOverlayStyle}"
                        Background="{StaticResource DangerOverlayBrush}"
                        BorderBrush="{StaticResource DangerAccentBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        IsHitTestVisible="False">
                    <Viewbox Width="42"
                             Height="42"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center">
                        <Canvas Width="24" Height="24">
                            <Path Stroke="{StaticResource DangerTextPaleBrush}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Data="M3,6 L5,6 M5,6 L21,6 M19,6 L21,6 M8,6 L8,4 L16,4 L16,6 M6,6 L7,21 L17,21 L18,6 M10,11 L10,17 M14,11 L14,17" />
                        </Canvas>
                    </Viewbox>
                </Border>
            </Grid>
        </Border>

        <Popup x:Name="DragPreviewPopup"
               Placement="RelativePoint"
               PlacementTarget="{Binding ElementName=RootPage}"
               AllowsTransparency="True"
               IsHitTestVisible="False"
               PopupAnimation="None"
               StaysOpen="True">
            <Border Background="{StaticResource AppInputFocusBrush}"
                    BorderBrush="{StaticResource AccentBlueBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="10,5"
                    Opacity="0.95">
                <TextBlock x:Name="DragPreviewText"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           FontWeight="SemiBold" />
            </Border>
        </Popup>
        </Grid>
    </ScrollViewer>
</Page>
