<Page x:Class="JoinGameAfk.View.ChampSelectSettingsPage"
      x:Name="RootPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      AllowDrop="True"
      SizeChanged="Page_SizeChanged"
      PreviewTextInput="Page_PreviewTextInput"
      PreviewKeyDown="Page_PreviewKeyDown"
      PreviewMouseMove="Page_PreviewMouseMove"
      PreviewMouseLeftButtonUp="Page_PreviewMouseLeftButtonUp"
      DragOver="Page_DragOver"
      DragLeave="Page_DragLeave">
    <Page.Resources>
        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#12121A" />
            <Setter Property="BorderBrush" Value="#1E1E2A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style x:Key="SearchDeleteDropCardStyle"
               TargetType="Border"
               BasedOn="{StaticResource SectionCardStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=RootPage, Path=IsSearchDeleteDropTarget}" Value="True">
                    <Setter Property="Background" Value="#2A1114" />
                    <Setter Property="BorderBrush" Value="#EF4444" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SearchDeleteOverlayStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=RootPage, Path=IsSearchDeleteDropTarget}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#E2E8F0" />
        </Style>

        <Style x:Key="SectionDescriptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#94A3B8" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#182338" />
            <Setter Property="Foreground" Value="#E2E8F0" />
            <Setter Property="CaretBrush" Value="#E2E8F0" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="InputBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="#60A5FA" />
                                <Setter TargetName="InputBorder" Property="Background" Value="#1E293B" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="InputBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DeleteSelectedButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Background" Value="#7F1D1D" />
            <Setter Property="BorderBrush" Value="#EF4444" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#FEE2E2" />
            <Setter Property="ToolTip" Value="Delete selected champions" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                TextElement.Foreground="{TemplateBinding Foreground}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#991B1B" />
                    <Setter Property="BorderBrush" Value="#F87171" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#1E293B" />
                    <Setter Property="BorderBrush" Value="#334155" />
                    <Setter Property="Foreground" Value="#64748B" />
                    <Setter Property="Cursor" Value="Arrow" />
                    <Setter Property="ToolTip" Value="Select one or more champions to delete." />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ChampionPillBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#182338" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
            <Setter Property="Cursor" Value="SizeAll" />
            <Setter Property="TextElement.Foreground" Value="#CBD5E1" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#182338" />
                    <Setter Property="BorderBrush" Value="#475569" />
                    <Setter Property="ToolTip" Value="Drag to reorder" />
                </Trigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="#1E3A8A" />
                    <Setter Property="BorderBrush" Value="#93C5FD" />
                    <Setter Property="TextElement.Foreground" Value="#EFF6FF" />
                    <Setter Property="ToolTip" Value="Selected" />
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsSelected}" Value="True" />
                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#1D4ED8" />
                    <Setter Property="BorderBrush" Value="#BFDBFE" />
                    <Setter Property="TextElement.Foreground" Value="#FFFFFF" />
                </MultiDataTrigger>
                <DataTrigger Binding="{Binding IsDuplicateDropTarget}" Value="True">
                    <Setter Property="Background" Value="#3A1114" />
                    <Setter Property="BorderBrush" Value="#EF4444" />
                    <Setter Property="TextElement.Foreground" Value="#FECACA" />
                    <Setter Property="ToolTip" Value="This existing champion will be replaced if you drop here." />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ChampionChipTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="LineHeight" Value="16" />
            <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
        </Style>

        <Style x:Key="ChampionReferenceButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#182338" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="SizeAll" />
            <Setter Property="Foreground" Value="#E2E8F0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,3,6,3" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
            <Setter Property="ToolTip" Value="Click to add to the selected list, or drag into a pick/ban list." />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                TextElement.Foreground="{TemplateBinding Foreground}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#22304A" />
                    <Setter Property="BorderBrush" Value="#60A5FA" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#17223A" />
                    <Setter Property="BorderBrush" Value="#93C5FD" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <ScrollViewer x:Name="PageScrollViewer"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid x:Name="ContentGrid" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

        <Border Grid.Row="3"
                Grid.RowSpan="2"
                Style="{StaticResource SectionCardStyle}"
                Margin="0,0,0,16">
            <StackPanel>

                    <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Position"
                               FontWeight="SemiBold"
                               Foreground="#CBD5E1"
                               Margin="0,0,0,6" />
                    <TextBlock Grid.Column="1"
                               Text="Pick Champions"
                               FontWeight="SemiBold"
                               Foreground="#CBD5E1"
                               Margin="6,0,0,6" />
                    <TextBlock Grid.Column="2"
                               Text="Ban Champions"
                               FontWeight="SemiBold"
                               Foreground="#CBD5E1"
                               Margin="6,0,0,6" />

                    <Button x:Name="DeleteSelectedButton"
                            Grid.Column="2"
                            Content="Delete selected"
                            Margin="12,0,0,6"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Click="DeleteSelectedButton_Click"
                            IsEnabled="{Binding ElementName=RootPage, Path=HasSelectedChampions}"
                            Style="{StaticResource DeleteSelectedButtonStyle}" />
                </Grid>

                <ItemsControl x:Name="PositionList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding PositionName}"
                                           VerticalAlignment="Top"
                                           Foreground="#E2E8F0"
                                           FontSize="14"
                                           Margin="0,10,0,0" />

                                <Border Grid.Column="1"
                                        Tag="Pick"
                                        Background="{Binding PickBackgroundBrush}"
                                        BorderBrush="{Binding PickBorderBrush}"
                                        BorderThickness="2"
                                        CornerRadius="8"
                                        AllowDrop="True"
                                        Padding="6"
                                        Margin="6,0,0,0"
                                        MinHeight="46"
                                        MouseLeftButtonDown="ChampionTarget_MouseLeftButtonDown"
                                        DragOver="ChampionList_DragOver"
                                        Drop="ChampionList_Drop">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Empty"
                                                   FontSize="11"
                                                   Foreground="#64748B"
                                                   FontStyle="Italic"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding PickPlaceholderVisibility}" />
                                        <ItemsControl ItemsSource="{Binding PickChampions}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,3,6,3"
                                                          VerticalAlignment="Center"
                                                          Background="Transparent"
                                                          AllowDrop="True"
                                                          DragOver="ChampionItem_DragOver"
                                                          Drop="ChampionItem_Drop">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <Border Grid.Column="0"
                                                                Width="3"
                                                                Margin="0,4,4,4"
                                                                Background="#60A5FA"
                                                                CornerRadius="2"
                                                                Visibility="{Binding InsertBeforeIndicatorVisibility}" />

                                                        <Border Grid.Column="1"
                                                                Tag="ChampionPill"
                                                                Style="{StaticResource ChampionPillBorderStyle}"
                                                                PreviewMouseLeftButtonDown="ChampionItem_PreviewMouseLeftButtonDown"
                                                                MouseMove="ChampionItem_MouseMove">
                                                            <TextBlock Text="{Binding DisplayText}"
                                                                       Style="{StaticResource ChampionChipTextStyle}" />
                                                        </Border>

                                                        <Border Grid.Column="2"
                                                                Width="3"
                                                                Margin="4,4,0,4"
                                                                Background="#60A5FA"
                                                                CornerRadius="2"
                                                                Visibility="{Binding InsertAfterIndicatorVisibility}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <Border Width="3"
                                                Height="28"
                                                Margin="4,2,0,0"
                                                Background="#60A5FA"
                                                CornerRadius="2"
                                                HorizontalAlignment="Left"
                                                Visibility="{Binding PickDropIndicatorVisibility}" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2"
                                        Tag="Ban"
                                        Background="{Binding BanBackgroundBrush}"
                                        BorderBrush="{Binding BanBorderBrush}"
                                        BorderThickness="2"
                                        CornerRadius="8"
                                        AllowDrop="True"
                                        Padding="6"
                                        Margin="6,0,0,0"
                                        MinHeight="46"
                                        MouseLeftButtonDown="ChampionTarget_MouseLeftButtonDown"
                                        DragOver="ChampionList_DragOver"
                                        Drop="ChampionList_Drop">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Empty"
                                                   FontSize="11"
                                                   Foreground="#64748B"
                                                   FontStyle="Italic"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding BanPlaceholderVisibility}" />
                                        <ItemsControl ItemsSource="{Binding BanChampions}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,3,6,3"
                                                          VerticalAlignment="Center"
                                                          Background="Transparent"
                                                          AllowDrop="True"
                                                          DragOver="ChampionItem_DragOver"
                                                          Drop="ChampionItem_Drop">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <Border Grid.Column="0"
                                                                Width="3"
                                                                Margin="0,4,4,4"
                                                                Background="#60A5FA"
                                                                CornerRadius="2"
                                                                Visibility="{Binding InsertBeforeIndicatorVisibility}" />

                                                        <Border Grid.Column="1"
                                                                Tag="ChampionPill"
                                                                Style="{StaticResource ChampionPillBorderStyle}"
                                                                PreviewMouseLeftButtonDown="ChampionItem_PreviewMouseLeftButtonDown"
                                                                MouseMove="ChampionItem_MouseMove">
                                                            <TextBlock Text="{Binding DisplayText}"
                                                                       Style="{StaticResource ChampionChipTextStyle}" />
                                                        </Border>

                                                        <Border Grid.Column="2"
                                                                Width="3"
                                                                Margin="4,4,0,4"
                                                                Background="#60A5FA"
                                                                CornerRadius="2"
                                                                Visibility="{Binding InsertAfterIndicatorVisibility}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <Border Width="3"
                                                Height="28"
                                                Margin="4,2,0,0"
                                                Background="#60A5FA"
                                                CornerRadius="2"
                                                HorizontalAlignment="Left"
                                                Visibility="{Binding BanDropIndicatorVisibility}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Border x:Name="ChampionSearchCard"
                Grid.Row="5"
                Grid.RowSpan="4"
                AllowDrop="True"
                PreviewDragOver="SearchArea_PreviewDragOver"
                PreviewDrop="SearchArea_PreviewDrop"
                Style="{StaticResource SearchDeleteDropCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Champion Search"
                           Style="{StaticResource SectionTitleStyle}"
                           Margin="0,0,0,4" />

                <TextBlock Grid.Row="1"
                           Text="Search by champion name or ID, then click to add to the selected list."
                           Style="{StaticResource SectionDescriptionStyle}"
                           Margin="0,0,0,8" />

                <TextBox x:Name="ChampionSearchBox"
                         Grid.Row="2"
                         TextChanged="ChampionSearchBox_TextChanged"
                         PreviewKeyDown="ChampionSearchBox_PreviewKeyDown"
                         Margin="0,0,0,8"
                         Style="{StaticResource SearchTextBoxStyle}" />

                <Border x:Name="ChampionReferenceBorder"
                        Grid.Row="3"
                        Background="#0F172A"
                        BorderBrush="#334155"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8">
                    <ScrollViewer x:Name="ChampionReferenceScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="ChampionReferenceList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Click="ChampionReferenceButton_Click"
                                            PreviewMouseLeftButtonDown="ChampionReferenceButton_PreviewMouseLeftButtonDown"
                                            PreviewMouseMove="ChampionReferenceButton_PreviewMouseMove"
                                            Style="{StaticResource ChampionReferenceButtonStyle}">
                                        <TextBlock Style="{StaticResource ChampionChipTextStyle}">
                                            <Run Text="+ " Foreground="#60A5FA" />
                                            <Run Text="{Binding Name, Mode=OneWay}" />
                                        </TextBlock>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <Border Grid.RowSpan="4"
                        Style="{StaticResource SearchDeleteOverlayStyle}"
                        Background="#992A1114"
                        BorderBrush="#EF4444"
                        BorderThickness="1"
                        CornerRadius="8"
                        IsHitTestVisible="False">
                    <Viewbox Width="42"
                             Height="42"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center">
                        <Canvas Width="24" Height="24">
                            <Path Stroke="#FEE2E2"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Data="M3,6 L5,6 M5,6 L21,6 M19,6 L21,6 M8,6 L8,4 L16,4 L16,6 M6,6 L7,21 L17,21 L18,6 M10,11 L10,17 M14,11 L14,17" />
                        </Canvas>
                    </Viewbox>
                </Border>
            </Grid>
        </Border>

        <Popup x:Name="DragPreviewPopup"
               Placement="RelativePoint"
               PlacementTarget="{Binding ElementName=RootPage}"
               AllowsTransparency="True"
               IsHitTestVisible="False"
               PopupAnimation="None"
               StaysOpen="True">
            <Border Background="#1E293B"
                    BorderBrush="#60A5FA"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="10,5"
                    Opacity="0.95">
                <TextBlock x:Name="DragPreviewText"
                           Foreground="#E2E8F0"
                           FontSize="12"
                           FontWeight="SemiBold" />
            </Border>
        </Popup>
        </Grid>
    </ScrollViewer>
</Page>
