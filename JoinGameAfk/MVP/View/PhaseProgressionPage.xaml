<Page x:Class="JoinGameAfk.View.PhaseProgressionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">
    <Page.Resources>
        <Style x:Key="AccentButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="24,12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.75" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PriorityListContainerStyle" TargetType="Border">
            <Setter Property="Background" Value="#0F172A" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="MinHeight" Value="56" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <Style x:Key="PriorityChampionChipStyle" TargetType="Border">
            <Setter Property="Background" Value="#0F172A" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,6,6" />
        </Style>

        <Style x:Key="DashboardCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#121722" />
            <Setter Property="BorderBrush" Value="#232836" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16,14" />
        </Style>

    </Page.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#12121A"
                BorderBrush="#1E1E2A"
                BorderThickness="1"
                CornerRadius="14"
                Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button x:Name="ToggleButton"
                        Grid.Column="0"
                        Width="100"
                        Background="#2E7D32"
                        Content="Start"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="ToggleButton_Click" />

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText"
                               Text="Stopped"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#F8FAFC" />
                    <TextBlock x:Name="ConnectionText"
                               Margin="0,4,0,0"
                               Text="Client offline"
                               FontSize="12"
                               Foreground="#FCA5A5" />
                </StackPanel>

                <StackPanel Grid.Column="4" VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <TextBlock x:Name="ChampSelectSubPhaseText"
                               Text=""
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#F8FAFC"
                               HorizontalAlignment="Right" />
                    <TextBlock x:Name="ChampSelectTimerText"
                               Text=""
                               Margin="0,4,0,0"
                               FontSize="12"
                               Foreground="#94A3B8"
                               HorizontalAlignment="Right" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#0B0E14"
                    BorderBrush="#232836"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="20,18">
                <UniformGrid Columns="2">
                        <Border Margin="0,0,8,0"
                                Style="{StaticResource DashboardCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Pick plan"
                                           FontSize="12"
                                           Foreground="#94A3B8" />
                                <Border Style="{StaticResource PriorityListContainerStyle}"
                                        Margin="0,8,0,0">
                                    <Grid>
                                        <TextBlock x:Name="PickChampionPlaceholderText"
                                                   Text="Waiting for champion select."
                                                   FontSize="11"
                                                   Foreground="#64748B"
                                                   FontStyle="Italic"
                                                    Margin="0,0,0,6"
                                                   Visibility="Visible" />
                                        <ItemsControl x:Name="PickChampionPriorityList">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border>
                                                        <Border.Style>
                                                            <Style TargetType="Border" BasedOn="{StaticResource PriorityChampionChipStyle}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                                        <Setter Property="Background" Value="#351417" />
                                                                        <Setter Property="BorderBrush" Value="#DC2626" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="12"
                                                                    VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#CBD5E1" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                                            <Setter Property="Foreground" Value="#FCA5A5" />
                                                                            <Setter Property="TextDecorations" Value="Strikethrough" />
                                                                            <Setter Property="ToolTip" Value="Not currently pickable." />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Border>
                                <TextBlock Text="Action"
                                           Margin="0,12,0,0"
                                           FontSize="12"
                                           Foreground="#94A3B8" />
                                <TextBlock x:Name="PickLockValueText"
                                           Margin="0,8,0,0"
                                           FontSize="13"
                                           Foreground="#CBD5E1"
                                           Text="—"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource DashboardCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Ban plan"
                                           FontSize="12"
                                           Foreground="#94A3B8" />
                                <Border Style="{StaticResource PriorityListContainerStyle}"
                                        Margin="0,8,0,0">
                                    <Grid>
                                        <TextBlock x:Name="BanChampionPlaceholderText"
                                                   Text="Waiting for champion select."
                                                   FontSize="11"
                                                   Foreground="#64748B"
                                                   FontStyle="Italic"
                                                    Margin="0,0,0,6"
                                                   Visibility="Visible" />
                                        <ItemsControl x:Name="BanChampionPriorityList">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border>
                                                        <Border.Style>
                                                            <Style TargetType="Border" BasedOn="{StaticResource PriorityChampionChipStyle}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                                        <Setter Property="Background" Value="#351417" />
                                                                        <Setter Property="BorderBrush" Value="#DC2626" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="12"
                                                                    VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#CBD5E1" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                                            <Setter Property="Foreground" Value="#FCA5A5" />
                                                                            <Setter Property="TextDecorations" Value="Strikethrough" />
                                                                            <Setter Property="ToolTip" Value="Not currently bannable." />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Border>
                                <TextBlock Text="Action"
                                           Margin="0,12,0,0"
                                           FontSize="12"
                                           Foreground="#94A3B8" />
                                <TextBlock x:Name="BanLockValueText"
                                           Margin="0,8,0,0"
                                           FontSize="13"
                                           Foreground="#CBD5E1"
                                           Text="—" />
                            </StackPanel>
                        </Border>
                </UniformGrid>
            </Border>

            <Border Grid.Row="2"
                    Background="#0B0E14"
                    BorderBrush="#232836"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16,14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Live log"
                               FontSize="12"
                               Foreground="#94A3B8" />

                    <Frame x:Name="EmbeddedLogsFrame"
                           Grid.Row="2"
                           NavigationUIVisibility="Hidden"
                           Background="Transparent"
                           BorderThickness="0" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>