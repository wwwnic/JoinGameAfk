<Page x:Class="JoinGameAfk.View.PhaseProgressionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      SizeChanged="Page_SizeChanged">
    <Page.Resources>
        <Style x:Key="DraftPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="DraftPanelHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="DraftSlotStyle" TargetType="Border">
            <Setter Property="MinHeight" Value="64" />
            <Setter Property="Padding" Value="11,9" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppMutedBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style x:Key="DraftAvatarStyle" TargetType="Border">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Background" Value="{DynamicResource AppInputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppStrongBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="TextElement.Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        </Style>

        <Style x:Key="DraftAvatarTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextSoftBrush}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="DraftRoleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="DraftChampionTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="HeaderBanPanelStyle" TargetType="Border">
            <Setter Property="MinHeight" Value="68" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Background" Value="{DynamicResource AppSurfaceInsetBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppMutedBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="HeaderBanChipStyle"
               TargetType="Border"
               BasedOn="{StaticResource PriorityChampionChipStyle}">
            <Setter Property="Background" Value="{DynamicResource DangerSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DangerAccentBrush}" />
            <Setter Property="TextElement.Foreground" Value="{DynamicResource DangerTextBrush}" />
        </Style>

        <Style x:Key="HeaderBanPlaceholderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
            <Setter Property="FontStyle" Value="Italic" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="RoleChipStyle" TargetType="Border">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Background" Value="{DynamicResource AppSurfaceInsetBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppMutedBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="TextElement.Foreground" Value="{DynamicResource TextMutedBrush}" />
        </Style>

        <Style x:Key="ActiveRoleChipStyle" TargetType="Border" BasedOn="{StaticResource RoleChipStyle}">
            <Setter Property="Background" Value="{DynamicResource AccentBlueInfoBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}" />
            <Setter Property="TextElement.Foreground" Value="{DynamicResource AccentBlueTextBrush}" />
        </Style>

        <Style x:Key="ActionPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppStrongBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
        </Style>

    </Page.Resources>

    <ScrollViewer Style="{StaticResource StableVerticalScrollViewerStyle}">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition x:Name="LogRow" Height="190" />
            </Grid.RowDefinitions>

            <Border x:Name="HeaderPanel"
                    Grid.Row="0"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16,11">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="132" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource HeaderBanPanelStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="YOUR BANS"
                                       Style="{StaticResource DraftPanelHeaderStyle}" />

                            <Grid Grid.Row="2">
                                <TextBlock x:Name="MyTeamBansPlaceholderText"
                                           Text="No bans yet."
                                           Style="{StaticResource HeaderBanPlaceholderStyle}"
                                           VerticalAlignment="Center" />
                                <ItemsControl x:Name="MyTeamBansList"
                                              VerticalAlignment="Top">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource HeaderBanChipStyle}">
                                                <TextBlock Text="{Binding Name}"
                                                           Style="{StaticResource ChampionChipTextStyle}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            MinHeight="68"
                            BorderBrush="{DynamicResource AccentBlueBrush}"
                            BorderThickness="1,0"
                            Padding="10,5"
                            VerticalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="ChampSelectTimerText"
                                       Text="--"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBlueSoftBrush}"
                                       HorizontalAlignment="Center"
                                       LineHeight="34"
                                       LineStackingStrategy="BlockLineHeight" />
                            <TextBlock Text="seconds"
                                       Margin="0,4,0,0"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4"
                            Style="{StaticResource HeaderBanPanelStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="ENEMY BANS"
                                       Style="{StaticResource DraftPanelHeaderStyle}"
                                       HorizontalAlignment="Right" />

                            <Grid Grid.Row="2">
                                <TextBlock x:Name="TheirTeamBansPlaceholderText"
                                           Text="No bans yet."
                                           Style="{StaticResource HeaderBanPlaceholderStyle}"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center" />
                                <ItemsControl x:Name="TheirTeamBansList"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Top">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource HeaderBanChipStyle}">
                                                <TextBlock Text="{Binding Name}"
                                                           Style="{StaticResource ChampionChipTextStyle}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="4"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Visibility="Collapsed">
                        <TextBlock x:Name="ConnectionText"
                                   Visibility="Collapsed"
                                   Text="Client offline"
                                   Foreground="{DynamicResource PhaseOfflineForegroundBrush}" />
                        <TextBlock x:Name="ChampSelectSubPhaseText"
                                   Visibility="Collapsed"
                                   Text="Idle" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid x:Name="DraftLayoutGrid"
                  Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" MinWidth="170" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="2.2*" MinWidth="280" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="1.05*" MinWidth="170" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource DraftPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Padding="12,10"
                                BorderBrush="{DynamicResource AppMutedBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <StackPanel>
                                <TextBlock Text="YOUR TEAM"
                                           Style="{StaticResource DraftPanelHeaderStyle}" />
                                <TextBlock Text="Current champions"
                                           Margin="0,2,0,0"
                                           Style="{StaticResource MutedTextStyle}" />
                            </StackPanel>
                        </Border>

                        <ItemsControl x:Name="MyTeamSlotList"
                                      Grid.Row="1">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource DraftSlotStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="9" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    Style="{StaticResource DraftAvatarStyle}">
                                                <TextBlock Text="{Binding ChampionInitial}"
                                                           Style="{StaticResource DraftAvatarTextStyle}" />
                                            </Border>
                                            <StackPanel Grid.Column="2"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ChampionName}"
                                                           Style="{StaticResource DraftRoleTextStyle}" />
                                                <TextBlock Text="{Binding RoleName}"
                                                           MinHeight="17"
                                                           Style="{StaticResource DraftChampionTextStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource DraftPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Padding="12,10"
                                BorderBrush="{DynamicResource AppMutedBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="PLANNER VIEW"
                                               Style="{StaticResource DraftPanelHeaderStyle}" />
                                    <TextBlock Text="Priority lists from your app settings"
                                               Margin="0,2,0,0"
                                               Style="{StaticResource MutedTextStyle}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <UniformGrid Grid.Row="1"
                                     Columns="6"
                                     Margin="12,12,12,0">
                            <Border x:Name="TopRoleChip"
                                    Style="{StaticResource RoleChipStyle}"
                                    Margin="0,0,6,0">
                                <TextBlock Text="Top"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <Border x:Name="JungleRoleChip"
                                    Style="{StaticResource RoleChipStyle}"
                                    Margin="0,0,6,0">
                                <TextBlock Text="Jungle"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <Border x:Name="MidRoleChip"
                                    Style="{StaticResource RoleChipStyle}"
                                    Margin="0,0,6,0">
                                <TextBlock Text="Mid"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <Border x:Name="AdcRoleChip"
                                    Style="{StaticResource RoleChipStyle}"
                                    Margin="0,0,6,0">
                                <TextBlock Text="ADC"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <Border x:Name="SupportRoleChip"
                                    Style="{StaticResource RoleChipStyle}"
                                    Margin="0,0,6,0">
                                <TextBlock Text="Support"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <Border x:Name="DefaultRoleChip"
                                    Style="{StaticResource ActiveRoleChipStyle}">
                                <TextBlock Text="Default"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                        </UniformGrid>

                        <Border Grid.Row="2"
                                Style="{StaticResource ActionPanelStyle}"
                                Margin="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Width="48"
                                        Height="48"
                                        Background="{DynamicResource AccentBlueInfoBrush}"
                                        BorderBrush="{DynamicResource AccentBlueBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <Viewbox Stretch="Uniform"
                                             Margin="5">
                                        <TextBlock x:Name="CurrentActionChampionText"
                                                   Text="--"
                                                   Width="42"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource AccentBlueTextBrush}"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Viewbox>
                                </Border>
                                <StackPanel Grid.Column="2"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Current action"
                                               Style="{StaticResource EyebrowTextStyle}" />
                                    <TextBlock x:Name="CurrentActionTitleText"
                                               Text="None plan"
                                               Margin="0,2,0,0"
                                               FontSize="19"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock x:Name="CurrentActionSubtitleText"
                                               Text=""
                                               Margin="0,3,0,0"
                                               Style="{StaticResource MutedTextStyle}"
                                               Visibility="Collapsed"
                                               TextWrapping="Wrap" />
                                    <TextBlock x:Name="CurrentActionLockText"
                                               Text="Lock timing unavailable."
                                               Margin="0,3,0,0"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="3"
                              Margin="12,0,12,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource ActionPanelStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Width="4"
                                                Height="28"
                                                Background="{DynamicResource AccentBlueBrush}"
                                                CornerRadius="2" />
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Pick plan"
                                                       Style="{StaticResource CardTitleStyle}"
                                                       FontSize="14" />
                                            <TextBlock Text="Champion priority"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       Margin="0,1,0,0" />
                                        </StackPanel>
                                    </Grid>

                                    <Border Grid.Row="2"
                                            Background="{DynamicResource AppSurfaceInsetBrush}"
                                            BorderBrush="{DynamicResource AppMutedBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="6"
                                            MinHeight="76">
                                        <Grid>
                                            <TextBlock x:Name="PickChampionPlaceholderText"
                                                       Text="Waiting for champion select."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSubtleBrush}"
                                                       FontStyle="Italic"
                                                       TextWrapping="Wrap"
                                                       VerticalAlignment="Center"
                                                       Visibility="Visible" />
                                            <ItemsControl x:Name="PickChampionPriorityList"
                                                          VerticalAlignment="Top">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,0,5"
                                                                Padding="8,0"
                                                                MinHeight="28"
                                                                Background="{DynamicResource AppInputBrush}"
                                                                BorderBrush="{DynamicResource AppStrongBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="7">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="18" />
                                                                    <ColumnDefinition Width="7" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <Border Grid.Column="0"
                                                                        Width="18"
                                                                        Height="18"
                                                                        Background="{DynamicResource AccentBlueInfoBrush}"
                                                                        BorderBrush="{DynamicResource AccentBlueBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="5">
                                                                    <TextBlock Text="{Binding Name[0]}"
                                                                               FontSize="9"
                                                                               FontWeight="Bold"
                                                                               Foreground="{DynamicResource AccentBlueTextBrush}"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center" />
                                                                </Border>
                                                                <TextBlock Grid.Column="2"
                                                                           Text="{Binding Name}"
                                                                           Style="{StaticResource ChampionChipTextStyle}"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                           TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Grid.Column="3"
                                                                           FontSize="10"
                                                                           FontWeight="Bold"
                                                                           Foreground="{DynamicResource AccentGreenTextBrush}"
                                                                           VerticalAlignment="Center">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="Pick" />
                                                                            <Setter Property="TextDecorations" Value="{x:Null}" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                                                    <Setter Property="Foreground" Value="{DynamicResource DangerTextBrush}" />
                                                                                    <Setter Property="Text" Value="Blocked" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Grid>
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Opacity" Value="1" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                                            <Setter Property="Background" Value="{DynamicResource DangerSurfaceRaisedBrush}" />
                                                                            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
                                                                            <Setter Property="Opacity" Value="0.88" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2"
                                    Style="{StaticResource ActionPanelStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Width="4"
                                                Height="28"
                                                Background="{DynamicResource DangerAccentBrush}"
                                                CornerRadius="2" />
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Ban plan"
                                                       Style="{StaticResource CardTitleStyle}"
                                                       FontSize="14" />
                                            <TextBlock Text="Champion priority"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       Margin="0,1,0,0" />
                                        </StackPanel>
                                    </Grid>

                                    <Border Grid.Row="2"
                                            Background="{DynamicResource AppSurfaceInsetBrush}"
                                            BorderBrush="{DynamicResource AppMutedBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="6"
                                            MinHeight="76">
                                        <Grid>
                                            <TextBlock x:Name="BanChampionPlaceholderText"
                                                       Text="Waiting for champion select."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSubtleBrush}"
                                                       FontStyle="Italic"
                                                       TextWrapping="Wrap"
                                                       VerticalAlignment="Center"
                                                       Visibility="Visible" />
                                            <ItemsControl x:Name="BanChampionPriorityList"
                                                          VerticalAlignment="Top">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,0,5"
                                                                Padding="8,0"
                                                                MinHeight="28"
                                                                Background="{DynamicResource AppInputBrush}"
                                                                BorderBrush="{DynamicResource AppStrongBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="7">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="18" />
                                                                    <ColumnDefinition Width="7" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <Border Grid.Column="0"
                                                                        Width="18"
                                                                        Height="18"
                                                                        Background="{DynamicResource DangerSurfaceBrush}"
                                                                        BorderBrush="{DynamicResource DangerAccentBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="5">
                                                                    <TextBlock Text="{Binding Name[0]}"
                                                                               FontSize="9"
                                                                               FontWeight="Bold"
                                                                               Foreground="{DynamicResource DangerTextBrush}"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center" />
                                                                </Border>
                                                                <TextBlock Grid.Column="2"
                                                                           Text="{Binding Name}"
                                                                           Style="{StaticResource ChampionChipTextStyle}"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                           TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Grid.Column="3"
                                                                           FontSize="10"
                                                                           FontWeight="Bold"
                                                                           Foreground="{DynamicResource DangerTextSoftBrush}"
                                                                           VerticalAlignment="Center">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="Ban" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                                                    <Setter Property="Foreground" Value="{DynamicResource DangerTextBrush}" />
                                                                                    <Setter Property="Text" Value="Blocked" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Grid>
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Opacity" Value="1" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                                            <Setter Property="Background" Value="{DynamicResource DangerSurfaceRaisedBrush}" />
                                                                            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
                                                                            <Setter Property="Opacity" Value="0.88" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Column="4"
                        Style="{StaticResource DraftPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Padding="12,10"
                                BorderBrush="{DynamicResource AppMutedBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <StackPanel HorizontalAlignment="Right">
                                <TextBlock Text="ENEMY TEAM"
                                           Style="{StaticResource DraftPanelHeaderStyle}"
                                           HorizontalAlignment="Right" />
                                <TextBlock Text="Current champions"
                                           Margin="0,2,0,0"
                                           Style="{StaticResource MutedTextStyle}"
                                           HorizontalAlignment="Right" />
                            </StackPanel>
                        </Border>

                        <ItemsControl x:Name="TheirTeamSlotList"
                                      Grid.Row="1">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource DraftSlotStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="9" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    Style="{StaticResource DraftAvatarStyle}">
                                                <TextBlock Text="{Binding ChampionInitial}"
                                                           Style="{StaticResource DraftAvatarTextStyle}" />
                                            </Border>
                                            <StackPanel Grid.Column="2"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ChampionName}"
                                                           Style="{StaticResource DraftRoleTextStyle}" />
                                                <TextBlock Text="{Binding RoleName}"
                                                           MinHeight="17"
                                                           Style="{StaticResource DraftChampionTextStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="4"
                    Style="{StaticResource DraftPanelStyle}"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="9" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="8"
                                Height="8"
                                Background="{DynamicResource AccentGreenTextBrush}"
                                CornerRadius="4"
                                VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   Text="Live log"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSoftBrush}" />
                        <TextBlock Grid.Column="3"
                                   Text="Watcher output"
                                   Style="{StaticResource EyebrowTextStyle}" />
                    </Grid>

                    <Frame x:Name="EmbeddedLogsFrame"
                           Grid.Row="2"
                           NavigationUIVisibility="Hidden"
                           Background="Transparent"
                           BorderThickness="0" />
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
