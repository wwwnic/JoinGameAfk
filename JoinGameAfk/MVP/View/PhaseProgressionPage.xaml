<Page x:Class="JoinGameAfk.View.PhaseProgressionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">
    <Page.Resources>
        <Style x:Key="AccentButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="22,11" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.75" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DashboardCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#0B0E14" />
            <Setter Property="BorderBrush" Value="#232836" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style x:Key="PriorityListContainerStyle" TargetType="Border">
            <Setter Property="Background" Value="#0F172A" />
            <Setter Property="BorderBrush" Value="#1E293B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="MinHeight" Value="70" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <Style x:Key="PriorityChampionChipStyle" TargetType="Border">
            <Setter Property="Background" Value="#182338" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="Margin" Value="0,0,6,6" />
        </Style>

        <Style x:Key="EyebrowTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#64748B" />
        </Style>

        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#E2E8F0" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#94A3B8" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#12121A"
                BorderBrush="#1E1E2A"
                BorderThickness="1"
                CornerRadius="14"
                Padding="18,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button x:Name="ToggleButton"
                        Grid.Column="0"
                        Width="116"
                        Background="#2E7D32"
                        Content="Start"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="ToggleButton_Click" />

                <StackPanel Grid.Column="2"
                            VerticalAlignment="Center">
                    <TextBlock Text="WATCHER"
                               Style="{StaticResource EyebrowTextStyle}" />
                    <TextBlock x:Name="StatusText"
                               Text="Stopped"
                               Margin="0,3,0,0"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#F8FAFC" />
                    <TextBlock x:Name="ConnectionText"
                               Margin="0,4,0,0"
                               Text="Client offline"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#FCA5A5" />
                </StackPanel>

                <Border Grid.Column="4"
                        MinWidth="150"
                        Background="#0F172A"
                        BorderBrush="#1E293B"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14,10"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="Phase"
                                   Style="{StaticResource EyebrowTextStyle}" />
                        <TextBlock Grid.Row="0"
                                   Grid.Column="2"
                                   Text="Timer"
                                   Style="{StaticResource EyebrowTextStyle}"
                                   HorizontalAlignment="Right" />

                        <TextBlock x:Name="ChampSelectSubPhaseText"
                                   Grid.Row="2"
                                   Grid.Column="0"
                                   Text=""
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#F8FAFC"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="ChampSelectTimerText"
                                   Grid.Row="2"
                                   Grid.Column="2"
                                   Text=""
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#93C5FD"
                                   HorizontalAlignment="Right" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource DashboardCardStyle}">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="4"
                                Height="34"
                                Background="#60A5FA"
                                CornerRadius="2" />
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Pick plan"
                                       Style="{StaticResource CardTitleStyle}" />
                            <TextBlock Text="Champion priority"
                                       Style="{StaticResource MutedTextStyle}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>

                    <Border Style="{StaticResource PriorityListContainerStyle}">
                        <Grid>
                            <TextBlock x:Name="PickChampionPlaceholderText"
                                       Text="Waiting for champion select."
                                       FontSize="12"
                                       Foreground="#64748B"
                                       FontStyle="Italic"
                                       TextWrapping="Wrap"
                                       Visibility="Visible" />
                            <ItemsControl x:Name="PickChampionPriorityList">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border>
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource PriorityChampionChipStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                            <Setter Property="Background" Value="#351417" />
                                                            <Setter Property="BorderBrush" Value="#DC2626" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#CBD5E1" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                                <Setter Property="Foreground" Value="#FCA5A5" />
                                                                <Setter Property="TextDecorations" Value="Strikethrough" />
                                                                <Setter Property="ToolTip" Value="Not currently pickable." />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <Border Background="#0F172A"
                            BorderBrush="#1E293B"
                            BorderThickness="1"
                            CornerRadius="9"
                            Padding="12"
                            Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Next action"
                                       Style="{StaticResource EyebrowTextStyle}" />
                            <TextBlock x:Name="PickLockValueText"
                                       Margin="0,5,0,0"
                                       FontSize="13"
                                       Foreground="#CBD5E1"
                                       Text="-"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource DashboardCardStyle}">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="4"
                                Height="34"
                                Background="#EF4444"
                                CornerRadius="2" />
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Ban plan"
                                       Style="{StaticResource CardTitleStyle}" />
                            <TextBlock Text="Champion priority"
                                       Style="{StaticResource MutedTextStyle}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>

                    <Border Style="{StaticResource PriorityListContainerStyle}">
                        <Grid>
                            <TextBlock x:Name="BanChampionPlaceholderText"
                                       Text="Waiting for champion select."
                                       FontSize="12"
                                       Foreground="#64748B"
                                       FontStyle="Italic"
                                       TextWrapping="Wrap"
                                       Visibility="Visible" />
                            <ItemsControl x:Name="BanChampionPriorityList">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border>
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource PriorityChampionChipStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                            <Setter Property="Background" Value="#351417" />
                                                            <Setter Property="BorderBrush" Value="#DC2626" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#CBD5E1" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                                <Setter Property="Foreground" Value="#FCA5A5" />
                                                                <Setter Property="TextDecorations" Value="Strikethrough" />
                                                                <Setter Property="ToolTip" Value="Not currently bannable." />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <Border Background="#0F172A"
                            BorderBrush="#1E293B"
                            BorderThickness="1"
                            CornerRadius="9"
                            Padding="12"
                            Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Next action"
                                       Style="{StaticResource EyebrowTextStyle}" />
                            <TextBlock x:Name="BanLockValueText"
                                       Margin="0,5,0,0"
                                       FontSize="13"
                                       Foreground="#CBD5E1"
                                       Text="-"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="4"
                Style="{StaticResource DashboardCardStyle}"
                Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="8"
                            Height="8"
                            Background="#7DD3A3"
                            CornerRadius="4"
                            VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2"
                               Text="Live log"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#CBD5E1" />
                </Grid>

                <Frame x:Name="EmbeddedLogsFrame"
                       Grid.Row="2"
                       NavigationUIVisibility="Hidden"
                       Background="Transparent"
                       BorderThickness="0" />
            </Grid>
        </Border>
    </Grid>
</Page>
