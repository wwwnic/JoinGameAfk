<Page x:Class="JoinGameAfk.View.PhaseProgressionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:viewControls="clr-namespace:JoinGameAfk.View.Controls"
      Background="Transparent"
      SizeChanged="Page_SizeChanged">
    <Page.Resources>
        <SolidColorBrush x:Key="UnavailableNotOwnedSurfaceBrush" Color="#3A2705" />
        <SolidColorBrush x:Key="UnavailableNotOwnedAccentBrush" Color="#F59E0B" />
        <SolidColorBrush x:Key="UnavailableNotOwnedTextBrush" Color="#FFE8A3" />
        <SolidColorBrush x:Key="UnavailableBannedSurfaceBrush" Color="#351015" />
        <SolidColorBrush x:Key="UnavailableBannedAccentBrush" Color="#EF4444" />
        <SolidColorBrush x:Key="UnavailableBannedTextBrush" Color="#FECACA" />
        <SolidColorBrush x:Key="UnavailableSelectedSurfaceBrush" Color="#261346" />
        <SolidColorBrush x:Key="UnavailableSelectedAccentBrush" Color="#A78BFA" />
        <SolidColorBrush x:Key="UnavailableSelectedTextBrush" Color="#DDD6FE" />
        <SolidColorBrush x:Key="UnavailableFailedSurfaceBrush" Color="#1F2937" />
        <SolidColorBrush x:Key="UnavailableFailedAccentBrush" Color="#94A3B8" />
        <SolidColorBrush x:Key="UnavailableFailedTextBrush" Color="#E5E7EB" />
        <SolidColorBrush x:Key="UnavailableBlockedSurfaceBrush" Color="#102A43" />
        <SolidColorBrush x:Key="UnavailableBlockedAccentBrush" Color="#38BDF8" />
        <SolidColorBrush x:Key="UnavailableBlockedTextBrush" Color="#BAE6FD" />

        <Style x:Key="DraftPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="DraftPanelHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="DraftSlotStyle" TargetType="Border">
            <Setter Property="MinHeight" Value="64" />
            <Setter Property="Padding" Value="11,9" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppMutedBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPlanReference}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DangerSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource DangerAccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding PlanReferenceReasonKind}" Value="Selected">
                    <Setter Property="Background" Value="{StaticResource UnavailableSelectedSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource UnavailableSelectedAccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsOwnAction}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBlueInfoBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DraftAvatarStyle" TargetType="Border">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Background" Value="{DynamicResource AppInputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppStrongBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
            <Setter Property="TextElement.Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPlanReference}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DangerSurfaceRaisedBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource DangerAccentBrush}" />
                    <Setter Property="TextElement.Foreground" Value="{DynamicResource DangerTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding PlanReferenceReasonKind}" Value="Selected">
                    <Setter Property="Background" Value="{StaticResource UnavailableSelectedSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource UnavailableSelectedAccentBrush}" />
                    <Setter Property="TextElement.Foreground" Value="{StaticResource UnavailableSelectedTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsOwnAction}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBlueInfoBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}" />
                    <Setter Property="TextElement.Foreground" Value="{DynamicResource AccentBlueTextBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DraftRoleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPlanReference}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource DangerTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding PlanReferenceReasonKind}" Value="Selected">
                    <Setter Property="Foreground" Value="{StaticResource UnavailableSelectedTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsOwnAction}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource AccentBlueTextBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DraftChampionTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPlanReference}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource DangerTextSoftBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding PlanReferenceReasonKind}" Value="Selected">
                    <Setter Property="Foreground" Value="{StaticResource UnavailableSelectedTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsOwnAction}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource AccentBlueTextBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderBanPanelStyle" TargetType="Border">
            <Setter Property="MinHeight" Value="68" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Background" Value="{DynamicResource AppSurfaceInsetBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppMutedBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="HeaderBanChipStyle"
               TargetType="Border"
               BasedOn="{StaticResource PriorityChampionChipStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPlanReference}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DangerSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource DangerAccentBrush}" />
                    <Setter Property="TextElement.Foreground" Value="{DynamicResource DangerTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding PlanReferenceReasonKind}" Value="Banned">
                    <Setter Property="Background" Value="{StaticResource UnavailableBannedSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource UnavailableBannedAccentBrush}" />
                    <Setter Property="TextElement.Foreground" Value="{StaticResource UnavailableBannedTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsOwnAction}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBlueInfoBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}" />
                    <Setter Property="TextElement.Foreground" Value="{DynamicResource AccentBlueTextBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderBanPortraitChipStyle"
               TargetType="Border"
               BasedOn="{StaticResource HeaderBanChipStyle}">
            <Setter Property="Padding" Value="4,2,8,2" />
            <Setter Property="MinHeight" Value="32" />
        </Style>

        <Style x:Key="HeaderBanPortraitSlotStyle"
               TargetType="Border"
               BasedOn="{StaticResource ChampionPortraitSlotStyle}">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="HeaderBanPlaceholderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
            <Setter Property="FontStyle" Value="Italic" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="ActionPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppStrongBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
        </Style>

    </Page.Resources>

    <ScrollViewer Style="{StaticResource StableVerticalScrollViewerStyle}">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition x:Name="LogRow" Height="190" />
            </Grid.RowDefinitions>

            <Border x:Name="HeaderPanel"
                    Grid.Row="0"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16,11">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="132" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource HeaderBanPanelStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="YOUR BANS"
                                       Style="{StaticResource DraftPanelHeaderStyle}" />

                            <Grid Grid.Row="2">
                                <TextBlock x:Name="MyTeamBansPlaceholderText"
                                           Text="No bans yet."
                                           Style="{StaticResource HeaderBanPlaceholderStyle}"
                                           VerticalAlignment="Center" />
                                <ItemsControl x:Name="MyTeamBansList"
                                              VerticalAlignment="Top">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource HeaderBanPortraitChipStyle}"
                                                    ToolTip="{Binding ToolTipText}">
                                                <DockPanel LastChildFill="True">
                                                    <Border ClipToBounds="True"
                                                            Style="{StaticResource HeaderBanPortraitSlotStyle}">
                                                        <Grid>
                                                            <viewControls:ChampionMysteryGlyph Width="16"
                                                                                               Height="16"
                                                                                               HorizontalAlignment="Center"
                                                                                               VerticalAlignment="Center"
                                                                                               Foreground="{DynamicResource TextSubtleBrush}" />
                                                            <Image Source="{Binding PortraitImageSource}"
                                                                   Stretch="UniformToFill"
                                                                   SnapsToDevicePixels="True" />
                                                        </Grid>
                                                    </Border>
                                                    <TextBlock Text="{Binding Name}"
                                                               MaxWidth="130"
                                                               Style="{StaticResource ChampionChipTextStyle}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            MinHeight="68"
                            BorderBrush="{DynamicResource AccentBlueBrush}"
                            BorderThickness="1,0"
                            Padding="10,5"
                            VerticalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="ChampSelectTimerText"
                                       Text="--"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBlueSoftBrush}"
                                       HorizontalAlignment="Center"
                                       LineHeight="34"
                                       LineStackingStrategy="BlockLineHeight" />
                            <TextBlock Text="seconds"
                                       Margin="0,4,0,0"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4"
                            Style="{StaticResource HeaderBanPanelStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="ENEMY BANS"
                                       Style="{StaticResource DraftPanelHeaderStyle}"
                                       HorizontalAlignment="Right" />

                            <Grid Grid.Row="2">
                                <TextBlock x:Name="TheirTeamBansPlaceholderText"
                                           Text="No bans yet."
                                           Style="{StaticResource HeaderBanPlaceholderStyle}"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center" />
                                <ItemsControl x:Name="TheirTeamBansList"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Top">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource HeaderBanPortraitChipStyle}"
                                                    ToolTip="{Binding ToolTipText}">
                                                <DockPanel LastChildFill="True">
                                                    <Border ClipToBounds="True"
                                                            Style="{StaticResource HeaderBanPortraitSlotStyle}">
                                                        <Grid>
                                                            <viewControls:ChampionMysteryGlyph Width="16"
                                                                                               Height="16"
                                                                                               HorizontalAlignment="Center"
                                                                                               VerticalAlignment="Center"
                                                                                               Foreground="{DynamicResource TextSubtleBrush}" />
                                                            <Image Source="{Binding PortraitImageSource}"
                                                                   Stretch="UniformToFill"
                                                                   SnapsToDevicePixels="True" />
                                                        </Grid>
                                                    </Border>
                                                    <TextBlock Text="{Binding Name}"
                                                               MaxWidth="130"
                                                               Style="{StaticResource ChampionChipTextStyle}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="4"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Visibility="Collapsed">
                        <TextBlock x:Name="ConnectionText"
                                   Visibility="Collapsed"
                                   Text="Client offline"
                                   Foreground="{DynamicResource PhaseOfflineForegroundBrush}" />
                        <TextBlock x:Name="ChampSelectSubPhaseText"
                                   Visibility="Collapsed"
                                   Text="Idle" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid x:Name="DraftLayoutGrid"
                  Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" MinWidth="170" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="2.2*" MinWidth="280" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="1.05*" MinWidth="170" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource DraftPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Padding="12,10"
                                BorderBrush="{DynamicResource AppMutedBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <StackPanel>
                                <TextBlock Text="YOUR TEAM"
                                           Style="{StaticResource DraftPanelHeaderStyle}" />
                                <TextBlock Text="Current champions"
                                           Margin="0,2,0,0"
                                           Style="{StaticResource MutedTextStyle}" />
                            </StackPanel>
                        </Border>

                        <ItemsControl x:Name="MyTeamSlotList"
                                      Grid.Row="1">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource DraftSlotStyle}"
                                            ToolTip="{Binding PlanReferenceText}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="9" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    Style="{StaticResource DraftAvatarStyle}">
                                                <Grid>
                                                    <viewControls:ChampionMysteryGlyph Width="28"
                                                                                       Height="28"
                                                                                       HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"
                                                                                       Foreground="{DynamicResource TextSubtleBrush}" />
                                                    <Image Source="{Binding PortraitImageSource}"
                                                           Stretch="UniformToFill"
                                                           SnapsToDevicePixels="True" />
                                                </Grid>
                                            </Border>
                                            <StackPanel Grid.Column="2"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ChampionName}"
                                                           Style="{StaticResource DraftRoleTextStyle}" />
                                                <TextBlock Text="{Binding RoleName}"
                                                           MinHeight="17"
                                                           Style="{StaticResource DraftChampionTextStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource DraftPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Padding="12,10"
                                BorderBrush="{DynamicResource AppMutedBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="PLANNER VIEW"
                                               Style="{StaticResource DraftPanelHeaderStyle}" />
                                    <TextBlock Text="Priority lists from your app settings"
                                               Margin="0,2,0,0"
                                               Style="{StaticResource MutedTextStyle}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Style="{StaticResource ActionPanelStyle}"
                                Margin="12,12,12,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Width="4"
                                            Height="28"
                                            Background="{DynamicResource AccentBlueBrush}"
                                            CornerRadius="2" />
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Pick plan"
                                                   Style="{StaticResource CardTitleStyle}"
                                                   FontSize="14" />
                                        <TextBlock Text="Champion priority"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   Margin="0,1,0,0" />
                                    </StackPanel>
                                    <TextBlock x:Name="PickPlanLockText"
                                               Grid.Column="4"
                                               Text="Lock timing unavailable."
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextAlignment="Right"
                                               TextWrapping="Wrap"
                                               MaxWidth="170"
                                               VerticalAlignment="Center" />
                                </Grid>

                                <Border Grid.Row="2"
                                        Background="{DynamicResource AppSurfaceInsetBrush}"
                                        BorderBrush="{DynamicResource AppMutedBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="6"
                                        MinHeight="76">
                                    <Grid>
                                        <TextBlock x:Name="PickChampionPlaceholderText"
                                                   Text="Waiting for champion select."
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSubtleBrush}"
                                                   FontStyle="Italic"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"
                                                   Visibility="Visible" />
                                        <ItemsControl x:Name="PickChampionPriorityList"
                                                      VerticalAlignment="Top">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource PlannerPortraitChampionChipStyle}"
                                                            ToolTip="{Binding ToolTipText}">
                                                        <Grid Width="48"
                                                              Height="64"
                                                              ClipToBounds="True">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="0" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>

                                                            <Border Grid.Row="0"
                                                                    ClipToBounds="True"
                                                                    Style="{StaticResource PlannerChampionPortraitSlotStyle}">
                                                                <Grid>
                                                                    <viewControls:ChampionMysteryGlyph Width="30"
                                                                                                       Height="30"
                                                                                                       HorizontalAlignment="Center"
                                                                                                       VerticalAlignment="Center"
                                                                                                       Foreground="{DynamicResource TextSubtleBrush}" />
                                                                    <Image Source="{Binding PortraitImageSource}"
                                                                           Stretch="UniformToFill"
                                                                           SnapsToDevicePixels="True" />
                                                                </Grid>
                                                            </Border>

                                                            <Viewbox Grid.Row="2"
                                                                     Style="{StaticResource ChampionTileLabelViewboxStyle}">
                                                                <TextBlock Text="{Binding ChipDisplayText}"
                                                                           FontSize="{Binding ChipDisplayFontSize}"
                                                                           Style="{StaticResource PlannerChampionChipTextStyle}" />
                                                            </Viewbox>

                                                            <Border Grid.Row="0"
                                                                    Panel.ZIndex="10"
                                                                    HorizontalAlignment="Right"
                                                                    VerticalAlignment="Top"
                                                                    Margin="0,2,2,0"
                                                                    Style="{StaticResource PlannerUnavailableHelpBadgeStyle}"
                                                                    ToolTip="{Binding StatusText}">
                                                                <TextBlock Text="?"
                                                                           Style="{StaticResource PlannerUnavailableHelpTextStyle}" />
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Row="3"
                                Style="{StaticResource ActionPanelStyle}"
                                Margin="12,0,12,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Width="4"
                                            Height="28"
                                            Background="{DynamicResource DangerAccentBrush}"
                                            CornerRadius="2" />
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Ban plan"
                                                   Style="{StaticResource CardTitleStyle}"
                                                   FontSize="14" />
                                        <TextBlock Text="Champion priority"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   Margin="0,1,0,0" />
                                    </StackPanel>
                                    <TextBlock x:Name="BanPlanLockText"
                                               Grid.Column="4"
                                               Text="Lock timing unavailable."
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextAlignment="Right"
                                               TextWrapping="Wrap"
                                               MaxWidth="170"
                                               VerticalAlignment="Center" />
                                </Grid>

                                <Border Grid.Row="2"
                                        Background="{DynamicResource AppSurfaceInsetBrush}"
                                        BorderBrush="{DynamicResource AppMutedBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="6"
                                        MinHeight="76">
                                    <Grid>
                                        <TextBlock x:Name="BanChampionPlaceholderText"
                                                   Text="Waiting for champion select."
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSubtleBrush}"
                                                   FontStyle="Italic"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"
                                                   Visibility="Visible" />
                                        <ItemsControl x:Name="BanChampionPriorityList"
                                                      VerticalAlignment="Top">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource PlannerPortraitChampionChipStyle}"
                                                            ToolTip="{Binding ToolTipText}">
                                                        <Grid Width="48"
                                                              Height="64"
                                                              ClipToBounds="True">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="0" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>

                                                            <Border Grid.Row="0"
                                                                    ClipToBounds="True"
                                                                    Style="{StaticResource PlannerChampionPortraitSlotStyle}">
                                                                <Grid>
                                                                    <viewControls:ChampionMysteryGlyph Width="30"
                                                                                                       Height="30"
                                                                                                       HorizontalAlignment="Center"
                                                                                                       VerticalAlignment="Center"
                                                                                                       Foreground="{DynamicResource TextSubtleBrush}" />
                                                                    <Image Source="{Binding PortraitImageSource}"
                                                                           Stretch="UniformToFill"
                                                                           SnapsToDevicePixels="True" />
                                                                </Grid>
                                                            </Border>

                                                            <Viewbox Grid.Row="2"
                                                                     Style="{StaticResource ChampionTileLabelViewboxStyle}">
                                                                <TextBlock Text="{Binding ChipDisplayText}"
                                                                           FontSize="{Binding ChipDisplayFontSize}"
                                                                           Style="{StaticResource PlannerChampionChipTextStyle}" />
                                                            </Viewbox>

                                                            <Border Grid.Row="0"
                                                                    Panel.ZIndex="10"
                                                                    HorizontalAlignment="Right"
                                                                    VerticalAlignment="Top"
                                                                    Margin="0,2,2,0"
                                                                    Style="{StaticResource PlannerUnavailableHelpBadgeStyle}"
                                                                    ToolTip="{Binding StatusText}">
                                                                <TextBlock Text="?"
                                                                           Style="{StaticResource PlannerUnavailableHelpTextStyle}" />
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="4"
                        Style="{StaticResource DraftPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Padding="12,10"
                                BorderBrush="{DynamicResource AppMutedBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <StackPanel HorizontalAlignment="Right">
                                <TextBlock Text="ENEMY TEAM"
                                           Style="{StaticResource DraftPanelHeaderStyle}"
                                           HorizontalAlignment="Right" />
                                <TextBlock Text="Current champions"
                                           Margin="0,2,0,0"
                                           Style="{StaticResource MutedTextStyle}"
                                           HorizontalAlignment="Right" />
                            </StackPanel>
                        </Border>

                        <ItemsControl x:Name="TheirTeamSlotList"
                                      Grid.Row="1">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource DraftSlotStyle}"
                                            ToolTip="{Binding PlanReferenceText}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="9" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    Style="{StaticResource DraftAvatarStyle}">
                                                <Grid>
                                                    <viewControls:ChampionMysteryGlyph Width="28"
                                                                                       Height="28"
                                                                                       HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"
                                                                                       Foreground="{DynamicResource TextSubtleBrush}" />
                                                    <Image Source="{Binding PortraitImageSource}"
                                                           Stretch="UniformToFill"
                                                           SnapsToDevicePixels="True" />
                                                </Grid>
                                            </Border>
                                            <StackPanel Grid.Column="2"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ChampionName}"
                                                           Style="{StaticResource DraftRoleTextStyle}" />
                                                <TextBlock Text="{Binding RoleName}"
                                                           MinHeight="17"
                                                           Style="{StaticResource DraftChampionTextStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="4"
                    Style="{StaticResource DraftPanelStyle}"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="9" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="8"
                                Height="8"
                                Background="{DynamicResource AccentGreenTextBrush}"
                                CornerRadius="4"
                                VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   Text="Live log"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSoftBrush}" />
                        <TextBlock Grid.Column="3"
                                   Text="Watcher output"
                                   Style="{StaticResource EyebrowTextStyle}" />
                    </Grid>

                    <Frame x:Name="EmbeddedLogsFrame"
                           Grid.Row="2"
                           NavigationUIVisibility="Hidden"
                           Background="Transparent"
                           BorderThickness="0" />
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
