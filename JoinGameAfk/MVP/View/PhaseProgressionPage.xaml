<Page x:Class="JoinGameAfk.View.PhaseProgressionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource AppSurfaceAltBrush}"
                BorderBrush="{DynamicResource AppSubtleBorderBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="18,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button x:Name="ToggleButton"
                        Grid.Column="0"
                        Width="116"
                        Background="{DynamicResource WatcherStartBrush}"
                        Content="Start"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="ToggleButton_Click" />

                <StackPanel Grid.Column="2"
                            VerticalAlignment="Center">
                    <TextBlock Text="WATCHER"
                               Style="{StaticResource EyebrowTextStyle}" />
                    <TextBlock x:Name="StatusText"
                               Text="Stopped"
                               Margin="0,3,0,0"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock x:Name="ConnectionText"
                               Margin="0,4,0,0"
                               Text="Client offline"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PhaseOfflineForegroundBrush}" />
                </StackPanel>

                <Border Grid.Column="4"
                        MinWidth="150"
                        Background="{DynamicResource AppSurfaceInsetBrush}"
                        BorderBrush="{DynamicResource AppMutedBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14,10"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="Phase"
                                   Style="{StaticResource EyebrowTextStyle}" />
                        <TextBlock Grid.Row="0"
                                   Grid.Column="2"
                                   Text="Timer"
                                   Style="{StaticResource EyebrowTextStyle}"
                                   HorizontalAlignment="Right" />

                        <TextBlock x:Name="ChampSelectSubPhaseText"
                                   Grid.Row="2"
                                   Grid.Column="0"
                                   Text=""
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="ChampSelectTimerText"
                                   Grid.Row="2"
                                   Grid.Column="2"
                                   Text=""
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBlueSoftBrush}"
                                   HorizontalAlignment="Right" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource DashboardCardStyle}">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="4"
                                Height="34"
                                Background="{DynamicResource AccentBlueBrush}"
                                CornerRadius="2" />
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Pick plan"
                                       Style="{StaticResource CardTitleStyle}" />
                            <TextBlock Text="Champion priority"
                                       Style="{StaticResource MutedTextStyle}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>

                    <Border Style="{StaticResource PriorityListContainerStyle}">
                        <Grid>
                            <TextBlock x:Name="PickChampionPlaceholderText"
                                       Text="Waiting for champion select."
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSubtleBrush}"
                                       FontStyle="Italic"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"
                                       Visibility="Visible" />
                            <ItemsControl x:Name="PickChampionPriorityList"
                                          VerticalAlignment="Center">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border>
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource PriorityChampionChipStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                            <Setter Property="Background" Value="{DynamicResource DangerSurfaceRaisedBrush}" />
                                                            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
                                                            <Setter Property="TextElement.Foreground" Value="{DynamicResource DangerTextBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Name}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource ChampionChipTextStyle}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                                <Setter Property="TextDecorations" Value="Strikethrough" />
                                                                <Setter Property="ToolTip" Value="Not currently pickable." />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <Border Background="{DynamicResource AppSurfaceInsetBrush}"
                            BorderBrush="{DynamicResource AppMutedBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="9"
                            Padding="12"
                            Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Next action"
                                       Style="{StaticResource EyebrowTextStyle}" />
                            <TextBlock x:Name="PickLockValueText"
                                       Margin="0,5,0,0"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextSoftBrush}"
                                       Text="-"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource DashboardCardStyle}">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="4"
                                Height="34"
                                Background="{DynamicResource DangerAccentBrush}"
                                CornerRadius="2" />
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Ban plan"
                                       Style="{StaticResource CardTitleStyle}" />
                            <TextBlock Text="Champion priority"
                                       Style="{StaticResource MutedTextStyle}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>

                    <Border Style="{StaticResource PriorityListContainerStyle}">
                        <Grid>
                            <TextBlock x:Name="BanChampionPlaceholderText"
                                       Text="Waiting for champion select."
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSubtleBrush}"
                                       FontStyle="Italic"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"
                                       Visibility="Visible" />
                            <ItemsControl x:Name="BanChampionPriorityList"
                                          VerticalAlignment="Center">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border>
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource PriorityChampionChipStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                            <Setter Property="Background" Value="{DynamicResource DangerSurfaceRaisedBrush}" />
                                                            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
                                                            <Setter Property="TextElement.Foreground" Value="{DynamicResource DangerTextBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Name}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource ChampionChipTextStyle}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                                <Setter Property="TextDecorations" Value="Strikethrough" />
                                                                <Setter Property="ToolTip" Value="Not currently bannable." />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <Border Background="{DynamicResource AppSurfaceInsetBrush}"
                            BorderBrush="{DynamicResource AppMutedBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="9"
                            Padding="12"
                            Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Next action"
                                       Style="{StaticResource EyebrowTextStyle}" />
                            <TextBlock x:Name="BanLockValueText"
                                       Margin="0,5,0,0"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextSoftBrush}"
                                       Text="-"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="4"
                Style="{StaticResource DashboardCardStyle}"
                Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="8"
                            Height="8"
                            Background="{DynamicResource AccentGreenTextBrush}"
                            CornerRadius="4"
                            VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2"
                               Text="Live log"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSoftBrush}" />
                </Grid>

                <Frame x:Name="EmbeddedLogsFrame"
                       Grid.Row="2"
                       NavigationUIVisibility="Hidden"
                       Background="Transparent"
                       BorderThickness="0" />
            </Grid>
        </Border>
    </Grid>
</Page>
