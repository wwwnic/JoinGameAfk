<Page x:Class="JoinGameAfk.View.PhaseProgressionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      SizeChanged="Page_SizeChanged">
    <Page.Resources>
        <Style x:Key="DraftPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="DraftPanelHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="DraftSlotStyle" TargetType="Border">
            <Setter Property="MinHeight" Value="54" />
            <Setter Property="Padding" Value="9,8" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppMutedBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style x:Key="DraftAvatarStyle" TargetType="Border">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="{DynamicResource AppInputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppStrongBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="TextElement.Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        </Style>

        <Style x:Key="DraftAvatarTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextSoftBrush}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="DraftRoleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
        </Style>

        <Style x:Key="DraftChampionTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="RoleChipStyle" TargetType="Border">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Background" Value="{DynamicResource AppSurfaceInsetBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppMutedBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="TextElement.Foreground" Value="{DynamicResource TextMutedBrush}" />
        </Style>

        <Style x:Key="ActiveRoleChipStyle" TargetType="Border" BasedOn="{StaticResource RoleChipStyle}">
            <Setter Property="Background" Value="{DynamicResource AccentBlueInfoBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}" />
            <Setter Property="TextElement.Foreground" Value="{DynamicResource AccentBluePaleBrush}" />
        </Style>

        <Style x:Key="ActionPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppStrongBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
        </Style>

        <Style x:Key="TinyStatusPillStyle" TargetType="Border">
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="Padding" Value="9,0" />
            <Setter Property="Background" Value="{DynamicResource AppInputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppStrongBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
        </Style>

        <Style x:Key="HeaderActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource AccentButtonStyle}">
            <Setter Property="Width" Value="124" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition x:Name="LogRow" Height="190" />
            </Grid.RowDefinitions>

            <Border x:Name="HeaderPanel"
                    Grid.Row="0"
                    Background="{DynamicResource AppSurfaceAltBrush}"
                    BorderBrush="{DynamicResource AppSubtleBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16,11">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="150" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="132" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" MinWidth="150" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0"
                          VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button x:Name="ToggleButton"
                                Grid.Column="0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Background="{DynamicResource WatcherStartBrush}"
                                Content="Start watcher"
                                Style="{StaticResource HeaderActionButtonStyle}"
                                Click="ToggleButton_Click" />

                        <StackPanel Grid.Column="2"
                                    VerticalAlignment="Center">
                            <TextBlock Text="CURRENT PHASE"
                                       Style="{StaticResource EyebrowTextStyle}" />
                            <TextBlock x:Name="StatusText"
                                       Text="Stopped"
                                       Margin="0,2,0,0"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Column="2"
                            MinHeight="68"
                            BorderBrush="{DynamicResource AccentBlueBrush}"
                            BorderThickness="1,0"
                            Padding="10,5"
                            VerticalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="ChampSelectTimerText"
                                       Text="--"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBlueSoftBrush}"
                                       HorizontalAlignment="Center"
                                       LineHeight="34"
                                       LineStackingStrategy="BlockLineHeight" />
                            <TextBlock Text="seconds"
                                       Margin="0,4,0,0"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="4"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="ConnectionText"
                                   Visibility="Collapsed"
                                   Text="Client offline"
                                   Foreground="{DynamicResource PhaseOfflineForegroundBrush}" />
                        <TextBlock x:Name="ChampSelectSubPhaseText"
                                   Visibility="Collapsed"
                                   Text="Idle" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid x:Name="DraftLayoutGrid"
                  Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" MinWidth="170" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="2.2*" MinWidth="280" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="1.05*" MinWidth="170" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource DraftPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Padding="12,10"
                                BorderBrush="{DynamicResource AppMutedBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <StackPanel>
                                <TextBlock Text="YOUR TEAM"
                                           Style="{StaticResource DraftPanelHeaderStyle}" />
                                <TextBlock Text="Live slots later"
                                           Margin="0,2,0,0"
                                           Style="{StaticResource MutedTextStyle}" />
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Row="1">
                            <Border Style="{StaticResource DraftSlotStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="9" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Style="{StaticResource DraftAvatarStyle}">
                                        <TextBlock Text="T"
                                                   Style="{StaticResource DraftAvatarTextStyle}" />
                                    </Border>
                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Top"
                                                   Style="{StaticResource DraftRoleTextStyle}" />
                                        <TextBlock Text="Waiting"
                                                   Style="{StaticResource DraftChampionTextStyle}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource DraftSlotStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="9" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Style="{StaticResource DraftAvatarStyle}">
                                        <TextBlock Text="J"
                                                   Style="{StaticResource DraftAvatarTextStyle}" />
                                    </Border>
                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Jungle"
                                                   Style="{StaticResource DraftRoleTextStyle}" />
                                        <TextBlock Text="Waiting"
                                                   Style="{StaticResource DraftChampionTextStyle}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource DraftSlotStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="9" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Style="{StaticResource DraftAvatarStyle}"
                                            BorderBrush="{DynamicResource AccentBlueBrush}">
                                        <TextBlock Text="M"
                                                   Style="{StaticResource DraftAvatarTextStyle}"
                                                   Foreground="{DynamicResource AccentBluePaleBrush}" />
                                    </Border>
                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Mid"
                                                   Style="{StaticResource DraftRoleTextStyle}" />
                                        <TextBlock Text="Local role"
                                                   Style="{StaticResource DraftChampionTextStyle}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource DraftSlotStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="9" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Style="{StaticResource DraftAvatarStyle}">
                                        <TextBlock Text="A"
                                                   Style="{StaticResource DraftAvatarTextStyle}" />
                                    </Border>
                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="ADC"
                                                   Style="{StaticResource DraftRoleTextStyle}" />
                                        <TextBlock Text="Waiting"
                                                   Style="{StaticResource DraftChampionTextStyle}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource DraftSlotStyle}"
                                    BorderThickness="0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="9" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Style="{StaticResource DraftAvatarStyle}">
                                        <TextBlock Text="S"
                                                   Style="{StaticResource DraftAvatarTextStyle}" />
                                    </Border>
                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Support"
                                                   Style="{StaticResource DraftRoleTextStyle}" />
                                        <TextBlock Text="Waiting"
                                                   Style="{StaticResource DraftChampionTextStyle}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource DraftPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Padding="12,10"
                                BorderBrush="{DynamicResource AppMutedBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="PLANNER VIEW"
                                               Style="{StaticResource DraftPanelHeaderStyle}" />
                                    <TextBlock Text="Priority lists from your app settings"
                                               Margin="0,2,0,0"
                                               Style="{StaticResource MutedTextStyle}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <UniformGrid Grid.Row="1"
                                     Columns="6"
                                     Margin="12,12,12,0">
                            <Border Style="{StaticResource RoleChipStyle}"
                                    Margin="0,0,6,0">
                                <TextBlock Text="Top"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <Border Style="{StaticResource RoleChipStyle}"
                                    Margin="0,0,6,0">
                                <TextBlock Text="Jungle"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <Border Style="{StaticResource ActiveRoleChipStyle}"
                                    Margin="0,0,6,0">
                                <TextBlock Text="Mid"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <Border Style="{StaticResource RoleChipStyle}"
                                    Margin="0,0,6,0">
                                <TextBlock Text="ADC"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <Border Style="{StaticResource RoleChipStyle}"
                                    Margin="0,0,6,0">
                                <TextBlock Text="Support"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <Border Style="{StaticResource RoleChipStyle}">
                                <TextBlock Text="None"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                        </UniformGrid>

                        <Border Grid.Row="2"
                                Style="{StaticResource ActionPanelStyle}"
                                Margin="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Width="48"
                                        Height="48"
                                        Background="{DynamicResource AccentBlueInfoBrush}"
                                        BorderBrush="{DynamicResource AccentBlueBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <TextBlock Text="JG"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource AccentBluePaleBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="2"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Current action"
                                               Style="{StaticResource EyebrowTextStyle}" />
                                    <TextBlock Text="Champion select plan"
                                               Margin="0,2,0,0"
                                               FontSize="19"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="The live pick and ban recommendations below still use the existing dashboard data."
                                               Margin="0,3,0,0"
                                               Style="{StaticResource MutedTextStyle}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="3"
                              Margin="12,0,12,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource ActionPanelStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Width="4"
                                                Height="28"
                                                Background="{DynamicResource AccentBlueBrush}"
                                                CornerRadius="2" />
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Pick plan"
                                                       Style="{StaticResource CardTitleStyle}"
                                                       FontSize="14" />
                                            <TextBlock Text="Champion priority"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       Margin="0,1,0,0" />
                                        </StackPanel>
                                    </Grid>

                                    <Border Grid.Row="2"
                                            Background="{DynamicResource AppSurfaceInsetBrush}"
                                            BorderBrush="{DynamicResource AppMutedBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="8"
                                            MinHeight="96">
                                        <Grid>
                                            <TextBlock x:Name="PickChampionPlaceholderText"
                                                       Text="Waiting for champion select."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSubtleBrush}"
                                                       FontStyle="Italic"
                                                       TextWrapping="Wrap"
                                                       VerticalAlignment="Center"
                                                       Visibility="Visible" />
                                            <ItemsControl x:Name="PickChampionPriorityList"
                                                          VerticalAlignment="Top">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,0,6"
                                                                Padding="7,6"
                                                                Background="{DynamicResource AppInputBrush}"
                                                                BorderBrush="{DynamicResource AppStrongBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="7">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="26" />
                                                                    <ColumnDefinition Width="8" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <Border Grid.Column="0"
                                                                        Width="26"
                                                                        Height="26"
                                                                        Background="{DynamicResource AccentBlueInfoBrush}"
                                                                        BorderBrush="{DynamicResource AccentBlueBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="7">
                                                                    <TextBlock Text="{Binding Name[0]}"
                                                                               FontSize="11"
                                                                               FontWeight="Bold"
                                                                               Foreground="{DynamicResource AccentBluePaleBrush}"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center" />
                                                                </Border>
                                                                <TextBlock Grid.Column="2"
                                                                           Text="{Binding Name}"
                                                                           Style="{StaticResource ChampionChipTextStyle}"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                           TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Grid.Column="3"
                                                                           FontSize="10"
                                                                           FontWeight="Bold"
                                                                           Foreground="{DynamicResource AccentGreenTextBrush}"
                                                                           VerticalAlignment="Center">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="Pick" />
                                                                            <Setter Property="TextDecorations" Value="{x:Null}" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                                                    <Setter Property="Foreground" Value="{DynamicResource DangerTextBrush}" />
                                                                                    <Setter Property="Text" Value="Blocked" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Grid>
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Opacity" Value="1" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                                            <Setter Property="Background" Value="{DynamicResource DangerSurfaceRaisedBrush}" />
                                                                            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
                                                                            <Setter Property="Opacity" Value="0.88" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Row="4">
                                        <TextBlock Text="Next action"
                                                   Style="{StaticResource EyebrowTextStyle}" />
                                        <TextBlock x:Name="PickLockValueText"
                                                   Margin="0,4,0,0"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSoftBrush}"
                                                   Text="-"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2"
                                    Style="{StaticResource ActionPanelStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Width="4"
                                                Height="28"
                                                Background="{DynamicResource DangerAccentBrush}"
                                                CornerRadius="2" />
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Ban plan"
                                                       Style="{StaticResource CardTitleStyle}"
                                                       FontSize="14" />
                                            <TextBlock Text="Champion priority"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       Margin="0,1,0,0" />
                                        </StackPanel>
                                    </Grid>

                                    <Border Grid.Row="2"
                                            Background="{DynamicResource AppSurfaceInsetBrush}"
                                            BorderBrush="{DynamicResource AppMutedBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="8"
                                            MinHeight="96">
                                        <Grid>
                                            <TextBlock x:Name="BanChampionPlaceholderText"
                                                       Text="Waiting for champion select."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSubtleBrush}"
                                                       FontStyle="Italic"
                                                       TextWrapping="Wrap"
                                                       VerticalAlignment="Center"
                                                       Visibility="Visible" />
                                            <ItemsControl x:Name="BanChampionPriorityList"
                                                          VerticalAlignment="Top">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,0,6"
                                                                Padding="7,6"
                                                                Background="{DynamicResource AppInputBrush}"
                                                                BorderBrush="{DynamicResource AppStrongBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="7">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="26" />
                                                                    <ColumnDefinition Width="8" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <Border Grid.Column="0"
                                                                        Width="26"
                                                                        Height="26"
                                                                        Background="{DynamicResource DangerSurfaceBrush}"
                                                                        BorderBrush="{DynamicResource DangerAccentBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="7">
                                                                    <TextBlock Text="{Binding Name[0]}"
                                                                               FontSize="11"
                                                                               FontWeight="Bold"
                                                                               Foreground="{DynamicResource DangerTextPaleBrush}"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center" />
                                                                </Border>
                                                                <TextBlock Grid.Column="2"
                                                                           Text="{Binding Name}"
                                                                           Style="{StaticResource ChampionChipTextStyle}"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                           TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Grid.Column="3"
                                                                           FontSize="10"
                                                                           FontWeight="Bold"
                                                                           Foreground="{DynamicResource DangerTextSoftBrush}"
                                                                           VerticalAlignment="Center">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="Ban" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                                                    <Setter Property="Foreground" Value="{DynamicResource DangerTextBrush}" />
                                                                                    <Setter Property="Text" Value="Blocked" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Grid>
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Opacity" Value="1" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                                            <Setter Property="Background" Value="{DynamicResource DangerSurfaceRaisedBrush}" />
                                                                            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
                                                                            <Setter Property="Opacity" Value="0.88" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Row="4">
                                        <TextBlock Text="Next action"
                                                   Style="{StaticResource EyebrowTextStyle}" />
                                        <TextBlock x:Name="BanLockValueText"
                                                   Margin="0,4,0,0"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSoftBrush}"
                                                   Text="-"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Column="4"
                        Style="{StaticResource DraftPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Padding="12,10"
                                BorderBrush="{DynamicResource AppMutedBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <StackPanel HorizontalAlignment="Right">
                                <TextBlock Text="ENEMY TEAM"
                                           Style="{StaticResource DraftPanelHeaderStyle}"
                                           HorizontalAlignment="Right" />
                                <TextBlock Text="Live slots later"
                                           Margin="0,2,0,0"
                                           Style="{StaticResource MutedTextStyle}"
                                           HorizontalAlignment="Right" />
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Row="1">
                            <Border Style="{StaticResource DraftSlotStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="9" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Right">
                                        <TextBlock Text="Top"
                                                   Style="{StaticResource DraftRoleTextStyle}"
                                                   HorizontalAlignment="Right" />
                                        <TextBlock Text="Unknown"
                                                   Style="{StaticResource DraftChampionTextStyle}"
                                                   HorizontalAlignment="Right" />
                                    </StackPanel>
                                    <Border Grid.Column="2"
                                            Style="{StaticResource DraftAvatarStyle}">
                                        <TextBlock Text="?"
                                                   Style="{StaticResource DraftAvatarTextStyle}" />
                                    </Border>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource DraftSlotStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="9" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Right">
                                        <TextBlock Text="Jungle"
                                                   Style="{StaticResource DraftRoleTextStyle}"
                                                   HorizontalAlignment="Right" />
                                        <TextBlock Text="Unknown"
                                                   Style="{StaticResource DraftChampionTextStyle}"
                                                   HorizontalAlignment="Right" />
                                    </StackPanel>
                                    <Border Grid.Column="2"
                                            Style="{StaticResource DraftAvatarStyle}">
                                        <TextBlock Text="?"
                                                   Style="{StaticResource DraftAvatarTextStyle}" />
                                    </Border>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource DraftSlotStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="9" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Right">
                                        <TextBlock Text="Mid"
                                                   Style="{StaticResource DraftRoleTextStyle}"
                                                   HorizontalAlignment="Right" />
                                        <TextBlock Text="Unknown"
                                                   Style="{StaticResource DraftChampionTextStyle}"
                                                   HorizontalAlignment="Right" />
                                    </StackPanel>
                                    <Border Grid.Column="2"
                                            Style="{StaticResource DraftAvatarStyle}"
                                            BorderBrush="{DynamicResource DangerAccentBrush}">
                                        <TextBlock Text="?"
                                                   Style="{StaticResource DraftAvatarTextStyle}"
                                                   Foreground="{DynamicResource DangerTextPaleBrush}" />
                                    </Border>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource DraftSlotStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="9" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Right">
                                        <TextBlock Text="ADC"
                                                   Style="{StaticResource DraftRoleTextStyle}"
                                                   HorizontalAlignment="Right" />
                                        <TextBlock Text="Unknown"
                                                   Style="{StaticResource DraftChampionTextStyle}"
                                                   HorizontalAlignment="Right" />
                                    </StackPanel>
                                    <Border Grid.Column="2"
                                            Style="{StaticResource DraftAvatarStyle}">
                                        <TextBlock Text="?"
                                                   Style="{StaticResource DraftAvatarTextStyle}" />
                                    </Border>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource DraftSlotStyle}"
                                    BorderThickness="0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="9" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Right">
                                        <TextBlock Text="Support"
                                                   Style="{StaticResource DraftRoleTextStyle}"
                                                   HorizontalAlignment="Right" />
                                        <TextBlock Text="Unknown"
                                                   Style="{StaticResource DraftChampionTextStyle}"
                                                   HorizontalAlignment="Right" />
                                    </StackPanel>
                                    <Border Grid.Column="2"
                                            Style="{StaticResource DraftAvatarStyle}">
                                        <TextBlock Text="?"
                                                   Style="{StaticResource DraftAvatarTextStyle}" />
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="4"
                    Style="{StaticResource DraftPanelStyle}"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="9" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="8"
                                Height="8"
                                Background="{DynamicResource AccentGreenTextBrush}"
                                CornerRadius="4"
                                VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   Text="Live log"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSoftBrush}" />
                        <TextBlock Grid.Column="3"
                                   Text="Watcher output"
                                   Style="{StaticResource EyebrowTextStyle}" />
                    </Grid>

                    <Frame x:Name="EmbeddedLogsFrame"
                           Grid.Row="2"
                           NavigationUIVisibility="Hidden"
                           Background="Transparent"
                           BorderThickness="0" />
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
