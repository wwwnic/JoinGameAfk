<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#05070D" />
    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#0B0E14" />
    <SolidColorBrush x:Key="AppSurfaceAltBrush" Color="#12121A" />
    <SolidColorBrush x:Key="AppSurfaceRaisedBrush" Color="#111827" />
    <SolidColorBrush x:Key="AppSurfaceInsetBrush" Color="#0F172A" />
    <SolidColorBrush x:Key="AppInputBrush" Color="#182338" />
    <SolidColorBrush x:Key="AppInputHoverBrush" Color="#22304A" />
    <SolidColorBrush x:Key="AppInputPressedBrush" Color="#17223A" />
    <SolidColorBrush x:Key="AppInputFocusBrush" Color="#1E293B" />

    <SolidColorBrush x:Key="AppSubtleBorderBrush" Color="#1E1E2A" />
    <SolidColorBrush x:Key="AppBorderBrush" Color="#232836" />
    <SolidColorBrush x:Key="AppMutedBorderBrush" Color="#1E293B" />
    <SolidColorBrush x:Key="AppStrongBorderBrush" Color="#334155" />
    <SolidColorBrush x:Key="AppHoverBorderBrush" Color="#475569" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F8FAFC" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#E2E8F0" />
    <SolidColorBrush x:Key="TextSoftBrush" Color="#CBD5E1" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#94A3B8" />
    <SolidColorBrush x:Key="TextSubtleBrush" Color="#64748B" />
    <SolidColorBrush x:Key="TextInverseBrush" Color="#FFFFFF" />

    <SolidColorBrush x:Key="AccentBlueBrush" Color="#60A5FA" />
    <SolidColorBrush x:Key="AccentBlueSoftBrush" Color="#93C5FD" />
    <SolidColorBrush x:Key="AccentBluePaleBrush" Color="#BFDBFE" />
    <SolidColorBrush x:Key="AccentBlueTextBrush" Color="#EFF6FF" />
    <SolidColorBrush x:Key="AccentBlueDeepBrush" Color="#1E3A8A" />
    <SolidColorBrush x:Key="AccentBlueStrongBrush" Color="#1D4ED8" />
    <SolidColorBrush x:Key="AccentBlueActionBrush" Color="#2563EB" />
    <SolidColorBrush x:Key="AccentBlueInfoBrush" Color="#102647" />

    <SolidColorBrush x:Key="AccentGreenBrush" Color="#2E7D32" />
    <SolidColorBrush x:Key="AccentGreenTextBrush" Color="#7DD3A3" />
    <SolidColorBrush x:Key="AccentConnectedBrush" Color="#4ADE80" />
    <SolidColorBrush x:Key="AccentAmberBrush" Color="#F59E0B" />

    <SolidColorBrush x:Key="DangerBrush" Color="#DC2626" />
    <SolidColorBrush x:Key="DangerStrongBrush" Color="#C62828" />
    <SolidColorBrush x:Key="DangerSurfaceBrush" Color="#2A1114" />
    <SolidColorBrush x:Key="DangerOverlayBrush" Color="#992A1114" />
    <SolidColorBrush x:Key="DangerSurfaceRaisedBrush" Color="#351417" />
    <SolidColorBrush x:Key="DangerSurfaceDeepBrush" Color="#3A1114" />
    <SolidColorBrush x:Key="DangerBorderBrush" Color="#7F1D1D" />
    <SolidColorBrush x:Key="DangerAccentBrush" Color="#EF4444" />
    <SolidColorBrush x:Key="DangerHoverBrush" Color="#991B1B" />
    <SolidColorBrush x:Key="DangerCloseHoverBrush" Color="#B91C1C" />
    <SolidColorBrush x:Key="DangerLightBrush" Color="#F87171" />
    <SolidColorBrush x:Key="DangerTextBrush" Color="#FCA5A5" />
    <SolidColorBrush x:Key="DangerTextSoftBrush" Color="#FECACA" />
    <SolidColorBrush x:Key="DangerTextPaleBrush" Color="#FEE2E2" />

    <SolidColorBrush x:Key="TabActiveBackgroundBrush" Color="#1E293B" />
    <SolidColorBrush x:Key="TabInactiveBackgroundBrush" Color="#0F172A" />
    <SolidColorBrush x:Key="TabActiveForegroundBrush" Color="#E2E8F0" />
    <SolidColorBrush x:Key="TabInactiveForegroundBrush" Color="#94A3B8" />
    <SolidColorBrush x:Key="TabActiveBorderBrush" Color="#60A5FA" />
    <SolidColorBrush x:Key="TabInactiveBorderBrush" Color="#1E293B" />

    <SolidColorBrush x:Key="WatcherStartBrush" Color="#2E7D32" />
    <SolidColorBrush x:Key="WatcherStopBrush" Color="#C62828" />
    <SolidColorBrush x:Key="PhaseConnectedForegroundBrush" Color="#4ADE80" />
    <SolidColorBrush x:Key="PhaseOfflineForegroundBrush" Color="#FCA5A5" />
    <SolidColorBrush x:Key="PhaseLobbyBrush" Color="#3B82F6" />
    <SolidColorBrush x:Key="PhaseReadyCheckBrush" Color="#2E7D32" />
    <SolidColorBrush x:Key="PhaseHoverBrush" Color="#F59E0B" />
    <SolidColorBrush x:Key="PhaseBanBrush" Color="#DC2626" />
    <SolidColorBrush x:Key="PhaseDefaultBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TargetActiveBrush" Color="#3B82F6" />
    <SolidColorBrush x:Key="TargetInactiveBrush" Color="#334155" />
    <SolidColorBrush x:Key="TargetDropHoverBrush" Color="#60A5FA" />
    <SolidColorBrush x:Key="TargetActiveBackgroundBrush" Color="#0F1B2D" />
    <SolidColorBrush x:Key="TargetInactiveBackgroundBrush" Color="#111827" />
    <SolidColorBrush x:Key="TargetDropHoverBackgroundBrush" Color="#102A43" />

    <Style x:Key="AppWindowBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppSubtleBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=WindowState}" Value="Maximized">
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="0" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="TitleBarButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="38" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Margin" Value="6,0,0,0" />
        <Setter Property="Foreground" Value="{StaticResource TextSoftBrush}" />
        <Setter Property="Background" Value="{StaticResource AppSurfaceInsetBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppMutedBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource AppInputFocusBrush}" />
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource AppStrongBorderBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.78" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CloseButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource TitleBarButtonStyle}">
        <Setter Property="Background" Value="{StaticResource DangerSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DangerBorderBrush}" />
        <Setter Property="Foreground" Value="{StaticResource DangerTextBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource DangerCloseHoverBrush}" />
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource DangerLightBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource TextInverseBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.78" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TabButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="16,7" />
        <Setter Property="Margin" Value="0,0,6,0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Background" Value="{StaticResource TabInactiveBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TabInactiveForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource TabInactiveBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="TabBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="9"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="TabBorder" Property="Opacity" Value="0.9" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="TabBorder" Property="Opacity" Value="0.76" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AccentButtonStyle" TargetType="Button">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextInverseBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="MinHeight" Value="42" />
        <Setter Property="Padding" Value="22,11" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="10"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.9" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.75" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource AccentButtonStyle}">
        <Setter Property="Background" Value="{StaticResource AppInputFocusBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
    </Style>

    <Style x:Key="DashboardCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style x:Key="SectionCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style x:Key="SettingRowStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource AppSurfaceRaisedBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppStrongBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="Margin" Value="0,10,0,0" />
    </Style>

    <Style x:Key="PriorityListContainerStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource AppSurfaceRaisedBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppStrongBorderBrush}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="MinHeight" Value="46" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <Style x:Key="PriorityChampionChipStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource AppInputBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppStrongBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="Margin" Value="0,3,6,3" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="TextElement.Foreground" Value="{StaticResource TextSoftBrush}" />
    </Style>

    <Style x:Key="ChampionPillBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource AppInputBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppStrongBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Cursor" Value="SizeAll" />
        <Setter Property="TextElement.Foreground" Value="{StaticResource TextSoftBrush}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource AppInputBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource AppHoverBorderBrush}" />
                <Setter Property="ToolTip" Value="Drag to reorder" />
            </Trigger>
            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                <Setter Property="Background" Value="{StaticResource AccentBlueDeepBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource AccentBlueSoftBrush}" />
                <Setter Property="TextElement.Foreground" Value="{StaticResource AccentBlueTextBrush}" />
                <Setter Property="ToolTip" Value="Selected" />
            </DataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsSelected}" Value="True" />
                    <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True" />
                </MultiDataTrigger.Conditions>
                <Setter Property="Background" Value="{StaticResource AccentBlueStrongBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource AccentBluePaleBrush}" />
                <Setter Property="TextElement.Foreground" Value="{StaticResource TextInverseBrush}" />
            </MultiDataTrigger>
            <DataTrigger Binding="{Binding IsDuplicateDropTarget}" Value="True">
                <Setter Property="Background" Value="{StaticResource DangerSurfaceDeepBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource DangerAccentBrush}" />
                <Setter Property="TextElement.Foreground" Value="{StaticResource DangerTextSoftBrush}" />
                <Setter Property="ToolTip" Value="This existing champion will be replaced if you drop here." />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ChampionReferenceButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AppInputBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppStrongBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="SizeAll" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,3,6,3" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="ToolTip" Value="Click to add to the selected list, or drag into a pick/ban list." />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}"
                            TextElement.Foreground="{TemplateBinding Foreground}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource AppInputHoverBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource AppInputPressedBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource AccentBlueSoftBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="DeleteSelectedButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="Background" Value="{StaticResource DangerBorderBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DangerAccentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="{StaticResource DangerTextPaleBrush}" />
        <Setter Property="ToolTip" Value="Delete selected champions" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            TextElement.Foreground="{TemplateBinding Foreground}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource DangerHoverBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource DangerLightBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="{StaticResource AppInputFocusBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource AppStrongBorderBrush}" />
                <Setter Property="Foreground" Value="{StaticResource TextSubtleBrush}" />
                <Setter Property="Cursor" Value="Arrow" />
                <Setter Property="ToolTip" Value="Select one or more champions to delete." />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="BaseTextBoxStyle" TargetType="TextBox">
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Background" Value="{StaticResource AppInputBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppStrongBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="InputBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="InputBorder" Property="BorderBrush" Value="{StaticResource AccentBlueBrush}" />
                            <Setter TargetName="InputBorder" Property="Background" Value="{StaticResource AppInputFocusBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="InputBorder" Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SearchTextBoxStyle"
           TargetType="TextBox"
           BasedOn="{StaticResource BaseTextBoxStyle}" />

    <Style x:Key="InputTextBoxStyle"
           TargetType="TextBox"
           BasedOn="{StaticResource BaseTextBoxStyle}">
        <Setter Property="Width" Value="110" />
        <Setter Property="HorizontalContentAlignment" Value="Right" />
    </Style>

    <Style x:Key="PageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="PageDescriptionStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
    </Style>

    <Style x:Key="SectionDescriptionStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextSoftBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="FieldHintStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource TextSubtleBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Margin" Value="0,3,0,0" />
    </Style>

    <Style x:Key="EyebrowTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextSubtleBrush}" />
    </Style>

    <Style x:Key="CardTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
    </Style>

    <Style x:Key="MutedTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="ChampionChipTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="LineHeight" Value="16" />
        <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
    </Style>

    <Style x:Key="InfoIndicatorStyle" TargetType="Button">
        <Setter Property="Width" Value="22" />
        <Setter Property="Height" Value="22" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{StaticResource AccentBluePaleBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Background" Value="{StaticResource AccentBlueInfoBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentBlueStrongBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="ToolTipService.InitialShowDelay" Value="150" />
        <Setter Property="ToolTipService.ShowDuration" Value="20000" />
        <Setter Property="ToolTipService.Placement" Value="Mouse" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="InfoBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="11">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="InfoBorder" Property="Background" Value="{StaticResource AccentBlueDeepBrush}" />
                            <Setter TargetName="InfoBorder" Property="BorderBrush" Value="{StaticResource AccentBlueBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource AccentBlueTextBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AppCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextSoftBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="CheckBorder"
                                Width="20"
                                Height="20"
                                Background="{StaticResource AppInputBrush}"
                                BorderBrush="{StaticResource AppStrongBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="5">
                            <Path x:Name="CheckMark"
                                  Data="M4,10 L8,14 L16,6"
                                  Stroke="{StaticResource TextInverseBrush}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Visibility="Collapsed" />
                        </Border>
                        <ContentPresenter Grid.Column="2"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{StaticResource AccentBlueBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckBorder" Property="Background" Value="{StaticResource AccentBlueActionBrush}" />
                            <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{StaticResource AccentBlueBrush}" />
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="CheckBorder" Property="Opacity" Value="0.55" />
                            <Setter Property="Foreground" Value="{StaticResource TextSubtleBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="{StaticResource AppSurfaceInsetBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppStrongBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="HasDropShadow" Value="True" />
    </Style>
</ResourceDictionary>
